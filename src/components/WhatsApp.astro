---
const { lang = "es" } = Astro.props;
const number = "34639501310";
const msg = lang === "en"
  ? "Hi! I have a question about La Negra World Championship"
  : "¡Hola! Tengo una consulta sobre La Negra World Championship";
const tip = lang === "en" ? "Any questions?" : "¿Tienes alguna duda?";
const href = `https://wa.me/${number}?text=${encodeURIComponent(msg)}`;
---
<a class="wa-float" href={href} target="_blank" rel="noopener" aria-label="WhatsApp">
  <span class="wa-label">{tip}</span>
  <span class="wa-icon">
    <svg viewBox="0 0 24 24" width="30" height="30" aria-hidden="true">
      <path fill="#fff" d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.91-7.02zM12.04 20.15h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24a8.2 8.2 0 0 1 5.83 2.42 8.2 8.2 0 0 1 2.41 5.83c0 4.54-3.7 8.23-8.25 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.17.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.12-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.43-.14-.01-.31-.01-.48-.01-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z"/>
    </svg>
  </span>
</a>

<style>
  .wa-float {
    position: fixed;
    bottom: 18px;
    right: 18px;
    z-index: 1500;
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .wa-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #25d366;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.22);
    transition: transform 0.2s ease;
  }
  .wa-float:hover .wa-icon { transform: scale(1.06); }
  .wa-label {
    background: #25d366;
    color: #fff;
    padding: 8px 14px;
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 14px;
    white-space: nowrap;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
    opacity: 0;
    transform: translateX(8px);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .wa-float:hover .wa-label { opacity: 1; transform: translateX(0); }
  @media (max-width: 640px) {
    .wa-float { bottom: 14px; right: 14px; }
    .wa-icon { width: 52px; height: 52px; }
    .wa-label { display: none; }
  }
</style>
