---
// Analítica con consentimiento previo (RGPD/AEPD): NADA se carga hasta que el
// usuario pulsa "Aceptar". Se cargan dos cosas:
//  · GA4 (gtag.js) directamente — ID en PUBLIC_GA_ID
//  · Google Tag Manager — ID en PUBLIC_GTM_ID (para píxeles/conversiones)
// OJO: no configures TAMBIÉN GA4 dentro de GTM o contarías las visitas dos veces.
import { COOKIES_BANNER } from "../data/nav.js";
const { lang = "es" } = Astro.props;
const GTM_ID = import.meta.env.PUBLIC_GTM_ID || "GTM-PFLT7J29";
const GA_ID = import.meta.env.PUBLIC_GA_ID || "G-MCTNDLVYZ0";
const c = COOKIES_BANNER[lang] || COOKIES_BANNER.es;
---
{(GTM_ID || GA_ID) && (
  <>
    <div class="cookie-banner" id="cookieBanner" role="dialog" aria-label="Cookies" hidden>
      <p class="cb-text">{c.text} <a href={c.moreUrl}>{c.more}</a></p>
      <div class="cb-actions">
        <button type="button" class="cb-btn cb-reject" data-cc="denied">{c.reject}</button>
        <button type="button" class="cb-btn cb-accept" data-cc="granted">{c.accept}</button>
      </div>
    </div>

    <script define:vars={{ GTM_ID, GA_ID }}>
      (function () {
        var KEY = "lng:consent";
        function loadGTM() {
          if (!GTM_ID || window.__gtmLoaded) return;
          window.__gtmLoaded = true;
          (function (w, d, s, l, i) {
            w[l] = w[l] || [];
            w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.start" });
            var f = d.getElementsByTagName(s)[0],
              j = d.createElement(s),
              dl = l != "dataLayer" ? "&l=" + l : "";
            j.async = true;
            j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
            f.parentNode.insertBefore(j, f);
          })(window, document, "script", "dataLayer", GTM_ID);
        }
        // GA4 (gtag.js) — mismo tag que da Google, pero solo tras aceptar
        function loadGA() {
          if (!GA_ID || window.__gaLoaded) return;
          window.__gaLoaded = true;
          var s = document.createElement("script");
          s.async = true;
          s.src = "https://www.googletagmanager.com/gtag/js?id=" + GA_ID;
          document.head.appendChild(s);
          window.dataLayer = window.dataLayer || [];
          window.gtag = function () { window.dataLayer.push(arguments); };
          window.gtag("js", new Date());
          window.gtag("config", GA_ID);
        }
        function loadAll() { loadGA(); loadGTM(); }
        var banner = document.getElementById("cookieBanner");
        var choice = null;
        try { choice = localStorage.getItem(KEY); } catch (e) {}
        if (choice === "granted") { loadAll(); }
        else if (choice !== "denied" && banner) { banner.hidden = false; }
        if (banner) {
          banner.querySelectorAll("[data-cc]").forEach(function (b) {
            b.addEventListener("click", function () {
              var v = b.getAttribute("data-cc");
              try { localStorage.setItem(KEY, v); } catch (e) {}
              banner.hidden = true;
              if (v === "granted") loadAll();
            });
          });
        }
      })();
    </script>

    <style>
      .cookie-banner {
        position: fixed; left: 16px; right: 16px; bottom: 16px; z-index: 4000;
        max-width: 580px; margin: 0 auto;
        background: #14121a; color: #fff; border-radius: 14px; padding: 15px 18px;
        box-shadow: 0 16px 44px rgba(0, 0, 0, .35);
        display: flex; flex-wrap: wrap; gap: 12px; align-items: center; justify-content: space-between;
      }
      .cookie-banner[hidden] { display: none; }
      .cb-text { margin: 0; font-size: 13px; line-height: 1.5; flex: 1 1 240px; }
      .cb-text a { color: var(--gold-light, #e7cf93); text-decoration: underline; }
      .cb-actions { display: flex; gap: 8px; flex: 0 0 auto; }
      .cb-btn { border: 0; cursor: pointer; padding: 9px 17px; border-radius: 999px; font-weight: 700; font-size: 13px; font-family: var(--font-body); }
      .cb-reject { background: transparent; color: #cfc9d6; border: 1px solid rgba(255, 255, 255, .3); }
      .cb-accept { background: var(--gold, #cda23a); color: #14121a; }
    </style>
  </>
)}
