---
// Lightbox reutilizable: haz click en cualquier <img data-lightbox> para verla en grande.
// Cierra con click fuera, botón ✕ o tecla Escape. Soporta teclado (Enter/Espacio) si el
// disparador tiene tabindex.
---
<div class="lightbox" data-lightbox-overlay hidden aria-hidden="true">
  <button class="lightbox-close" type="button" aria-label="Cerrar">&times;</button>
  <img class="lightbox-img" alt="" />
</div>

<style>
  .lightbox {
    position: fixed; inset: 0; z-index: 4000;
    display: flex; align-items: center; justify-content: center;
    padding: clamp(16px, 4vw, 56px);
    background: rgba(10, 8, 20, .9);
    -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
    opacity: 0; transition: opacity .25s ease;
  }
  .lightbox[hidden] { display: none; }
  .lightbox.open { opacity: 1; }
  .lightbox-img {
    max-width: min(92vw, 620px); max-height: 90vh;
    width: auto; height: auto; object-fit: contain;
    border-radius: 14px; box-shadow: 0 24px 70px rgba(0, 0, 0, .55);
    transform: scale(.95); transition: transform .28s cubic-bezier(.22, 1, .36, 1);
  }
  .lightbox.open .lightbox-img { transform: scale(1); }
  .lightbox-close {
    position: absolute; top: 18px; right: 22px;
    width: 46px; height: 46px; border-radius: 50%;
    border: none; cursor: pointer;
    background: rgba(255, 255, 255, .14); color: #fff;
    font-size: 30px; line-height: 1;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s;
  }
  .lightbox-close:hover { background: rgba(255, 255, 255, .3); }
  @media (prefers-reduced-motion: reduce) {
    .lightbox, .lightbox-img { transition: none; }
  }
</style>

<script>
  const overlay = document.querySelector("[data-lightbox-overlay]");
  if (overlay) {
    const imgEl = overlay.querySelector(".lightbox-img");
    const open = (trigger) => {
      imgEl.src = trigger.getAttribute("data-full") || trigger.currentSrc || trigger.src;
      imgEl.alt = trigger.alt || "";
      overlay.hidden = false;
      overlay.setAttribute("aria-hidden", "false");
      requestAnimationFrame(() => overlay.classList.add("open"));
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      overlay.classList.remove("open");
      overlay.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      setTimeout(() => { overlay.hidden = true; imgEl.removeAttribute("src"); }, 280);
    };
    document.addEventListener("click", (e) => {
      const trigger = e.target.closest("img[data-lightbox]");
      if (trigger) { e.preventDefault(); open(trigger); return; }
      if (e.target === overlay || e.target.closest(".lightbox-close")) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !overlay.hidden) { close(); return; }
      if ((e.key === "Enter" || e.key === " ")) {
        const t = document.activeElement;
        if (t && t.matches && t.matches("img[data-lightbox]")) { e.preventDefault(); open(t); }
      }
    });
  }
</script>
