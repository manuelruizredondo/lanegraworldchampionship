---
// Lightbox reutilizable: haz click en cualquier <img data-lightbox> para verla en grande.
// Navega entre todas las imágenes data-lightbox de la página con las flechas, el teclado
// (← →) o deslizando en móvil. Cierra con click fuera, botón ✕ o tecla Escape.
---
<div class="lightbox" data-lightbox-overlay hidden aria-hidden="true">
  <button class="lightbox-close" type="button" aria-label="Cerrar">&times;</button>
  <button class="lightbox-nav lightbox-prev" type="button" aria-label="Anterior">&#8249;</button>
  <figure class="lightbox-fig">
    <img class="lightbox-img" alt="" />
    <figcaption class="lightbox-count" data-lightbox-count></figcaption>
  </figure>
  <button class="lightbox-nav lightbox-next" type="button" aria-label="Siguiente">&#8250;</button>
</div>

<style>
  .lightbox {
    position: fixed; inset: 0; z-index: 4000;
    display: flex; align-items: center; justify-content: center;
    padding: clamp(16px, 4vw, 56px);
    background: rgba(10, 8, 20, .9);
    -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
    opacity: 0; transition: opacity .25s ease;
  }
  .lightbox[hidden] { display: none; }
  .lightbox.open { opacity: 1; }
  .lightbox-fig { margin: 0; display: flex; flex-direction: column; align-items: center; }
  .lightbox-img {
    max-width: min(92vw, 1100px); max-height: 86vh;
    width: auto; height: auto; object-fit: contain;
    border-radius: 14px; box-shadow: 0 24px 70px rgba(0, 0, 0, .55);
    transform: scale(.95); transition: transform .28s cubic-bezier(.22, 1, .36, 1);
  }
  .lightbox.open .lightbox-img { transform: scale(1); }
  .lightbox-img.swap { animation: lb-swap .26s ease; }
  @keyframes lb-swap { from { opacity: .25; } to { opacity: 1; } }
  .lightbox-count {
    text-align: center; margin-top: 14px;
    color: rgba(255, 255, 255, .82); font-family: var(--font-body);
    font-size: 14px; letter-spacing: .05em;
  }
  .lightbox-close {
    position: absolute; top: 18px; right: 22px;
    width: 46px; height: 46px; border-radius: 50%;
    border: none; cursor: pointer;
    background: rgba(255, 255, 255, .14); color: #fff;
    font-size: 30px; line-height: 1;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s;
  }
  .lightbox-close:hover { background: rgba(255, 255, 255, .3); }
  .lightbox-nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 52px; height: 52px; border-radius: 50%;
    border: none; cursor: pointer;
    background: rgba(255, 255, 255, .14); color: #fff;
    font-size: 34px; line-height: 1;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s;
  }
  .lightbox-nav:hover { background: rgba(255, 255, 255, .3); }
  .lightbox-nav[hidden] { display: none; }
  .lightbox-prev { left: clamp(8px, 3vw, 34px); }
  .lightbox-next { right: clamp(8px, 3vw, 34px); }
  @media (max-width: 560px) {
    .lightbox-nav { width: 44px; height: 44px; font-size: 28px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .lightbox, .lightbox-img { transition: none; }
    .lightbox-img.swap { animation: none; }
  }
</style>

<script>
  const overlay = document.querySelector<HTMLElement>("[data-lightbox-overlay]");
  if (overlay) {
    const imgEl = overlay.querySelector<HTMLImageElement>(".lightbox-img");
    const countEl = overlay.querySelector<HTMLElement>("[data-lightbox-count]");
    const prevBtn = overlay.querySelector<HTMLButtonElement>(".lightbox-prev");
    const nextBtn = overlay.querySelector<HTMLButtonElement>(".lightbox-next");
    if (!imgEl || !countEl || !prevBtn || !nextBtn) throw new Error("Lightbox markup incomplete");

    let items: HTMLImageElement[] = [];
    let idx = 0;

    const render = () => {
      const t = items[idx];
      if (!t) return;
      imgEl.src = t.getAttribute("data-full") || t.currentSrc || t.src;
      imgEl.alt = t.alt || "";
      const multi = items.length > 1;
      countEl.textContent = multi ? `${idx + 1} / ${items.length}` : "";
      prevBtn.hidden = !multi;
      nextBtn.hidden = !multi;
    };
    const open = (trigger: HTMLImageElement) => {
      items = [...document.querySelectorAll<HTMLImageElement>("img[data-lightbox]")];
      idx = Math.max(0, items.indexOf(trigger));
      overlay.hidden = false;
      overlay.setAttribute("aria-hidden", "false");
      render();
      requestAnimationFrame(() => overlay.classList.add("open"));
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      overlay.classList.remove("open");
      overlay.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      setTimeout(() => { overlay.hidden = true; imgEl.removeAttribute("src"); }, 280);
    };
    const go = (dir: number) => {
      if (items.length < 2) return;
      idx = (idx + dir + items.length) % items.length;
      imgEl.classList.remove("swap");
      void imgEl.offsetWidth;
      imgEl.classList.add("swap");
      render();
    };

    document.addEventListener("click", (e) => {
      const target = e.target as Element | null;
      if (!target?.closest) return;
      const trigger = target.closest("img[data-lightbox]") as HTMLImageElement | null;
      if (trigger) { e.preventDefault(); open(trigger); return; }
      if (overlay.hidden) return;
      if (target.closest(".lightbox-prev")) { e.stopPropagation(); go(-1); return; }
      if (target.closest(".lightbox-next")) { e.stopPropagation(); go(1); return; }
      if (target === overlay || target.closest(".lightbox-close")) close();
    });
    document.addEventListener("keydown", (e) => {
      if (overlay.hidden) {
        if (e.key === "Enter" || e.key === " ") {
          const t = document.activeElement;
          if (t instanceof HTMLImageElement && t.matches("img[data-lightbox]")) {
            e.preventDefault();
            open(t);
          }
        }
        return;
      }
      if (e.key === "Escape") close();
      else if (e.key === "ArrowLeft") go(-1);
      else if (e.key === "ArrowRight") go(1);
    });

    // Deslizar en móvil para navegar
    let sx = 0;
    overlay.addEventListener("touchstart", (e) => { sx = e.touches[0].clientX; }, { passive: true });
    overlay.addEventListener("touchend", (e) => {
      const dx = e.changedTouches[0].clientX - sx;
      if (Math.abs(dx) > 50) go(dx < 0 ? 1 : -1);
    }, { passive: true });
  }
</script>
