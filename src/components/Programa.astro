---
import { PROGRAMA, ROOM_LIST, I18N } from "@/data/programa.js";

const { lang = "es" } = Astro.props;
const t = I18N[lang] || I18N.es;

// Agrupa las sesiones de cada día por franja horaria (respetando el orden del PDF)
const days = PROGRAMA.map((d) => {
  const slots = [];
  d.sessions.forEach((s) => {
    const last = slots[slots.length - 1];
    if (last && last.t === s.t) last.items.push(s);
    else slots.push({ t: s.t, items: [s] });
  });
  return { ...d, slots };
});

const FILTER_KEYS = ["all", "fav", "taller", "master", "comp", "social"];
const title = (s) => (s.r === "full" ? (t.band[s.n] || s.n) : s.n);
const describe = (s) => {
  if (s.k === "taller") return s.l ? t.levelInfo[s.l] : t.desc.taller;
  return t.desc[s.k] || t.desc.taller;
};
---

<section class="pr-hero">
  <div class="container">
    <p class="eyebrow dark">{t.eyebrow}</p>
    <h1 class="script-title">{t.h1}</h1>
    <p class="pr-sub">{t.sub}</p>
  </div>
</section>

<!-- Salones (antes de los días, NO sticky). Click = bocadillo con la ubicación -->
<section class="pr-rooms">
  <div class="container">
    <p class="pr-rooms-label">{t.roomsLabel}</p>
    <div class="pr-rooms-list">
      {ROOM_LIST.map((r) => (
        <div class="pr-room-item">
          <button class={"pr-room-chip rc-" + r.key} data-room={r.key} type="button" aria-expanded="false">
            <span class={"pr-dot pr-r-" + r.key}></span>{t.roomFull[r.key]}
          </button>
          <div class="pr-room-pop" role="tooltip" hidden>
            <strong>{t.roomFull[r.key]}</strong>
            <span>{t.roomLoc[r.key]}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Controles sticky: días + filtros + buscador -->
<div class="pr-controls">
  <div class="container">
    <div class="pr-days" role="tablist" aria-label={t.daysAria}>
      {days.map((d, i) => (
        <button class={"pr-day-btn" + (i === 0 ? " active" : "")} data-day={i} role="tab" aria-selected={i === 0 ? "true" : "false"}>
          <span class="pr-day-name">{t.days[d.day]}</span>
          <span class="pr-day-date">{d.date}</span>
        </button>
      ))}
    </div>
    <div class="pr-filters" role="group" aria-label={t.filtersAria}>
      {FILTER_KEYS.map((k, i) => (
        <button class={"pr-chip" + (k === "fav" ? " pr-chip-fav" : "") + (i === 0 ? " active" : "")} data-filter={k}>
          {k === "fav" && <svg class="pr-chip-heart" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path d="M12 21s-7.5-4.6-10-9.2C.6 8.9 1.9 5.5 5 5c2-.3 3.4.8 4.2 2 .8-1.2 2.2-2.3 4.2-2 3.1.5 4.4 3.9 3 6.8C19.5 16.4 12 21 12 21z"/></svg>}
          <span>{t.filters[k]}</span>
          {k === "fav" && <span class="pr-fav-count" hidden>0</span>}
        </button>
      ))}
    </div>
    <label class="pr-search">
      <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="search" id="pr-q" placeholder={t.search} autocomplete="off" aria-label={t.searchAria} />
    </label>
  </div>
</div>

<section class="pr-body">
  <div class="container">
    <p class="pr-fav-empty" hidden>{t.favEmpty}</p>
    {days.map((d, di) => (
      <div class="pr-day" id={`pr-day-${di}`} data-day-panel={di}>
        <h2 class="pr-day-head"><span class="pr-day-head-name">{t.days[d.day]}</span><span class="pr-day-head-date">{d.date}</span></h2>
        {d.slots.map((slot) => { const tm = slot.t.split(/\s*[–—-]\s*/); return (
          <div class="pr-slot">
            <div class="pr-time pr-time-start"><span>{tm[0]}</span></div>
            <div class="pr-sessions">
              {slot.items.map((s) => (
                <article
                  class={"pr-card rc-" + s.r + " k-" + s.k + (s.r === "full" ? " pr-band" : "")}
                  data-kind={s.k}
                  data-text={((s.n || "") + " " + (s.p || "")).toLowerCase()}
                >
                  {s.r !== "full" && <span class={"pr-room pr-r-" + s.r}>{t.rooms[s.r]}</span>}
                  <div class="pr-card-in">
                    <div class="pr-meta">
                      <span class={"pr-kind kb-" + s.k}>{t.kind[s.k]}</span>
                      {s.l && <span class={"pr-level lv-" + s.l.replace(/[^a-zA-ZñÑ]/g, "")}>{t.levels[s.l]}</span>}
                    </div>
                    <h3 class="pr-title">{title(s)}</h3>
                    {s.p && <p class="pr-teacher">{s.p}</p>}
                    {s.r !== "full" && (
                      <div class="pr-card-detail">
                        <p class="pr-det-desc">{describe(s)}</p>
                        <p class="pr-det-loc"><span class={"pr-dot pr-r-" + s.r}></span>{t.roomFull[s.r]} · {t.roomLoc[s.r]}</p>
                      </div>
                    )}
                  </div>
                  {s.r !== "full" && <span class="pr-card-more" aria-hidden="true">+</span>}
                  {s.r !== "full" && (
                    <button class="pr-fav" type="button" aria-pressed="false" aria-label={t.favAria} data-fav={`${di}|${slot.t}|${s.r}|${s.n}`}>
                      <svg viewBox="0 0 24 24" width="19" height="19" aria-hidden="true"><path d="M12 21s-7.5-4.6-10-9.2C.6 8.9 1.9 5.5 5 5c2-.3 3.4.8 4.2 2 .8-1.2 2.2-2.3 4.2-2 3.1.5 4.4 3.9 3 6.8C19.5 16.4 12 21 12 21z"/></svg>
                    </button>
                  )}
                </article>
              ))}
            </div>
            {tm[1] && <div class="pr-time pr-time-end"><span>{tm[1]}</span></div>}
          </div>
        ); })}
        <p class="pr-empty" hidden>{t.empty} <button type="button" class="pr-reset">{t.reset}</button></p>
      </div>
    ))}
    <p class="pr-note">{t.note}</p>
  </div>
</section>

<script>
  const dayBtns = [...document.querySelectorAll(".pr-day-btn")];
  const panels = [...document.querySelectorAll("[data-day-panel]")];
  const chips = [...document.querySelectorAll(".pr-chip")];
  const q = document.getElementById("pr-q");
  let filter = "all", query = "";
  const controlsEl = document.querySelector(".pr-controls");

  // ── Favoritos (persisten en el navegador con localStorage) ──
  const FAV_KEY = "lanegra:programa:favs";
  const loadFavs = () => { try { return new Set(JSON.parse(localStorage.getItem(FAV_KEY) || "[]")); } catch (e) { return new Set(); } };
  const favs = loadFavs();
  const saveFavs = () => { try { localStorage.setItem(FAV_KEY, JSON.stringify([...favs])); } catch (e) {} };
  const favCountEl = document.querySelector(".pr-fav-count");
  const favEmptyEl = document.querySelector(".pr-fav-empty");
  const favBtns = [...document.querySelectorAll(".pr-fav")];
  const syncFavCount = () => {
    if (!favCountEl) return;
    favCountEl.textContent = favs.size;
    favCountEl.hidden = favs.size === 0;
  };
  const markFavs = () => favBtns.forEach((btn) => {
    const on = favs.has(btn.dataset.fav);
    btn.classList.toggle("is-fav", on);
    btn.setAttribute("aria-pressed", on ? "true" : "false");
  });
  favBtns.forEach((btn) => btn.addEventListener("click", (e) => {
    e.stopPropagation(); // no expandir la tarjeta al tocar el corazón
    const id = btn.dataset.fav;
    if (favs.has(id)) favs.delete(id); else favs.add(id);
    saveFavs();
    const on = favs.has(id);
    btn.classList.toggle("is-fav", on);
    btn.setAttribute("aria-pressed", on ? "true" : "false");
    btn.classList.remove("pr-fav-pop"); void btn.offsetWidth; if (on) btn.classList.add("pr-fav-pop");
    syncFavCount();
    if (filter === "fav") apply();
  }));
  markFavs();
  syncFavCount();
  const headerH = () => parseInt(getComputedStyle(document.documentElement).getPropertyValue("--header-h")) || 88;
  // Publica la altura de la barra de controles para fijar la cabecera de día justo debajo
  const setControlsH = () => document.documentElement.style.setProperty("--controls-h", controlsEl.offsetHeight + "px");
  setControlsH();
  window.addEventListener("resize", setControlsH);

  const apply = () => {
    const favMode = filter === "fav";
    panels.forEach((panel) => {
      let visible = 0;
      panel.querySelectorAll(".pr-slot").forEach((slot) => {
        let shown = 0;
        slot.querySelectorAll(".pr-card").forEach((card) => {
          const favBtn = card.querySelector(".pr-fav");
          const okKind = favMode
            ? !!(favBtn && favs.has(favBtn.dataset.fav))
            : filter === "all" || card.dataset.kind === filter
              || (filter === "social" && (card.dataset.kind === "social" || card.dataset.kind === "meal"));
          const okText = !query || (card.dataset.text || "").includes(query);
          const ok = okKind && okText;
          card.hidden = !ok;
          if (ok) shown++;
        });
        slot.hidden = shown === 0;
        visible += shown;
      });
      const empty = panel.querySelector(".pr-empty");
      // En modo favoritos usamos un único mensaje global, no el de cada día
      if (empty) empty.hidden = favMode || visible !== 0;
    });
    if (favEmptyEl) favEmptyEl.hidden = !(favMode && favs.size === 0);
  };

  // Todos los días están visibles a la vez. Click en un día -> scroll suave a ese día.
  const scrollToDay = (i) => {
    const target = Math.max(0, Math.round(panels[i].getBoundingClientRect().top + window.scrollY - headerH() - controlsEl.offsetHeight - 6));
    window.scrollTo({ top: target, behavior: "smooth" });
  };
  dayBtns.forEach((b) => b.addEventListener("click", () => scrollToDay(+b.dataset.day)));

  // Scroll-spy: resalta el botón del día que se está viendo
  let spyTick = false;
  const spy = () => {
    spyTick = false;
    const y = window.scrollY + headerH() + controlsEl.offsetHeight + 24;
    let active = 0;
    panels.forEach((p, i) => { if (p.getBoundingClientRect().top + window.scrollY <= y) active = i; });
    dayBtns.forEach((b, i) => { const on = i === active; b.classList.toggle("active", on); b.setAttribute("aria-selected", on ? "true" : "false"); });
  };
  window.addEventListener("scroll", () => { if (!spyTick) { spyTick = true; requestAnimationFrame(spy); } }, { passive: true });
  window.addEventListener("resize", spy);
  chips.forEach((c) => c.addEventListener("click", () => {
    filter = c.dataset.filter;
    chips.forEach((x) => x.classList.toggle("active", x === c));
    apply();
  }));
  q.addEventListener("input", () => { query = q.value.trim().toLowerCase(); apply(); });

  // Salones: click en un salón -> bocadillo con su ubicación
  const roomItems = [...document.querySelectorAll(".pr-room-item")];
  const closeRoomPops = (except) => roomItems.forEach((it) => {
    if (it === except) return;
    it.querySelector(".pr-room-pop").hidden = true;
    it.querySelector(".pr-room-chip").setAttribute("aria-expanded", "false");
  });
  roomItems.forEach((it) => {
    const chip = it.querySelector(".pr-room-chip");
    const pop = it.querySelector(".pr-room-pop");
    chip.addEventListener("click", (e) => {
      e.stopPropagation();
      const willOpen = pop.hidden;
      closeRoomPops(it);
      pop.hidden = !willOpen;
      chip.setAttribute("aria-expanded", willOpen ? "true" : "false");
    });
  });
  document.addEventListener("click", () => closeRoomPops(null));

  // Click en una tarjeta -> crece y muestra el texto explicativo
  document.querySelector(".pr-body").addEventListener("click", (e) => {
    const card = e.target.closest(".pr-card:not(.pr-band)");
    if (card) card.classList.toggle("expanded");
  });
  document.querySelectorAll(".pr-reset").forEach((r) => r.addEventListener("click", () => {
    filter = "all"; query = ""; q.value = "";
    chips.forEach((x) => x.classList.toggle("active", x.dataset.filter === "all"));
    apply();
  }));
  apply();
  spy();
</script>

<style>
  .pr-hero { padding: clamp(40px, 6vw, 72px) 0 clamp(20px, 3vw, 32px); text-align: center; }
  .pr-hero .script-title { margin: 0 0 14px; }
  .pr-sub { max-width: 640px; margin: 0 auto; color: #6a6a74; font-size: 16px; line-height: 1.6; }

  .pr-controls {
    position: sticky; top: var(--header-h, 88px); z-index: 500;
    background: rgba(255, 255, 255, 0.86);
    -webkit-backdrop-filter: blur(14px); backdrop-filter: blur(14px);
    border-bottom: 1px solid #ece8e1;
    padding: 12px 0;
  }
  .pr-days, .pr-filters { display: flex; overflow-x: auto; scrollbar-width: none; margin: 0 -24px; padding: 6px 24px; }
  .pr-days::-webkit-scrollbar, .pr-filters::-webkit-scrollbar { display: none; }
  .pr-days { gap: 8px; }
  .pr-day-btn {
    flex: 0 0 auto; display: flex; flex-direction: column; align-items: center; gap: 1px;
    padding: 8px 18px; border-radius: 14px; cursor: pointer;
    border: 1.5px solid #e6e3dd; background: #fff; color: #14121a;
    font-family: var(--font-body); transition: all .18s ease; line-height: 1.1;
  }
  .pr-day-btn .pr-day-name { font-weight: 700; font-size: 15px; }
  .pr-day-btn .pr-day-date { font-size: 11px; letter-spacing: .06em; text-transform: uppercase; opacity: .6; }
  .pr-day-btn.active { background: #14121a; border-color: #14121a; color: #fff; }
  .pr-day-btn.active .pr-day-date { opacity: .7; }

  .pr-filters { gap: 6px; margin-top: 4px; }
  .pr-chip {
    flex: 0 0 auto; padding: 7px 14px; border-radius: 999px; cursor: pointer;
    border: 1.5px solid #e6e3dd; background: #fff; color: #14121a;
    font-family: var(--font-body); font-weight: 600; font-size: 13.5px; transition: all .18s ease; white-space: nowrap;
  }
  .pr-chip:hover { border-color: var(--gold); }
  .pr-chip.active { background: var(--gold); border-color: var(--gold); color: #fff; }
  .pr-search {
    display: inline-flex; align-items: center; gap: 7px; margin-top: 10px;
    width: 100%; max-width: 440px;
    padding: 8px 14px; border-radius: 999px; border: 1.5px solid #e6e3dd; background: #fff; color: #9a9aa2;
  }
  .pr-search input { border: 0; outline: 0; background: transparent; font-family: var(--font-body); font-size: 16px; color: #14121a; width: 100%; }
  .pr-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; flex: 0 0 auto; }

  .pr-rooms { padding: 6px 0 10px; }
  .pr-rooms-label { font-size: 12px; color: #9a9aa2; margin: 0 0 9px; font-weight: 600; letter-spacing: .01em; text-align: center; }
  .pr-rooms-list { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
  .pr-room-item { position: relative; }
  .pr-room-chip {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 7px 15px 7px 12px; border-radius: 999px; cursor: pointer;
    border: 1.75px solid #e6e3dd; background: #fff; color: #14121a;
    font-family: var(--font-body); font-weight: 600; font-size: 13.5px;
    transition: box-shadow .15s ease;
  }
  .pr-room-chip:hover { box-shadow: 0 4px 14px rgba(20, 18, 26, .08); }
  .pr-room-chip[aria-expanded="true"] { box-shadow: 0 6px 18px rgba(20, 18, 26, .14); }
  .pr-room-pop {
    position: absolute; bottom: calc(100% + 10px); left: 50%; transform: translateX(-50%); z-index: 30;
    width: 260px; max-width: 78vw;
    background: #14121a; color: #fff; border-radius: 13px; padding: 12px 15px;
    box-shadow: 0 16px 38px rgba(20, 18, 26, .3);
    font-size: 13px; line-height: 1.45; text-align: left;
  }
  .pr-room-pop[hidden] { display: none; }
  .pr-room-pop strong { display: block; margin-bottom: 3px; font-size: 13.5px; }
  .pr-room-pop span { color: rgba(255, 255, 255, .82); }
  .pr-room-pop::before {
    content: ""; position: absolute; top: 100%; left: 50%; transform: translateX(-50%);
    border: 7px solid transparent; border-top-color: #14121a;
  }

  .pr-r-gs { background: #cc9933; }
  .pr-r-pb { background: #2a9d8f; }
  .pr-r-s1 { background: #5b6ee1; }
  .pr-r-s2 { background: #e05a8c; }
  .pr-r-full { background: #b8b3a8; }

  .pr-body { padding: clamp(20px, 3vw, 32px) 0 64px; }
  /* Todos los días visibles, uno debajo de otro */
  .pr-day { display: block; scroll-margin-top: calc(var(--header-h, 88px) + 150px); }
  .pr-day-head {
    position: sticky; top: calc(var(--header-h, 88px) + var(--controls-h, 140px)); z-index: 400;
    display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap;
    margin: 30px 0 4px; padding: 8px 0 10px; border-bottom: 2px solid #ece8e1;
    background: rgba(255, 255, 255, 0.94);
    -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
  }
  .pr-day:first-child .pr-day-head { margin-top: 6px; }
  .pr-day-head-name { font-weight: 800; font-size: clamp(22px, 4.4vw, 34px); letter-spacing: -.03em; color: #14121a; line-height: 1; }
  .pr-day-head-date { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--gold-dark); }
  .pr-slot {
    display: grid; grid-template-columns: 108px 1fr;
    grid-template-areas: "start sessions" "end sessions";
    gap: 4px 16px; padding: 14px 0; border-top: 1px solid #efece6;
  }
  .pr-slot:first-child, .pr-day-head + .pr-slot { border-top: 0; }
  .pr-time-start { grid-area: start; align-self: start; }
  .pr-time-end { grid-area: end; align-self: end; }
  .pr-sessions { grid-area: sessions; }
  .pr-time span { font-weight: 800; font-size: 19px; color: #14121a; letter-spacing: -.02em; line-height: 1.2; display: block; }
  .pr-time-end span { font-weight: 700; font-size: 14.5px; color: #a7a2b0; }
  .pr-time-end span::before { content: "–"; margin-right: 5px; color: #cfc9bb; }
  .pr-sessions { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 12px; }

  .pr-card {
    position: relative; overflow: hidden;
    border-radius: 16px; border: 2px solid #ece8e1; background: #fff;
    box-shadow: 0 4px 16px rgba(20, 18, 26, .04);
    transition: transform .15s ease, box-shadow .15s ease;
  }
  .pr-card:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(20, 18, 26, .09); }
  .rc-gs { border-color: #cc9933; }
  .rc-pb { border-color: #2a9d8f; }
  .rc-s1 { border-color: #5b6ee1; }
  .rc-s2 { border-color: #e05a8c; }
  .rc-full { border-color: #e8e2d6; }
  .pr-card-in { padding: 13px 15px; min-width: 0; }
  .pr-meta { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px; align-items: center; padding-right: 96px; min-height: 22px; }
  .pr-room {
    position: absolute; top: 0; right: 0; z-index: 2;
    font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: #fff;
    padding: 4px 11px 5px; border-radius: 0 15px 0 12px;
    box-shadow: -2px 3px 9px rgba(20, 18, 26, .14);
  }
  .pr-kind { font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; padding: 2px 8px; border-radius: 999px; background: #f0ede7; color: #6a6a74; }
  .kb-master { background: #fbeecb; color: #a2711a; }
  .kb-comp { background: #14121a; color: #fff; }
  .kb-social { background: #efe6fb; color: #7a4bcc; }
  .pr-level { font-size: 10.5px; font-weight: 700; padding: 2px 8px; border-radius: 999px; border: 1px solid; white-space: nowrap; }
  .lv-Abierto { color: #2e9b63; border-color: #b8e6cd; background: #eafaf1; }
  .lv-MedioBajo { color: #2a9d8f; border-color: #b7e3dd; background: #e9f7f5; }
  .lv-Medio { color: #3f6fd0; border-color: #c4d4f2; background: #edf2fc; }
  .lv-MedioAlto { color: #c9781b; border-color: #f0d8ad; background: #fdf3e2; }
  .lv-MedioAvanzado { color: #cc5a1e; border-color: #f2ccb0; background: #fdeee4; }
  .lv-Avanzado { color: #cc3d38; border-color: #f2c1bf; background: #fdeceb; }
  .pr-title { font-size: 15px; font-weight: 700; letter-spacing: -.01em; line-height: 1.28; margin: 0; color: #14121a; }
  .pr-teacher { margin: 5px 0 0; font-size: 13px; color: #6a6a74; line-height: 1.4; padding-right: 26px; }

  .pr-card:not(.pr-band) { cursor: pointer; }
  .pr-card, .pr-day-btn, .pr-chip, .pr-room-chip { touch-action: manipulation; }
  .pr-card-detail {
    max-height: 0; overflow: hidden; opacity: 0; margin-top: 0;
    transition: max-height .32s ease, opacity .25s ease, margin-top .3s ease;
  }
  .pr-card.expanded { box-shadow: 0 14px 32px rgba(20, 18, 26, .12); }
  .pr-card.expanded .pr-card-detail { max-height: 280px; opacity: 1; margin-top: 11px; }
  .pr-det-desc { margin: 0 0 8px; font-size: 13.5px; line-height: 1.5; color: #4a4a52; }
  .pr-det-loc { margin: 0; font-size: 12.5px; font-weight: 600; color: #6a6a74; display: flex; align-items: center; gap: 7px; }
  .pr-card-more {
    position: absolute; right: 11px; bottom: 10px;
    width: 22px; height: 22px; display: flex; align-items: center; justify-content: center;
    border-radius: 50%; background: #f1ede6; color: #8a8578; font-size: 17px; line-height: 1;
    transition: transform .28s ease, background .2s, color .2s;
  }
  .pr-card.expanded .pr-card-more { transform: rotate(45deg); background: var(--gold); color: #fff; }

  /* Botón favorito (corazón) — abajo a la derecha, junto al "+" */
