---
import { PROGRAMA, ROOM_LIST, I18N } from "@/data/programa.js";

const { lang = "es" } = Astro.props;
const t = I18N[lang] || I18N.es;

// Agrupa las sesiones de cada día por franja horaria (respetando el orden del PDF)
const days = PROGRAMA.map((d) => {
  const slots = [];
  d.sessions.forEach((s) => {
    const last = slots[slots.length - 1];
    if (last && last.t === s.t) last.items.push(s);
    else slots.push({ t: s.t, items: [s] });
  });
  return { ...d, slots };
});

const FILTER_KEYS = ["all", "fav", "taller", "bachata", "salsa", "master", "comp", "social"];
// Estilo del taller según el título: Bachata (RD) o Salsa (por defecto)
const isBachata = (s) => /bachata|dominican|bacano/i.test(s.n || "");
const title = (s) => (s.r === "full" ? (t.band[s.n] || s.n) : s.n);
const describe = (s) => {
  if (s.k === "taller") return s.l ? t.levelInfo[s.l] : t.desc.taller;
  return t.desc[s.k] || t.desc.taller;
};
---

<section class="pr-hero">
  <div class="container">
    <p class="eyebrow dark">{t.eyebrow}</p>
    <h1 class="script-title">{t.h1}</h1>
    <p class="pr-sub">{t.sub}</p>
  </div>
</section>

<!-- Salones: 4 cajas con imagen, borde de color y la bolita arriba a la izquierda -->
<section class="pr-rooms">
  <div class="container">
    <p class="pr-rooms-label">{t.roomsLabel}</p>
    <div class="pr-rooms-grid">
      {ROOM_LIST.map((r) => (
        <article class={"pr-room-box rc-" + r.key} data-room={r.key} data-name={t.roomFull[r.key]} data-loc={t.roomLoc[r.key]} role="button" tabindex="0" aria-expanded="false">
          <div class={"pr-room-img pr-rimg-" + r.key} style={r.img ? `background-image:url(${r.img})` : undefined}>
            <strong class="pr-room-name-full">{t.roomFull[r.key]}</strong>
            <strong class="pr-room-name-short">{t.rooms[r.key]}</strong>
            <span class={"pr-dot pr-r-" + r.key}></span>
          </div>
        </article>
      ))}
    </div>
    <div class="pr-room-info" hidden><strong></strong><span></span></div>
  </div>
</section>

<!-- Controles sticky: filtros + buscador, y abajo los días como tabs con barra deslizante -->
<div class="pr-controls">
  <div class="container">
    <label class="pr-search">
      <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="search" id="pr-q" placeholder={t.search} autocomplete="off" aria-label={t.searchAria} />
    </label>
    <div class="pr-filters" role="group" aria-label={t.filtersAria}>
      {FILTER_KEYS.map((k, i) => (
        <button class={"pr-chip" + (k === "fav" ? " pr-chip-fav" : "") + (i === 0 ? " active" : "")} data-filter={k}>
          {k === "fav" && <svg class="pr-chip-heart" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path d="M12 21s-7.5-4.6-10-9.2C.6 8.9 1.9 5.5 5 5c2-.3 3.4.8 4.2 2 .8-1.2 2.2-2.3 4.2-2 3.1.5 4.4 3.9 3 6.8C19.5 16.4 12 21 12 21z"/></svg>}
          <span>{t.filters[k]}</span>
          {k === "fav" && <span class="pr-fav-count" hidden>0</span>}
        </button>
      ))}
    </div>
    <div class="pr-days" role="tablist" aria-label={t.daysAria}>
      {days.map((d, i) => (
        <button class={"pr-day-btn" + (i === 0 ? " active" : "")} data-day={i} role="tab" aria-selected={i === 0 ? "true" : "false"}>
          <span class="pr-day-name">{t.days[d.day]}</span>
          <span class="pr-day-date">{d.date}</span>
        </button>
      ))}
      <span class="pr-days-ink" aria-hidden="true"></span>
    </div>
  </div>
</div>

<section class="pr-body">
  <div class="container">
    <p class="pr-fav-empty" hidden>{t.favEmpty}</p>
    {days.map((d, di) => (
      <div class="pr-day" id={`pr-day-${di}`} data-day-panel={di}>
        <h2 class="pr-day-head"><span class="pr-day-head-name">{t.days[d.day]}</span><span class="pr-day-head-date">{d.date}</span></h2>
        <div class="pr-timeline">
        {d.slots.map((slot) => { const tm = slot.t.split(/\s*[–—-]\s*/); return (
          <div class="pr-slot">
            <div class="pr-rail">
              <div class="pr-time pr-time-start"><span>{tm[0]}</span></div>
              {tm[1] && <div class="pr-time pr-time-end"><span>{tm[1]}</span></div>}
            </div>
            <div class="pr-sessions">
              {slot.items.map((s) => (
                <article
                  class={"pr-card rc-" + s.r + " k-" + s.k + (s.r === "full" ? " pr-band" : "") + (s.k === "taller" ? (isBachata(s) ? " sp-b" : " sp-s") : "")}
                  data-kind={s.k}
                  data-text={((s.n || "") + " " + (s.p || "")).toLowerCase()}
                >
                  {s.r !== "full" && (s.k === "taller"
                    ? <span class={"pr-room pr-st-" + (isBachata(s) ? "b" : "s")}>{isBachata(s) ? "Bachata" : "Salsa"}</span>
                    : <span class={"pr-room pr-r-" + s.r}>{t.rooms[s.r]}</span>)}
                  <div class="pr-card-in">
                    {s.k !== "taller" && (
                      <div class="pr-meta">
                        <span class={"pr-kind kb-" + s.k}>{t.kind[s.k]}</span>
                        {s.l && <span class={"pr-level lv-" + s.l.replace(/[^a-zA-ZñÑ]/g, "")}>{t.levels[s.l]}</span>}
                      </div>
                    )}
                    <h3 class="pr-title">{title(s)}</h3>
                    {s.p && <p class="pr-teacher">{s.p}</p>}
                    {s.k === "taller" && (
                      <div class="pr-meta pr-meta-bottom">
                        <span class="pr-roomtag"><span class={"pr-dot pr-r-" + s.r}></span>{t.rooms[s.r]}</span>
                        {s.l && <span class={"pr-level lv-" + s.l.replace(/[^a-zA-ZñÑ]/g, "")}>{t.levels[s.l]}</span>}
                      </div>
                    )}
                    {s.r !== "full" && (
                      <div class="pr-card-detail">
                        <p class="pr-det-desc">{describe(s)}</p>
                        <p class="pr-det-loc"><span class={"pr-rname pr-rt-" + s.r}>{t.roomFull[s.r]}</span> · {t.roomLoc[s.r]}</p>
                      </div>
                    )}
                  </div>
                  {s.r !== "full" && <span class="pr-card-more" aria-hidden="true">+</span>}
                  {s.r !== "full" && (
                    <button class="pr-fav" type="button" aria-pressed="false" aria-label={t.favAria} data-fav={`${di}|${slot.t}|${s.r}|${s.n}`}>
                      <svg viewBox="0 0 24 24" width="19" height="19" aria-hidden="true"><path d="M12 21s-7.5-4.6-10-9.2C.6 8.9 1.9 5.5 5 5c2-.3 3.4.8 4.2 2 .8-1.2 2.2-2.3 4.2-2 3.1.5 4.4 3.9 3 6.8C19.5 16.4 12 21 12 21z"/></svg>
                    </button>
                  )}
                </article>
              ))}
            </div>
          </div>
        ); })}
        </div>
        <p class="pr-empty" hidden>{t.empty} <button type="button" class="pr-reset">{t.reset}</button></p>
      </div>
    ))}
    <p class="pr-note">{t.note}</p>
  </div>
</section>

<script>
  const dayBtns = [...document.querySelectorAll(".pr-day-btn")];
  const panels = [...document.querySelectorAll("[data-day-panel]")];
  const chips = [...document.querySelectorAll(".pr-chip")];
  const q = document.getElementById("pr-q");
  let filter = "all", query = "";
  const controlsEl = document.querySelector(".pr-controls");

  // ── Favoritos (persisten en el navegador con localStorage) ──
  const FAV_KEY = "lanegra:programa:favs";
  const loadFavs = () => { try { return new Set(JSON.parse(localStorage.getItem(FAV_KEY) || "[]")); } catch (e) { return new Set(); } };
  const favs = loadFavs();
  const saveFavs = () => { try { localStorage.setItem(FAV_KEY, JSON.stringify([...favs])); } catch (e) {} };
  const favCountEl = document.querySelector(".pr-fav-count");
  const favEmptyEl = document.querySelector(".pr-fav-empty");
  const favBtns = [...document.querySelectorAll(".pr-fav")];
  const syncFavCount = () => {
    if (!favCountEl) return;
    favCountEl.textContent = favs.size;
    favCountEl.hidden = favs.size === 0;
  };
  const markFavs = () => favBtns.forEach((btn) => {
    const on = favs.has(btn.dataset.fav);
    btn.classList.toggle("is-fav", on);
    btn.setAttribute("aria-pressed", on ? "true" : "false");
  });
  favBtns.forEach((btn) => btn.addEventListener("click", (e) => {
    e.stopPropagation(); // no expandir la tarjeta al tocar el corazón
    const id = btn.dataset.fav;
    if (favs.has(id)) favs.delete(id); else favs.add(id);
    saveFavs();
    const on = favs.has(id);
    btn.classList.toggle("is-fav", on);
    btn.setAttribute("aria-pressed", on ? "true" : "false");
    btn.classList.remove("pr-fav-pop"); void btn.offsetWidth; if (on) btn.classList.add("pr-fav-pop");
    syncFavCount();
    if (filter === "fav") apply();
  }));
  markFavs();
  syncFavCount();
  const headerH = () => parseInt(getComputedStyle(document.documentElement).getPropertyValue("--header-h")) || 88;
  // Publica la altura de la barra de controles para fijar la cabecera de día justo debajo
  const setControlsH = () => document.documentElement.style.setProperty("--controls-h", controlsEl.offsetHeight + "px");
  setControlsH();
  window.addEventListener("resize", setControlsH);

  const apply = () => {
    const favMode = filter === "fav";
    panels.forEach((panel) => {
      let visible = 0;
      panel.querySelectorAll(".pr-slot").forEach((slot) => {
        let shown = 0;
        slot.querySelectorAll(".pr-card").forEach((card) => {
          const favBtn = card.querySelector(".pr-fav");
          const okKind = favMode
            ? !!(favBtn && favs.has(favBtn.dataset.fav))
            : filter === "bachata" ? card.classList.contains("sp-b")
            : filter === "salsa" ? card.classList.contains("sp-s")
            : filter === "all" || card.dataset.kind === filter
              || (filter === "social" && (card.dataset.kind === "social" || card.dataset.kind === "meal"));
          const okText = !query || (card.dataset.text || "").includes(query);
          const ok = okKind && okText;
          card.hidden = !ok;
          if (ok) shown++;
        });
        slot.hidden = shown === 0;
        visible += shown;
      });
      const empty = panel.querySelector(".pr-empty");
      // En modo favoritos usamos un único mensaje global, no el de cada día
      if (empty) empty.hidden = favMode || visible !== 0;
    });
    if (favEmptyEl) favEmptyEl.hidden = !(favMode && favs.size === 0);
  };

  // Barra deslizante (ink) bajo la pestaña del día activo
  const daysEl = document.querySelector(".pr-days");
  const ink = document.querySelector(".pr-days-ink");
  const moveInk = (i) => {
    const btn = dayBtns[i];
    if (!btn || !ink) return;
    ink.style.width = btn.offsetWidth + "px";
    ink.style.transform = "translateX(" + btn.offsetLeft + "px)";
  };

  // Todos los días apilados. Click en una pestaña -> scroll suave a ese día.
  const scrollToDay = (i) => {
    const target = Math.max(0, Math.round(panels[i].getBoundingClientRect().top + window.scrollY - headerH() - controlsEl.offsetHeight - 6));
    window.scrollTo({ top: target, behavior: "smooth" });
  };
  const activateDay = (i) => {
    lastActive = i;
    dayBtns.forEach((x, idx) => { const on = idx === i; x.classList.toggle("active", on); x.setAttribute("aria-selected", on ? "true" : "false"); });
    moveInk(i);
  };
  dayBtns.forEach((b) => b.addEventListener("click", () => { const i = +b.dataset.day; activateDay(i); scrollToDay(i); }));

  // Scroll-spy: al hacer scroll, resalta el día que se está viendo y desliza la barra
  let spyTick = false, lastActive = -1;
  const spy = () => {
    spyTick = false;
    const y = window.scrollY + headerH() + controlsEl.offsetHeight + 24;
    let active = 0;
    panels.forEach((p, i) => { if (p.getBoundingClientRect().top + window.scrollY <= y) active = i; });
    if (active !== lastActive) {
      lastActive = active;
      dayBtns.forEach((b, i) => { const on = i === active; b.classList.toggle("active", on); b.setAttribute("aria-selected", on ? "true" : "false"); });
      moveInk(active);
      // mantén visible la pestaña activa dentro del carrusel de días
      const btn = dayBtns[active];
      if (btn && daysEl) daysEl.scrollTo({ left: btn.offsetLeft - 24, behavior: "smooth" });
    }
  };
  window.addEventListener("scroll", () => { if (!spyTick) { spyTick = true; requestAnimationFrame(spy); } }, { passive: true });
  window.addEventListener("resize", () => { moveInk(Math.max(0, lastActive)); spy(); });
  window.addEventListener("load", () => moveInk(Math.max(0, lastActive)));
  chips.forEach((c) => c.addEventListener("click", () => {
    filter = c.dataset.filter;
    chips.forEach((x) => x.classList.toggle("active", x === c));
    apply();
  }));
  q.addEventListener("input", () => { query = q.value.trim().toLowerCase(); apply(); });

  // Salas: al tocar una caja se abre un panel con su ubicación (info extra)
  const roomBoxes = [...document.querySelectorAll(".pr-room-box")];
  const roomInfo = document.querySelector(".pr-room-info");
  let openRoom = null;
  const closeRoomInfo = () => {
    if (roomInfo) roomInfo.hidden = true;
    roomBoxes.forEach((b) => { b.classList.remove("open"); b.setAttribute("aria-expanded", "false"); });
    openRoom = null;
  };
  const toggleRoom = (b) => {
    if (openRoom === b) { closeRoomInfo(); return; }
    closeRoomInfo();
    roomInfo.className = "pr-room-info rc-" + b.dataset.room;
    roomInfo.querySelector("strong").textContent = b.dataset.name;
    roomInfo.querySelector("span").textContent = b.dataset.loc;
    roomInfo.hidden = false;
    b.classList.add("open"); b.setAttribute("aria-expanded", "true");
    openRoom = b;
  };
  roomBoxes.forEach((b) => {
    b.addEventListener("click", (e) => { e.stopPropagation(); toggleRoom(b); });
    b.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); toggleRoom(b); } });
  });
  if (roomInfo) roomInfo.addEventListener("click", (e) => e.stopPropagation());
  document.addEventListener("click", closeRoomInfo);

  // Click en una tarjeta -> crece y muestra el texto explicativo
  document.querySelector(".pr-body").addEventListener("click", (e) => {
    const card = e.target.closest(".pr-card:not(.pr-band)");
    if (card) card.classList.toggle("expanded");
  });
  document.querySelectorAll(".pr-reset").forEach((r) => r.addEventListener("click", () => {
    filter = "all"; query = ""; q.value = "";
    chips.forEach((x) => x.classList.toggle("active", x.dataset.filter === "all"));
    apply();
  }));
  apply();
  spy();
</script>

<style>
  .pr-hero { padding: clamp(40px, 6vw, 72px) 0 clamp(20px, 3vw, 32px); text-align: center; }
  .pr-hero .script-title { margin: 0 0 14px; }
  .pr-sub { max-width: 640px; margin: 0 auto; color: #6a6a74; font-size: 16px; line-height: 1.6; }

  .pr-controls {
    position: sticky; top: var(--header-h, 88px); z-index: 500;
    background: rgba(255, 255, 255, 0.86);
    -webkit-backdrop-filter: blur(14px); backdrop-filter: blur(14px);
    border-bottom: 0;
    padding: 12px 0 0;
  }
  .pr-filters { display: flex; overflow-x: auto; scrollbar-width: none; margin: 8px -24px 0; padding: 6px 24px; gap: 6px; }
  .pr-filters::-webkit-scrollbar { display: none; }

  /* Días como tabs con barra inferior deslizante */
  .pr-days {
    position: relative; display: flex; overflow-x: auto; scrollbar-width: none;
    margin: 10px -24px 0; padding: 0 24px; gap: 2px;
    border-bottom: 1.5px solid #ece8e1;
  }
  .pr-days::-webkit-scrollbar { display: none; }
  .pr-day-btn {
    flex: 0 0 auto; display: flex; flex-direction: column; align-items: center; gap: 1px;
    padding: 8px 16px 11px; border: 0; background: none; cursor: pointer;
    color: #9a9aa2; font-family: var(--font-body); transition: color .18s ease; line-height: 1.1;
  }
  .pr-day-btn .pr-day-name { font-weight: 700; font-size: 15px; }
  .pr-day-btn .pr-day-date { font-size: 11px; letter-spacing: .06em; text-transform: uppercase; opacity: .85; }
  .pr-day-btn.active { color: #14121a; }
  .pr-days-ink {
    position: absolute; bottom: 0; left: 0; width: 0; height: 3px;
    background: var(--gold); border-radius: 3px 3px 0 0; pointer-events: none;
    transform: translateX(0);
    transition: transform .32s cubic-bezier(.4, 0, .2, 1), width .32s cubic-bezier(.4, 0, .2, 1);
  }
  .pr-chip {
    flex: 0 0 auto; padding: 7px 14px; border-radius: 999px; cursor: pointer;
    border: 1.5px solid #e6e3dd; background: #fff; color: #14121a;
    font-family: var(--font-body); font-weight: 600; font-size: 13.5px; transition: all .18s ease; white-space: nowrap;
  }
  .pr-chip:hover { border-color: var(--gold); }
  .pr-chip.active { background: var(--gold); border-color: var(--gold); color: #fff; }
  .pr-search {
    display: inline-flex; align-items: center; gap: 7px;
    width: 100%; max-width: 440px;
    padding: 8px 14px; border-radius: 999px; border: 1.5px solid #e6e3dd; background: #fff; color: #9a9aa2;
  }
  .pr-search input { border: 0; outline: 0; background: transparent; font-family: var(--font-body); font-size: 16px; color: #14121a; width: 100%; }
  .pr-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; flex: 0 0 auto; }

  .pr-rooms { padding: 6px 0 14px; }
  .pr-rooms-label { font-size: 12px; color: #9a9aa2; margin: 0 0 12px; font-weight: 600; letter-spacing: .01em; text-align: center; }
  /* 4 cajas de sala una al lado de otra */
  .pr-rooms-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  .pr-room-box {
    border: 2px solid; border-radius: 15px; overflow: hidden; background: #fff;
    box-shadow: 0 4px 14px rgba(20, 18, 26, .05);
    cursor: pointer; transition: transform .15s ease, box-shadow .15s ease;
  }
  .pr-room-box:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(20, 18, 26, .1); }
  .pr-room-box.open { box-shadow: 0 12px 28px rgba(20, 18, 26, .16); }
  .pr-room-img {
    position: relative; aspect-ratio: 5 / 4;
    background-size: cover; background-position: center;
  }
  /* Bola de color arriba a la derecha, pegada al borde */
  .pr-room-img .pr-dot {
    position: absolute; top: 6px; right: 6px; width: 15px; height: 15px;
    box-shadow: 0 0 0 3px rgba(255, 255, 255, .9), 0 2px 6px rgba(20, 18, 26, .25);
  }
  /* Nombre arriba a la izquierda, a 4px del borde, sobre la imagen */
  .pr-room-img strong {
    position: absolute; top: 4px; left: 4px; max-width: calc(100% - 30px);
    padding: 2px 6px; border-radius: 7px;
    font-size: 13px; font-weight: 700; color: #fff; line-height: 1.15; letter-spacing: -.01em;
    text-shadow: 0 1px 5px rgba(0, 0, 0, .45);
  }
  .pr-room-img .pr-room-name-short { display: none; }
  /* Panel de info que aparece al tocar una sala */
  .pr-room-info {
    margin-top: 12px; padding: 12px 16px; border-radius: 12px;
    background: #faf7f1; border: 1px solid #ece8e1; border-left-width: 4px;
    animation: prInfoIn .2s ease;
  }
  .pr-room-info[hidden] { display: none; }
  .pr-room-info strong { display: block; font-size: 14px; color: #14121a; margin-bottom: 3px; }
  .pr-room-info span { display: block; font-size: 13px; color: #6a6a74; line-height: 1.45; }
  @keyframes prInfoIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: none; } }
  /* Placeholder degradado del color de cada sala (se sustituye al poner foto real) */
  .pr-rimg-gs { background: linear-gradient(135deg, #e4bd5f 0%, #a9781f 100%); }
  .pr-rimg-pb { background: linear-gradient(135deg, #46b6a7 0%, #1c7367 100%); }
  .pr-rimg-s1 { background: linear-gradient(135deg, #808fef 0%, #3f4fbf 100%); }
  .pr-rimg-s2 { background: linear-gradient(135deg, #ee7fa9 0%, #c13f70 100%); }

  .pr-r-gs { background: #cc9933; }
  .pr-r-pb { background: #2a9d8f; }
  .pr-r-s1 { background: #5b6ee1; }
  .pr-r-s2 { background: #e05a8c; }
  .pr-r-full { background: #b8b3a8; }

  .pr-body { padding: 12px 0 64px; }
  /* Todos los días apilados; al hacer scroll cambia el día activo (scroll-spy) */
  .pr-day { display: block; scroll-margin-top: calc(var(--header-h, 88px) + var(--controls-h, 140px) + 8px); }
  /* Cabecera de día: título normal (no sticky) que separa cada día en la lista */
  .pr-day-head {
    display: flex; align-items: baseline; gap: 9px; flex-wrap: wrap;
    margin: 8px 0 16px -20px; padding: 0;
  }
  .pr-day:first-child .pr-day-head { margin-top: 0; }
  .pr-day-head-name { font-weight: 800; font-size: clamp(19px, 4vw, 26px); letter-spacing: -.02em; color: #14121a; line-height: 1; }
  .pr-day-head-date { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: var(--gold-dark); }

  /* Eje de horas continuo (rail): línea vertical con las horas de inicio/fin.
     Se saca 20px a la izquierda para que la hora quede a 4px del borde (padding
     del contenedor = 24px) y aprovechar el ancho. */
  .pr-timeline { position: relative; margin-left: -20px; }
  .pr-slot {
    display: grid; grid-template-columns: 46px 1fr; gap: 0 12px;
    padding: 16px 0; border-top: 1px solid #efece6;
  }
  .pr-slot:first-child { border-top: 0; }
  .pr-rail { position: relative; text-align: left; padding-right: 8px; display: flex; flex-direction: column; }
  .pr-rail::before { /* línea continua del eje */
