---
import { VIDEOS, VIDEOS_META, VIDEOS_CHANNEL } from "@/data/videos.js";

const { lang = "es" } = Astro.props;
const t = VIDEOS_META[lang] || VIDEOS_META.es;

// Agrupa por categoría respetando el orden de aparición
const groups = [];
for (const v of VIDEOS) {
  const cat = v.category || "";
  let g = groups.find((x) => x.cat === cat);
  if (!g) { g = { cat, items: [] }; groups.push(g); }
  g.items.push(v);
}
groups.forEach((g) => g.items.sort((a, b) => (a.place || 9) - (b.place || 9)));

const medal = { 1: "🥇", 2: "🥈", 3: "🥉" };
const ytIcon = `<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M23 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.7-1.7C19.4 5.2 12 5.2 12 5.2s-7.4 0-8.9.4A2.5 2.5 0 0 0 1.4 7.3C1 8.8 1 12 1 12s0 3.2.4 4.7a2.5 2.5 0 0 0 1.7 1.7c1.5.4 8.9.4 8.9.4s7.4 0 8.9-.4a2.5 2.5 0 0 0 1.7-1.7C23 15.2 23 12 23 12zM9.7 15.3V8.7l5.8 3.3-5.8 3.3z"/></svg>`;
---

<section class="section vid-head text-center">
  <div class="container">
    <p class="eyebrow dark">{t.eyebrow}</p>
    <h1 class="script-title">{t.h1}</h1>
    <p class="vid-sub">{t.sub}</p>
    <a class="btn btn-outline vid-channel" href={VIDEOS_CHANNEL} target="_blank" rel="noopener">
      <Fragment set:html={ytIcon} />
      {t.channelBtn}
    </a>
  </div>
</section>

{VIDEOS.length === 0 ? (
  <section class="section-tight text-center">
    <div class="container vid-empty">
      <p>{t.emptyNote}</p>
    </div>
  </section>
) : (
  <section class="section-tight">
    <div class="container">
      {groups.map((g) => (
        <div class="vid-group">
          {g.cat && <h2 class="vid-cat">{g.cat}</h2>}
          <div class="vid-grid">
            {g.items.map((v) => (
              <article class="vid-card">
                <button class="vid-play" type="button" data-yt={v.id} aria-label={`${t.places[v.place] || ""} ${v.title || ""}`.trim()}>
                  <img src={`https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`} alt={v.title || ""} loading="lazy" />
                  <span class="vid-icon" set:html={ytIcon}></span>
                  {v.place && <span class={"vid-badge place-" + v.place}>{medal[v.place]} {t.places[v.place]}</span>}
                </button>
                {v.title && <p class="vid-title">{v.title}</p>}
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .eyebrow.dark { color: var(--gold); }
  .vid-head { padding-bottom: clamp(20px, 3vw, 32px); }
  .vid-sub { max-width: 640px; margin: 10px auto 22px; color: #6a6a74; font-size: 16px; line-height: 1.6; }
  .vid-channel { display: inline-flex; align-items: center; gap: 8px; }

  .vid-empty { max-width: 560px; color: #6a6a74; font-size: 16px; line-height: 1.7; }

  .vid-group { margin-bottom: clamp(30px, 5vw, 52px); }
  .vid-cat {
    font-size: clamp(18px, 2.4vw, 24px); font-weight: 700; letter-spacing: -.02em; color: #14121a;
    margin: 0 0 18px; padding-bottom: 10px; border-bottom: 2px solid #ece8e1;
  }
  .vid-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

  .vid-card { margin: 0; }
  .vid-play {
    position: relative; display: block; width: 100%; padding: 0; border: none; cursor: pointer;
    aspect-ratio: 16 / 9; border-radius: 12px; overflow: hidden; background: #14121a;
  }
  .vid-play img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease, opacity .2s; }
  .vid-play:hover img { transform: scale(1.05); opacity: .9; }
  .vid-icon {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 62px; height: 62px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: rgba(220, 30, 40, .92); color: #fff;
    box-shadow: 0 6px 20px rgba(0, 0, 0, .35); transition: transform .2s, background .2s;
  }
  .vid-icon svg { width: 30px; height: 30px; margin-left: 2px; }
  .vid-play:hover .vid-icon { transform: translate(-50%, -50%) scale(1.08); background: rgb(220, 30, 40); }
  .vid-badge {
    position: absolute; top: 10px; left: 10px;
    padding: 5px 11px; border-radius: 999px; font-size: 12.5px; font-weight: 700;
    background: rgba(20, 18, 26, .82); color: #fff; -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px);
  }
  .vid-badge.place-1 { background: linear-gradient(135deg, #f5cf5a, #c8912a); color: #3a2a00; }
  .vid-badge.place-2 { background: linear-gradient(135deg, #d7dbe0, #a3a8b0); color: #2a2d33; }
  .vid-badge.place-3 { background: linear-gradient(135deg, #e0a878, #b5773f); color: #3a1e00; }
  .vid-title { margin: 12px 0 0; font-weight: 600; font-size: 15.5px; color: #14121a; line-height: 1.4; }

  .vid-card.playing .vid-play { cursor: default; }
  .vid-card iframe { width: 100%; aspect-ratio: 16 / 9; border: 0; border-radius: 12px; display: block; }

  @media (max-width: 900px) { .vid-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .vid-grid { grid-template-columns: 1fr; } }
</style>

<script>
  document.querySelectorAll(".vid-play").forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-yt");
      if (!id) return;
      const card = btn.closest(".vid-card");
      const iframe = document.createElement("iframe");
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
      iframe.allowFullscreen = true;
      iframe.title = btn.getAttribute("aria-label") || "Vídeo";
      card.classList.add("playing");
      btn.replaceWith(iframe);
    });
  });
</script>
