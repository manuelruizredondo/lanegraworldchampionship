---
// Página insignia del Mundial: explica qué es el Campeonato Mundial de Pasos Libres.
// Primer ítem del submenú MUNDIAL. Contenido trilingüe (ES/EN/IT).
import { img } from "@/data/img.js";
import SubNav from "@/components/SubNav.astro";
import Statement from "@/components/Statement.astro";

const { lang = "es" } = Astro.props;

// Menú de secciones (píldora sticky) — mismo patrón que el Festival
const NAV = {
  es: { label: "Secciones del Mundial", items: [
    { label: "QUÉ ES", href: "#que-es" }, { label: "DISCIPLINAS", href: "#disciplinas" },
    { label: "CATEGORÍAS", href: "#categorias" }, { label: "CÓMO SE COMPITE", href: "#competir" },
    { label: "HISTORIA", href: "#historia" },
  ] },
  en: { label: "Championship sections", items: [
    { label: "WHAT IT IS", href: "#que-es" }, { label: "DISCIPLINES", href: "#disciplinas" },
    { label: "CATEGORIES", href: "#categorias" }, { label: "HOW IT WORKS", href: "#competir" },
    { label: "HISTORY", href: "#historia" },
  ] },
  it: { label: "Sezioni del Mondiale", items: [
    { label: "COS'È", href: "#que-es" }, { label: "DISCIPLINE", href: "#disciplinas" },
    { label: "CATEGORIE", href: "#categorias" }, { label: "COME SI COMPETE", href: "#competir" },
    { label: "STORIA", href: "#historia" },
  ] },
};
const nav = NAV[lang] || NAV.es;

const IG_URL = "https://www.instagram.com/lanegraworldchampionship/";

const T = {
  es: {
    eyebrow: "El Campeonato Mundial de Pasos Libres",
    h1: "El Mundial",
    lead: "El corazón competitivo de La Negra Dance Festival: la cita donde los mejores bailarines de salsa y bachata del planeta se juegan el título mundial.",
    ig: "Síguenos en Instagram",
    intro1: "El Mundial de Pasos Libres La Negra es uno de los campeonatos de baile latino más prestigiosos del mundo. Cada año, competidores de más de 20 países se dan cita en Calpe (Alicante) para medirse en la pista y en el escenario, ante un jurado formado por estrellas internacionales de la salsa y la bachata.",
    intro2: "\"Pasos libres\" significa libertad de estilo: cada bailarín o grupo interpreta su propia coreografía y personalidad. No hay un molde único, gana quien mejor combina técnica, musicalidad, puesta en escena y emoción.",
    stats: [
      { n: "XV", l: "Mundial de Salsa 2026" },
      { n: "V", l: "Mundial de Bachata 2026" },
      { n: "+20", l: "Países" },
      { n: "11", l: "Categorías" },
    ],
    discTitle: "Dos disciplinas, un mismo escenario",
    basesBtn: "Ver las bases",
    disciplines: [
      { tag: "XV edición", title: "Mundial de Salsa", desc: "La gran cita de la salsa en todos sus estilos: cubana, lineal On1 y On2, fusión y lo más urbano. Quince ediciones consolidan el campeonato de salsa de referencia.", href: "/bases-y-reglamento/#salsa" },
      { tag: "V edición", title: "Mundial de Bachata", desc: "La bachata en toda su esencia: dominicana, sensual, tradicional y fusión. Un campeonato joven que crece cada año y ya es cita obligada para los bachateros de todo el mundo.", href: "/bases-y-reglamento/#bachata" },
    ],
    catTitle: "Categorías",
    catIntro: "Se compite en salsa y en bachata, en múltiples formatos para todos los niveles y formaciones:",
    categories: ["Solistas Chicas", "Solistas Chicos", "Dúos Femeninos", "Dúos Masculinos", "Dúos Mixtos", "Parejas", "Grupos", "Equipos"],
    formatTitle: "Cómo se compite",
    formatSteps: [
      { n: "1", title: "Preeliminatorias", desc: "Las primeras rondas en pista, donde cada participante demuestra su nivel ante el jurado." },
      { n: "2", title: "Eliminatorias", desc: "Se seleccionan los mejores de cada categoría para dar el salto al gran escenario." },
      { n: "3", title: "Gran Final", desc: "Las finales sobre el escenario del Mundial, ante el público y un jurado de estrellas internacionales." },
    ],
    histTitle: "Historia y palmarés",
    histText: "Revive a los campeones y las mejores actuaciones de cada edición del Mundial.",
    histLinks: [
      { t: "Ediciones anteriores", h: "/ediciones/" },
      { t: "Vídeos del Mundial", h: "/videos/" },
      { t: "Ganadores 2025", h: "/ganadores-2025/" },
    ],
    ctaTitle: "¿Listo para competir?",
    ctaText: "Consulta las bases oficiales de salsa y bachata y prepárate para el próximo Mundial.",
    ctaButtons: [
      { t: "Bases y reglamento", h: "/bases-y-reglamento/", solid: true },
      { t: "Ver competidores", h: "/competidores/", solid: false },
    ],
  },
  en: {
    eyebrow: "The Pasos Libres World Championship",
    h1: "The Championship",
    lead: "The competitive heart of La Negra Dance Festival: where the best salsa and bachata dancers on the planet fight for the world title.",
    ig: "Follow us on Instagram",
    intro1: "The La Negra Pasos Libres World Championship is one of the most prestigious Latin dance championships in the world. Every year, competitors from more than 20 countries gather in Calpe (Alicante, Spain) to compete on the floor and on stage, before a jury of international salsa and bachata stars.",
    intro2: "\"Pasos libres\" (free steps) means freedom of style: each dancer or group performs their own choreography and personality. There is no single mould — the winner is whoever best combines technique, musicality, staging and emotion.",
    stats: [
      { n: "XV", l: "Salsa World Cup 2026" },
      { n: "V", l: "Bachata World Cup 2026" },
      { n: "+20", l: "Countries" },
      { n: "11", l: "Categories" },
    ],
    discTitle: "Two disciplines, one stage",
    basesBtn: "See the rules",
    disciplines: [
      { tag: "15th edition", title: "Salsa World Cup", desc: "The great salsa gathering in all its styles: Cuban, linear On1 and On2, fusion and the most urban. Fifteen editions make it the benchmark salsa championship.", href: "/en/competition-rules/#salsa" },
      { tag: "5th edition", title: "Bachata World Cup", desc: "Bachata in all its essence: Dominican, sensual, traditional and fusion. A young championship that grows every year and is already a must for bachata dancers worldwide.", href: "/en/competition-rules/#bachata" },
    ],
    catTitle: "Categories",
    catIntro: "Competition takes place in salsa and bachata, across multiple formats for all levels and line-ups:",
    categories: ["Female Solos", "Male Solos", "Female Duos", "Male Duos", "Mixed Duos", "Couples", "Groups", "Teams"],
    formatTitle: "How it works",
    formatSteps: [
      { n: "1", title: "Pre-qualifiers", desc: "The first rounds on the floor, where each participant shows their level to the jury." },
      { n: "2", title: "Qualifiers", desc: "The best of each category are selected to make the leap to the main stage." },
      { n: "3", title: "Grand Final", desc: "The finals on the Championship stage, before the audience and a jury of international stars." },
    ],
    histTitle: "History & roll of honour",
    histText: "Relive the champions and the best performances of every edition of the Championship.",
    histLinks: [
      { t: "Past editions", h: "/en/editions/" },
      { t: "Championship videos", h: "/en/videos/" },
      { t: "Winners 2025", h: "/en/winners-2025/" },
    ],
    ctaTitle: "Ready to compete?",
    ctaText: "Check the official salsa and bachata rules and get ready for the next Championship.",
    ctaButtons: [
      { t: "Rules & regulations", h: "/en/competition-rules/", solid: true },
      { t: "See competitors", h: "/en/competitors/", solid: false },
    ],
  },
  it: {
    eyebrow: "Il Mondiale di Pasos Libres",
    h1: "Il Mondiale",
    lead: "Il cuore competitivo di La Negra Dance Festival: dove i migliori ballerini di salsa e bachata del pianeta si contendono il titolo mondiale.",
    ig: "Seguici su Instagram",
    intro1: "Il Mondiale di Pasos Libres La Negra è uno dei campionati di ballo latino più prestigiosi al mondo. Ogni anno, concorrenti da più di 20 paesi si ritrovano a Calpe (Alicante, Spagna) per sfidarsi in pista e sul palco, davanti a una giuria di stelle internazionali della salsa e della bachata.",
    intro2: "\"Pasos libres\" (passi liberi) significa libertà di stile: ogni ballerino o gruppo interpreta la propria coreografia e personalità. Non c'è un unico stampo — vince chi combina meglio tecnica, musicalità, messa in scena ed emozione.",
    stats: [
      { n: "XV", l: "Mondiale di Salsa 2026" },
      { n: "V", l: "Mondiale di Bachata 2026" },
      { n: "+20", l: "Paesi" },
      { n: "11", l: "Categorie" },
    ],
    discTitle: "Due discipline, un solo palco",
    basesBtn: "Vedi il regolamento",
    disciplines: [
      { tag: "15ª edizione", title: "Mondiale di Salsa", desc: "Il grande appuntamento della salsa in tutti i suoi stili: cubana, lineare On1 e On2, fusion e il più urbano. Quindici edizioni ne fanno il campionato di salsa di riferimento.", href: "/it/regolamento/#salsa" },
      { tag: "5ª edizione", title: "Mondiale di Bachata", desc: "La bachata in tutta la sua essenza: dominicana, sensual, tradizionale e fusion. Un campionato giovane che cresce ogni anno ed è già un appuntamento imperdibile per i bachateri di tutto il mondo.", href: "/it/regolamento/#bachata" },
    ],
    catTitle: "Categorie",
    catIntro: "Si compete in salsa e bachata, in molteplici formati per tutti i livelli e formazioni:",
    categories: ["Soliste", "Solisti", "Duo Femminili", "Duo Maschili", "Duo Misti", "Coppie", "Gruppi", "Squadre"],
    formatTitle: "Come si compete",
    formatSteps: [
      { n: "1", title: "Pre-eliminatorie", desc: "I primi turni in pista, dove ogni partecipante mostra il proprio livello alla giuria." },
      { n: "2", title: "Eliminatorie", desc: "I migliori di ogni categoria vengono selezionati per il salto sul grande palco." },
      { n: "3", title: "Gran Finale", desc: "Le finali sul palco del Mondiale, davanti al pubblico e a una giuria di stelle internazionali." },
    ],
    histTitle: "Storia e albo d'oro",
    histText: "Rivivi i campioni e le migliori esibizioni di ogni edizione del Mondiale.",
    histLinks: [
      { t: "Edizioni precedenti", h: "/it/edizioni/" },
      { t: "Video del Mondiale", h: "/it/videos/" },
      { t: "Vincitori 2025", h: "/it/winners-2025/" },
    ],
    ctaTitle: "Pronto a competere?",
    ctaText: "Consulta il regolamento ufficiale di salsa e bachata e preparati per il prossimo Mondiale.",
    ctaButtons: [
      { t: "Regolamento", h: "/it/regolamento/", solid: true },
      { t: "Vedi i concorrenti", h: "/it/competitors/", solid: false },
    ],
  },
};

const t = T[lang] || T.es;
const igIcon = `<svg viewBox="0 0 24 24" width="19" height="19" fill="currentColor" aria-hidden="true"><path d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.8.3 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.3 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.8-.3-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.4-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.9c.1-1.2.3-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4C8.4 2.2 8.8 2.2 12 2.2zm0 4.9a4.9 4.9 0 1 0 0 9.8 4.9 4.9 0 0 0 0-9.8zm0 8.1a3.2 3.2 0 1 1 0-6.4 3.2 3.2 0 0 1 0 6.4zm6.3-8.3a1.1 1.1 0 1 1-2.3 0 1.1 1.1 0 0 1 2.3 0z"/></svg>`;

// Declaración con palabras subrayadas en oro (estilo home)
const hl = (w, second) => `<span class="p-hl${second ? " p-hl-2" : ""}">${w}<svg class="p-hl-line" viewBox="0 0 500 150" preserveAspectRatio="none" aria-hidden="true"><path d="M8.1,146.2c0,0,240.6-55.6,479-13.8" pathLength="500"></path></svg></span>`;
const STATEMENT = {
  es: { h: `El escenario donde los mejores del planeta se juegan el título en la ${hl("salsa")} y la ${hl("bachata", true)}, ante un jurado de leyendas.`, sub: "Quince ediciones de técnica, musicalidad y emoción sobre la gran tarima." },
  en: { h: `The stage where the world's best fight for the title in ${hl("salsa")} and ${hl("bachata", true)}, before a jury of legends.`, sub: "Fifteen editions of technique, musicality and emotion on the great stage." },
  it: { h: `Il palco dove i migliori del pianeta si contendono il titolo in ${hl("salsa")} e ${hl("bachata", true)}, davanti a una giuria di leggende.`, sub: "Quindici edizioni di tecnica, musicalità ed emozione sul grande palco." },
};
const st = STATEMENT[lang] || STATEMENT.es;
---

<section class="p-phero mu-hero" style={`background-image:url(${img("ganadores_grupos_salsa_2025.jpg")})`}>
  <div class="p-phero-inner">
    <p class="p-eyebrow">{t.eyebrow}</p>
    <h1 class="p-phero-title">{t.h1}</h1>
    <p class="p-phero-sub">{t.lead}</p>
    <div class="p-phero-cta">
      <a class="mu-ig" href={IG_URL} target="_blank" rel="noopener">
        <Fragment set:html={igIcon} />
        {t.ig}
      </a>
    </div>
  </div>
</section>

<!-- Menú de secciones (justo después del hero) -->
<SubNav items={nav.items} label={nav.label} />

<!-- Declaración (insignia girando + frase grande con subrayado dorado) -->
<Statement html={st.h} sub={st.sub} id="que-es" />

<section class="section-tight">
  <div class="container mu-intro">
    <p>{t.intro1}</p>
    <p>{t.intro2}</p>
  </div>
  <div class="container">
    <div class="mu-stats">
      {t.stats.map((s) => (
        <div class="mu-stat"><span class="mu-stat-n">{s.n}</span><span class="mu-stat-l">{s.l}</span></div>
      ))}
    </div>
  </div>
</section>

<section id="disciplinas" class="section mu-disc-sec">
  <div class="container text-center">
    <h2 class="script-title mu-h2">{t.discTitle}</h2>
  </div>
  <div class="container mu-disc">
    {t.disciplines.map((d) => (
      <article class="mu-disc-card">
        <span class="mu-disc-tag">{d.tag}</span>
        <h3 class="mu-disc-t">{d.title}</h3>
        <p class="mu-disc-d">{d.desc}</p>
        <a class="mu-disc-btn" href={d.href}>{t.basesBtn}</a>
      </article>
    ))}
  </div>
</section>

<section id="categorias" class="section-tight">
  <div class="container mu-cat">
    <div class="mu-cat-head">
      <h2 class="script-title mu-h2">{t.catTitle}</h2>
      <p class="mu-cat-intro">{t.catIntro}</p>
    </div>
    <div class="mu-chips">
      {t.categories.map((c) => <span class="mu-chip">{c}</span>)}
    </div>
  </div>
</section>

<section id="competir" class="section mu-format-sec">
  <div class="container text-center">
    <h2 class="script-title mu-h2">{t.formatTitle}</h2>
  </div>
  <div class="container mu-steps">
    {t.formatSteps.map((s) => (
      <article class="mu-step">
        <span class="mu-step-n">{s.n}</span>
        <h3 class="mu-step-t">{s.title}</h3>
        <p class="mu-step-d">{s.desc}</p>
      </article>
    ))}
  </div>
</section>

<section id="historia" class="section-tight text-center">
  <div class="container">
    <h2 class="script-title mu-h2">{t.histTitle}</h2>
    <p class="mu-cat-intro mu-center">{t.histText}</p>
    <div class="mu-hist-links">
      {t.histLinks.map((l) => <a class="btn btn-outline" href={l.h}>{l.t}</a>)}
    </div>
  </div>
</section>

<section class="section mu-cta-sec">
  <div class="container">
    <div class="mu-cta text-center">
      <h2 class="script-title mu-h2 mu-white">{t.ctaTitle}</h2>
      <p class="mu-cta-text">{t.ctaText}</p>
      <div class="mu-cta-btns">
        {t.ctaButtons.map((b) => <a class={b.solid ? "btn btn-light" : "btn btn-outline-light"} href={b.h}>{b.t}</a>)}
      </div>
      <a class="mu-ig mu-ig-dark" href={IG_URL} target="_blank" rel="noopener">
        <Fragment set:html={igIcon} />
        @lanegraworldchampionship
      </a>
    </div>
  </div>
</section>

<style>
  .eyebrow.dark { color: var(--gold); }

  /* Hero del Mundial: sube bajo el header (que queda transparente hasta el scroll),
     contenido alineado arriba y con hueco para no quedar tapado por el header */
  .mu-hero {
    display: flex; flex-direction: column; align-items: center; justify-content: flex-start;
    margin-top: calc(-1 * var(--header-bar, 76px));
    min-height: clamp(460px, 76vh, 720px);
    padding-top: calc(var(--header-bar, 76px) + clamp(28px, 6vw, 70px));
    padding-bottom: clamp(56px, 9vw, 110px);
  }

  .mu-h2 { font-size: clamp(24px, 3.4vw, 38px); }

  .mu-lead { max-width: 660px; margin: 8px auto 22px; color: #5a5a64; font-size: clamp(17px, 2vw, 20px); line-height: 1.55; }
  .mu-ig {
    display: inline-flex; align-items: center; gap: 9px;
    padding: 11px 22px; border-radius: 999px; text-decoration: none;
    background: var(--gold); color: #fff; font-weight: 700; font-size: 15px;
    transition: background .2s, transform .15s;
  }
  .mu-ig:hover { background: var(--gold-dark); transform: translateY(-2px); }

  .mu-intro { max-width: 820px; }
  .mu-intro p { font-size: 17px; line-height: 1.7; color: #3a3a44; margin: 0 0 18px; }

  .mu-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 20px; border-top: 1px solid #ece8e1; border-bottom: 1px solid #ece8e1; padding: 30px 0; }
  .mu-stat { text-align: center; }
  .mu-stat-n { display: block; font-family: var(--font-body); font-weight: 800; font-size: clamp(30px, 4.5vw, 52px); line-height: 1; letter-spacing: -.02em; color: var(--gold-dark); }
  .mu-stat-l { display: block; margin-top: 8px; font-size: 13px; color: #6a6a74; letter-spacing: .02em; }

  .mu-disc-sec { background: var(--cream); }
  .mu-disc { display: grid; grid-template-columns: 1fr 1fr; gap: 26px; margin-top: 28px; }
  .mu-disc-card { background: #fff; border: 1px solid #ece8e1; border-radius: 18px; padding: 32px 30px; display: flex; flex-direction: column; align-items: flex-start; }
  .mu-disc-tag { display: inline-block; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--gold-dark); background: #faf3e2; padding: 4px 12px; border-radius: 999px; margin-bottom: 14px; }
  .mu-disc-t { font-size: clamp(22px, 3vw, 28px); font-weight: 700; letter-spacing: -.02em; color: #14121a; margin: 0 0 10px; }
  .mu-disc-d { font-size: 15.5px; line-height: 1.65; color: #4a4a54; margin: 0 0 22px; }
  .mu-disc-btn {
    margin-top: auto; display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 24px; border-radius: 999px; text-decoration: none;
    background: var(--gold); color: #fff; font-weight: 700; font-size: 15px;
    transition: background .2s, transform .15s;
  }
  .mu-disc-btn::after { content: "→"; font-size: 16px; }
  .mu-disc-btn:hover { background: var(--gold-dark); transform: translateY(-2px); }

  .mu-cat { max-width: 900px; }
  .mu-cat-head { text-align: center; margin-bottom: 26px; }
  .mu-cat-intro { color: #5a5a64; font-size: 16px; line-height: 1.6; max-width: 620px; margin: 8px auto 0; }
  .mu-center { margin-left: auto; margin-right: auto; }
  .mu-chips { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
  .mu-chip { padding: 10px 20px; border-radius: 999px; border: 1.5px solid #e6e3dd; background: #fff; font-weight: 600; font-size: 15px; color: #14121a; }

  .mu-format-sec { background: var(--cream); }
  .mu-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 28px; }
  .mu-step { background: #fff; border: 1px solid #ece8e1; border-radius: 18px; padding: 30px 28px; }
  .mu-step-n {
    display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px; border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), var(--gold-dark)); color: #fff;
    font-weight: 800; font-size: 20px; margin-bottom: 16px;
  }
  .mu-step-t { font-size: 19px; font-weight: 700; color: #14121a; margin: 0 0 8px; }
  .mu-step-d { font-size: 15px; line-height: 1.6; color: #4a4a54; margin: 0; }

  .mu-hist-links { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-top: 22px; }

  .mu-cta-sec { padding-bottom: clamp(50px, 8vw, 90px); }
  .mu-cta { background: linear-gradient(160deg, #211c3d 0%, #0f0b1e 100%); border-radius: 28px; padding: clamp(40px, 6vw, 72px) clamp(24px, 5vw, 60px); }
  .mu-white { color: #fff; }
  .mu-cta-text { color: rgba(255, 255, 255, .8); font-size: 16px; line-height: 1.6; max-width: 560px; margin: 0 auto 26px; }
  .mu-cta-btns { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; margin-bottom: 26px; }
  .btn-outline-light { background: transparent; color: #fff; border: 1.5px solid rgba(255, 255, 255, .5); }
  .btn-outline-light:hover { background: rgba(255, 255, 255, .12); }
  .mu-ig-dark { background: rgba(255, 255, 255, .12); }
  .mu-ig-dark:hover { background: var(--gold); }

  @media (max-width: 820px) {
    .mu-stats { grid-template-columns: repeat(2, 1fr); gap: 26px 20px; }
    .mu-disc { grid-template-columns: 1fr; }
    .mu-steps { grid-template-columns: 1fr; }
  }
</style>
