---
import { REGLAMENTO, REGLAMENTO_META, REGLAMENTO_PDF } from "@/data/reglamento.js";

const { lang = "es" } = Astro.props;
const t = REGLAMENTO_META[lang] || REGLAMENTO_META.es;

// Contenido del idioma; si falta, respaldo en español
const src = REGLAMENTO[lang] || REGLAMENTO.es;
const salsa = (src.salsa && src.salsa.length) ? src.salsa : REGLAMENTO.es.salsa;
const bachata = (src.bachata && src.bachata.length) ? src.bachata : REGLAMENTO.es.bachata;
const DOCS = [
  { key: "salsa", label: t.tabs.salsa, blocks: salsa, pdf: REGLAMENTO_PDF.salsa },
  { key: "bachata", label: t.tabs.bachata, blocks: bachata, pdf: REGLAMENTO_PDF.bachata },
];

// Resalta en negrita la hora, la disciplina y palabras clave de cada línea de horario
const esc = (s) => s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
const fmtSchedule = (s) => {
  let out = esc(s);
  out = out.replace(/^(\s*\d{1,2}:\d{2}(?:\s*a\s*\d{1,2}:\d{2}h?)?)/, "<strong>$1</strong>");
  out = out.replace(/\b(SALSA|BACHATA)\b/g, "<strong>$1</strong>");
  out = out.replace(/\b(Descanso[-\s]?\w*|Premiaci[oó]n\b[^,.]*|Ceremonia\b[^,.]*|DANI J[^,.]*)/gi, "<strong>$1</strong>");
  return out;
};
---

<section class="rg-hero">
  <div class="container">
    <p class="eyebrow dark">{t.eyebrow}</p>
    <h1 class="script-title">{t.h1}</h1>
    <p class="rg-sub">{t.sub}</p>
  </div>
</section>

<div class="rg-tabs-bar">
  <div class="container rg-tabs">
    {DOCS.map((d, i) => (
      <button class={"rg-tab" + (i === 0 ? " active" : "")} data-doc={d.key} type="button">{d.label}</button>
    ))}
  </div>
</div>

<section class="rg-body">
  <div class="container">
    {DOCS.map((d, i) => (
      <article class={"rg-doc" + (i === 0 ? " active" : "")} data-doc-panel={d.key}>
        <a class="rg-pdf" href={d.pdf} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>
          {t.pdf}
        </a>
        {d.blocks.map((b) => (
          b.type === "h2" ? <h2 class="rg-h2">{b.text}</h2> :
          b.type === "h3" ? <h3 class="rg-h3">{b.text}</h3> :
          b.type === "p" ? <p class="rg-p">{b.text}</p> :
          b.type === "note" ? <p class="rg-note">{b.text}</p> :
          b.type === "ul" ? <ul class="rg-ul">{b.items.map((it) => <li>{it}</li>)}</ul> :
          b.type === "schedule" ? (
            <div class="rg-sched">
              <p class="rg-sched-day">{b.day}</p>
              <ul class="rg-sched-list">{b.items.map((it) => <li set:html={fmtSchedule(it)}></li>)}</ul>
            </div>
          ) : null
        ))}
        <p class="rg-updated">{t.updated}</p>
      </article>
    ))}
  </div>
</section>

<script>
  const tabs = [...document.querySelectorAll(".rg-tab")];
  const panels = [...document.querySelectorAll("[data-doc-panel]")];
  const activate = (key, scroll) => {
    if (!tabs.some((t) => t.dataset.doc === key)) return;
    tabs.forEach((x) => x.classList.toggle("active", x.dataset.doc === key));
    panels.forEach((p) => p.classList.toggle("active", p.dataset.docPanel === key));
    if (scroll) window.scrollTo({ top: 0, behavior: "smooth" });
  };
  tabs.forEach((tab) => tab.addEventListener("click", () => {
    activate(tab.dataset.doc, true);
    history.replaceState(null, "", "#" + tab.dataset.doc);
  }));
  // Abrir la pestaña indicada en la URL (ej. /bases-y-reglamento/#bachata)
  const fromHash = () => activate((location.hash || "").replace("#", ""), false);
  fromHash();
  window.addEventListener("hashchange", fromHash);
</script>

<style>
  .rg-hero { padding: clamp(36px, 6vw, 68px) 0 clamp(16px, 3vw, 26px); text-align: center; }
  .rg-hero .script-title { margin: 0 0 12px; }
  .rg-sub { max-width: 640px; margin: 0 auto; color: #6a6a74; font-size: 16px; line-height: 1.6; }

  .rg-tabs-bar {
    position: sticky; top: var(--header-h, 88px); z-index: 500;
    background: rgba(255, 255, 255, 0.88);
    -webkit-backdrop-filter: blur(14px); backdrop-filter: blur(14px);
    border-bottom: 1px solid #ece8e1; padding: 10px 0;
  }
  .rg-tabs { display: flex; gap: 8px; justify-content: center; }
  .rg-tab {
    flex: 0 0 auto; padding: 9px 26px; border-radius: 999px; cursor: pointer;
    border: 1.5px solid #e6e3dd; background: #fff; color: #14121a;
    font-family: var(--font-body); font-weight: 700; font-size: 15px; transition: all .18s ease;
  }
  .rg-tab:hover { border-color: var(--gold); }
  .rg-tab.active { background: var(--gold); border-color: var(--gold); color: #fff; }

  .rg-body { padding: clamp(24px, 4vw, 40px) 0 72px; }
  .rg-body .container { max-width: 820px; }
  .rg-doc { display: none; }
  .rg-doc.active { display: block; }

  .rg-pdf {
    display: inline-flex; align-items: center; gap: 8px; margin: 0 0 26px;
    padding: 10px 20px; border-radius: 999px; background: #14121a; color: #fff;
    text-decoration: none; font-weight: 600; font-size: 14px; transition: opacity .15s;
  }
  .rg-pdf:hover { opacity: .88; }

  .rg-h2 {
    font-size: clamp(20px, 3vw, 26px); font-weight: 800; letter-spacing: -.02em; color: #14121a;
    margin: 40px 0 14px; padding-bottom: 10px; border-bottom: 2px solid #ece8e1; line-height: 1.2;
  }
  .rg-doc > .rg-pdf + .rg-h2 { margin-top: 0; }
  .rg-h3 { font-size: 17px; font-weight: 700; color: #14121a; margin: 26px 0 6px; line-height: 1.35; }
  .rg-p { font-size: 15.5px; line-height: 1.7; color: #3a3a44; margin: 0 0 14px; }
  .rg-ul { margin: 0 0 16px; padding-left: 22px; }
  .rg-ul li { font-size: 15.5px; line-height: 1.6; color: #3a3a44; margin-bottom: 6px; }

  .rg-note {
    background: #faf3e2; border-left: 4px solid var(--gold); border-radius: 8px;
    padding: 14px 18px; margin: 0 0 18px; font-size: 15px; line-height: 1.6; color: #5a4a22; font-weight: 500;
  }

  .rg-sched { background: #faf7f1; border: 1px solid #ece8e1; border-radius: 12px; padding: 14px 18px; margin: 0 0 14px; }
  .rg-sched-day { margin: 0 0 8px; font-weight: 800; font-size: 14px; text-transform: uppercase; letter-spacing: .04em; color: var(--gold-dark); }
  .rg-sched-list { margin: 0; padding: 0; list-style: none; }
  .rg-sched-list li { font-size: 14.5px; line-height: 1.7; color: #3a3a44; padding-left: 2px; }
  .rg-sched-list strong { color: #14121a; font-weight: 800; }

  .rg-updated { margin: 40px 0 0; font-size: 12.5px; color: #9a9aa2; }

  @media (max-width: 640px) {
    .rg-tab { padding: 8px 20px; font-size: 14px; }
  }
</style>
