  /* Tipografía */
  .p-eyebrow { font-weight: 700; text-transform: uppercase; letter-spacing: .14em; font-size: 13px; color: var(--gold); margin: 0 0 16px; }
  .p-display { font-weight: 600; font-size: clamp(38px, 6.6vw, 88px); line-height: .98; letter-spacing: -.05em; margin: 0 0 20px; }
  .p-h2 { font-weight: 600; font-size: clamp(28px, 4vw, 50px); line-height: 1.05; letter-spacing: -.05em; margin: 0 0 20px; }
  .p-lead { font-size: clamp(16px, 1.5vw, 20px); line-height: 1.6; color: var(--p-muted); margin: 0; }
  .p-quote { margin-top: 20px; }

  /* Botones */
  .p-btn { display: inline-block; padding: 15px 30px; border-radius: 999px; font-weight: 700; font-size: 16px; text-decoration: none; transition: transform .15s ease, opacity .2s, background .2s, color .2s; }
  .p-btn:hover { transform: translateY(-2px); }
  .p-btn-sm { padding: 11px 22px; font-size: 14px; }
  .p-btn-dark { background: var(--p-ink); color: #fff; }
  .p-btn-light { background: #fff; color: var(--p-ink); border: 1px solid var(--p-line); }
  .p-btn-outline { background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,.5); }
  .p-btn-outline:hover { background: rgba(255,255,255,.1); }
  .p-link { color: var(--p-ink); font-weight: 700; }

  /* HERO oscuro */
  .p-hero { position: relative; overflow: hidden; background: radial-gradient(120% 120% at 50% 0%, #211c33 0%, #0f0b1e 60%); color: #fff; min-height: 100vh; min-height: 100svh; display: flex; align-items: center; justify-content: center; text-align: center; margin-top: calc(-1 * var(--header-bar, 64px)); padding: 140px 24px 90px; }
  .p-hero-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  /* Oscurecido para legibilidad del contenido sobre el vídeo */
  .p-hero::after { content: ""; position: absolute; inset: 0; z-index: 1; background: linear-gradient(180deg, rgba(10, 8, 20, .55) 0%, rgba(10, 8, 20, .35) 45%, rgba(10, 8, 20, .6) 100%); pointer-events: none; }
  .p-hero-inner { position: relative; z-index: 2; }

  /* MARQUEE (justo después del hero) */
  .p-marquee { overflow: hidden; padding: clamp(30px, 4.5vw, 64px) 0; will-change: transform; }
  .p-marquee-track { display: flex; width: max-content; }
  .p-marquee-half { display: flex; align-items: center; gap: clamp(28px, 3.8vw, 58px); padding-right: clamp(28px, 3.8vw, 58px); }
  .p-marquee-half span { font-weight: 400; font-size: clamp(64px, 10.5vw, 150px); line-height: 1; letter-spacing: -0.09em; white-space: nowrap; }
  .p-marquee-half :global(.p-fire) {
    height: clamp(38px, 5.6vw, 86px); width: auto; overflow: visible;
    filter: drop-shadow(0 0 12px rgba(238, 123, 30, .5));
  }
  .p-marquee-half :global(.p-fire-o),
  .p-marquee-half :global(.p-fire-i) { transform-origin: 50% 100%; transform-box: fill-box; }
  .p-marquee-half :global(.p-fire-o) { animation: p-fire-flicker .9s ease-in-out infinite; }
  .p-marquee-half :global(.p-fire-i) { animation: p-fire-flicker-i .65s ease-in-out infinite; }
  .p-marquee-half:nth-child(2n) :global(.p-fire-o) { animation-delay: -.45s; }
  .p-marquee-half :global(.p-fire:nth-of-type(2n) .p-fire-o) { animation-delay: -.3s; }
