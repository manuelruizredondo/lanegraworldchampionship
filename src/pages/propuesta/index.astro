  .p-final { background: radial-gradient(120% 120% at 50% 0%, #211c33 0%, #0f0b1e 65%); color: #fff; text-align: center; padding: var(--p-gap) 24px; }
  .p-final-inner { max-width: 780px; margin: 0 auto; }
  .p-white { color: #fff; }
