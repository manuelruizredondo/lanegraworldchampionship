  .p-hero-date span:last-child { font-weight: 700; letter-spacing: .18em; text-transform: uppercase; font-size: clamp(12px, 1.5vw, 15px); color: rgba(255,255,255,.75); }
  .p-hero-cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  /* INTRO */
  .p-intro { display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(30px, 5vw, 70px); align-items: end; }
