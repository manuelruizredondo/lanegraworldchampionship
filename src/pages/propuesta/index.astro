  .p-value-d { color: var(--p-muted); font-size: 15px; line-height: 1.55; margin: 0; }
  .p-values-media { border-radius: var(--p-radius); overflow: hidden; aspect-ratio: 3/4; }
  .p-values-media img { width: 100%; height: 100%; object-fit: cover; }

  /* STATS */
  .p-stats { padding: clamp(30px, 4vw, 54px) 0; border-top: 1px solid var(--p-line); border-bottom: 1px solid var(--p-line); }
  .p-stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .p-stat { display: flex; flex-direction: column; gap: 6px; }
