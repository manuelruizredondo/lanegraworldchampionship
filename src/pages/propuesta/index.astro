    .p-values { gap: 26px; }
    .p-value { padding: 9px 0; border-bottom: none; }
  }
  @media (max-width: 520px) {
  }

  /* Contador del hero */
  .p-hero-count { display: flex; justify-content: center; align-items: stretch; margin-top: 40px; }
  .p-hc { display: flex; flex-direction: column; align-items: center; padding: 0 clamp(14px, 3vw, 30px); }
  .p-hc + .p-hc { border-left: 1px solid rgba(255, 255, 255, .28); }
  .p-hc-n { font-weight: 600; font-size: clamp(24px, 3.4vw, 42px); line-height: 1; letter-spacing: -.02em; font-variant-numeric: tabular-nums; color: #fff; }
  .p-hc-l { margin-top: 7px; font-size: 11px; text-transform: uppercase; letter-spacing: .16em; color: rgba(255, 255, 255, .7); }

  /* Resaltado dorado con subrayado curvo que se dibuja */
  .p-hl { position: relative; display: inline-block; color: var(--gold); }
  .p-hl-line { position: absolute; left: -2%; bottom: -.08em; width: 104%; height: .32em; overflow: visible; }
  .p-hl-line path {
    fill: none; stroke: var(--gold); stroke-width: 3px; stroke-linecap: round;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 500; stroke-dashoffset: 500;
  }
  .rv-mask.in .p-hl-line path { stroke-dashoffset: 0; transition: stroke-dashoffset 1s ease-out .7s; }
  .rv-mask.in .p-hl-2 .p-hl-line path { transition-delay: 1.5s; }
  html:not(.js-fx) .p-hl-line path { stroke-dashoffset: 0; }

  /* Insignia: cara estática con el texto circular girando encima */
  .p-badge { position: relative; width: clamp(130px, 15vw, 180px); aspect-ratio: 1; margin: 0 auto 36px; }
  .p-badge-ring { position: absolute; inset: 0; width: 100%; height: 100%; animation: p-spin 24s linear infinite; }
  .p-badge-face { position: absolute; left: 50%; top: 50%; width: 56%; transform: translate(-50%, -50%); }
  @keyframes p-spin { to { transform: rotate(-360deg); } }
  @media (max-width: 600px) { .p-badge { width: clamp(180px, 52vw, 220px); } }
  @media (prefers-reduced-motion: reduce) { .p-badge-ring { animation: none; } }

  /* ===== Efectos ===== */
  /* Entrada del hero al cargar: logo -> fecha -> lugar -> botones */
  html.js-fx .p-hero-date span,
  html.js-fx .p-hero-cta,
  html.js-fx .p-hero-count {
    opacity: 0; transform: translateY(28px);
    animation: p-hero-in .9s cubic-bezier(.22, 1, .36, 1) forwards;
  }
  html.js-fx .p-hero-date span:first-child { animation-delay: .2s; }
  html.js-fx .p-hero-date span:last-child { animation-delay: .38s; }
  html.js-fx .p-hero-cta { animation-delay: .56s; }
  html.js-fx .p-hero-count { animation-delay: .74s; }
  @keyframes p-hero-in { to { opacity: 1; transform: none; } }

  /* Reveal on scroll (las clases las añade JS; sin JS todo queda visible) */
  .rv { opacity: 0; transform: translateY(26px); transition: opacity .7s ease var(--rv-d, 0ms), transform .8s cubic-bezier(.22, 1, .36, 1) var(--rv-d, 0ms); }
  .rv.rv-scale { transform: translateY(18px) scale(.96); }
  .rv.in { opacity: 1; transform: none; }
  /* Titulares: cada frase (separada por <br>) entra deslizando, una tras otra */
  .rv-mask :global(.rv-line) { display: block; overflow: clip; padding-block: .16em; margin-block: -.16em; }
  .p-nb { white-space: nowrap; }
  .p-accent { color: var(--gold); }
  .rv-mask :global(.rv-line-inner) { display: block; transform: translateY(115%); transition: transform .85s cubic-bezier(.22, 1, .36, 1); }
  .rv-mask.in :global(.rv-line-inner) { transform: none; }

  /* Parallax interior en la imagen de valores */
  html.js-fx .p-values-media img { height: 122%; will-change: transform; }
  html.js-fx .p-band img { will-change: transform; }
  html.js-fx .p-hero-inner { will-change: transform, opacity; }

  /* Avatares blob con morph lento */
  @keyframes p-blob {
