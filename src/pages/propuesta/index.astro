  .p-stat-l { font-size: 13px; text-transform: uppercase; letter-spacing: .1em; color: var(--p-muted); }

  /* PHOTO BAND (100% ancho, parallax interior recortado, texto centrado) */
  .p-band { position: relative; width: 100%; height: clamp(420px, 62vh, 660px); overflow: hidden; }
  .p-band-media { position: absolute; inset: 0; }
  .p-band-media img { width: 100%; height: 130%; object-fit: cover; display: block; }
  .p-band::after { content: ""; position: absolute; inset: 0; z-index: 1; background: rgba(10, 8, 20, .48); }
  .p-band-content {
    position: absolute; inset: 0; z-index: 2;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; color: #fff; padding: 0 24px;
  }
  .p-band-eyebrow { font-weight: 700; text-transform: uppercase; letter-spacing: .16em; font-size: 13px; color: var(--gold); margin: 0 0 16px; }
  .p-band-title { font-weight: 600; font-size: clamp(36px, 6.4vw, 76px); line-height: 1; letter-spacing: -.04em; margin: 0 0 18px; color: #fff; }
  .p-band-sub { max-width: 560px; font-size: clamp(15px, 1.5vw, 19px); line-height: 1.6; color: rgba(255, 255, 255, .82); margin: 0; }

  /* ARTISTS (avatares blob, a todo el ancho) */
  .p-section.p-center .p-lead { text-align: center; margin-left: auto; margin-right: auto; }
  .p-artists { overflow-x: auto; width: 100%; margin: 52px 0; scrollbar-width: none; touch-action: pan-y; cursor: grab; }
  .p-artists:active { cursor: grabbing; }
  .p-artists img { -webkit-user-drag: none; }
  .p-artists-set { user-select: none; }
  .p-artists::-webkit-scrollbar { display: none; }
  html.js-fx .p-artists { overflow: hidden; }
  .p-artists-track { display: flex; width: max-content; will-change: transform; }
  .p-artists-set { display: flex; gap: clamp(22px, 3vw, 40px); padding-right: clamp(22px, 3vw, 40px); }
  .p-artist { width: clamp(170px, 19vw, 230px); flex: 0 0 auto; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .p-artist-img { width: 100%; aspect-ratio: 1; overflow: hidden; margin-bottom: 18px; border-radius: 42% 58% 47% 53% / 52% 43% 57% 48%; }
