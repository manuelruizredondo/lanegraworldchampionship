  .p-intro-cols p { font-size: 17px; line-height: 1.6; color: var(--p-muted); margin: 0; }

  /* SPLIT (título + lead) */
  .p-split { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(30px, 5vw, 70px); align-items: end; margin-bottom: 44px; }

  /* PILLARS */
  .p-pillars { display: grid; grid-template-columns: 1fr 1fr; gap: 26px; }
  .p-pillar { position: relative; display: block; border-radius: var(--p-radius); overflow: hidden; text-decoration: none; color: #fff; min-height: clamp(420px, 46vw, 560px); }
  .p-pillar-media { position: absolute; inset: 0; }
  .p-pillar-media img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease; }
  .p-pillar:hover .p-pillar-media img { transform: scale(1.04); }
  .p-pillar-panel { position: absolute; left: 16px; right: 16px; bottom: 16px; background: rgba(15,11,30,.9); -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px); border-radius: 20px; padding: 26px 28px; }
  .p-pillar-tag { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; color: var(--gold); }
  .p-pillar-t { font-weight: 800; font-size: clamp(30px, 4vw, 46px); letter-spacing: -.02em; margin: 6px 0 10px; }
  .p-pillar-d { color: rgba(255,255,255,.8); font-size: 15px; line-height: 1.5; margin: 0 0 18px; }

  /* CARDS (imagen a sangre + panel inferior con blur oscuro) */
  .p-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .p-card { position: relative; display: block; border-radius: var(--p-radius); overflow: hidden; text-decoration: none; color: #fff; min-height: clamp(400px, 36vw, 520px); transition: transform .15s ease; }
  .p-card:hover { transform: translateY(-4px); }
  .p-card-media { position: absolute; inset: 0; }
  .p-card-media img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease; }
  .p-card:hover .p-card-media img { transform: scale(1.04); }
  .p-card-panel {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 22px 24px 24px;
    background: rgba(15, 11, 30, .55);
    -webkit-backdrop-filter: blur(10px); backdrop-filter: blur(10px);
  }
  .p-card-t { font-weight: 800; font-size: clamp(22px, 2.4vw, 30px); letter-spacing: -.02em; margin: 0 0 10px; color: #fff; }
  .p-card-d { color: rgba(255, 255, 255, .85); font-size: 15px; line-height: 1.55; margin: 0 0 16px; }
  .p-card-link { color: #fff; font-weight: 700; }

  /* VALUES */
  .p-values { display: grid; grid-template-columns: 0.8fr 1fr 1fr; gap: clamp(30px, 4vw, 60px); align-items: start; }
  .p-values-list { display: grid; gap: 4px; }
  .p-value { padding: 22px 0; border-bottom: 1px solid var(--p-line); cursor: pointer; transition: opacity .2s; }
