    50% { transform: scaleY(.93) scaleX(1.06) rotate(1.6deg); }
    75% { transform: scaleY(1.1) scaleX(.94) rotate(-1deg); }
  }
  @keyframes p-fire-flicker-i {
    0%, 100% { transform: scaleY(1) scaleX(1); }
    30% { transform: scaleY(1.22) scaleX(.88); }
    60% { transform: scaleY(.82) scaleX(1.12); }
  }
  .p-hero-date { display: flex; flex-direction: column; gap: 4px; margin: 0 0 34px; }
