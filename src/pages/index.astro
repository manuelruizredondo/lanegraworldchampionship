---
import Base from "@/layouts/Base.astro";
import EventSchema from "@/components/EventSchema.astro";
import { img } from "@/data/img.js";
import { ARTISTS_ES } from "@/data/artists.js";

// Propuesta de home — estructura tipo "Board" (Nixtio) adaptada a La Negra Dance Festival.
const pillars = [
  {
    tag: "Vienes a competir",
    title: "El Mundial",
    desc: "Inscríbete en el Campeonato Mundial de Salsa y Bachata y compite ante un jurado de élite internacional.",
    cta: "Ver la competición",
    href: "/competicion/",
    img: img("festival-negra-dance-home-1.jpg"),
  },
  {
    tag: "Vienes al festival",
    title: "El Festival",
    desc: "Talleres, fiestas, shows y hotel-spa frente al mar. Disfrútalo como público en la mejor compañía.",
    cta: "Ver el festival",
    href: "/festival/",
    img: img("lanegra-dance-festival-comepeticion-7.webp"),
  },
];

const features = [
  { title: "Los Artistas", desc: "Entra y descubre la constelación de estrellas de la salsa y la bachata que tendrás como maestros, jueces y compañeros de baile.", cta: "Ver artistas", href: "/artistas/", img: img("la-negra-dance-festival-galeria-2023-23.webp") },
  { title: "Workshops", desc: "Talleres y masterclass para tu nivel (básico, medio, avanzado o máster) en todos los estilos de salsa y bachata.", cta: "Ver workshops", href: "/talleres/", img: img("la-negra-dance-festival-galeria-2023-10.webp") },
  { title: "La fiesta", desc: "Dos salas de baile social hasta el amanecer: salsa y bachata en todas sus variantes con los mejores DJs.", cta: "Ver la fiesta", href: "/fiesta/", img: "/img/2025/03/lanegra-dance-festival-slide-2.webp" },
];

const values = [
  { t: "Nivel", d: "El único Mundial con coreografías 100% de estreno y un jurado de primer nivel.", img: img("lanegra-dance-festival-comepeticion-19.webp") },
  { t: "Comunidad", d: "Bailarines de más de 35 países unidos por la misma pasión.", img: img("festival-pasos-negra-dance-2.jpeg") },
  { t: "Emoción", d: "Shows, competición y fiestas que se viven una sola vez al año.", img: img("la-negra-dance-festival-fiesta-img-1.webp") },
];

const stats = [
  { n: "35+", l: "Países" },
  { n: "90+", l: "Artistas" },
  { n: "15", l: "Ediciones" },
  { n: "5.000+", l: "Bailarines" },
];

// Mapa de nacionalidades: [país, asistentes, x%, y%] (cifras editables)
// Mapa de nacionalidades: país, asistentes, posición (x/y %), altura de varilla (h px)
const mapPins = [
  { l: "España", n: 3200, x: 47.2, y: 25.5, h: 150, big: true },
  { l: "Portugal", n: 170, x: 45.7, y: 28, h: 56 },
  { l: "Francia", n: 180, x: 48.6, y: 21.5, h: 96 },
  { l: "Reino Unido", n: 230, x: 47.6, y: 18.5, h: 144 },
  { l: "Alemania", n: 260, x: 50.4, y: 21.5, h: 62 },
  { l: "Italia", n: 640, x: 51.6, y: 24.5, h: 114 },
  { l: "EE. UU.", n: 150, x: 21, y: 27.5, h: 110 },
  { l: "Canadá", n: 110, x: 25, y: 13.5, h: 66 },
  { l: "México", n: 210, x: 19, y: 37.5, h: 62 },
  { l: "Cuba", n: 130, x: 26.3, y: 39.5, h: 122 },
  { l: "R. Dominicana", n: 90, x: 28.6, y: 41.5, h: 58 },
  { l: "Venezuela", n: 110, x: 29.2, y: 47.5, h: 100 },
  { l: "Colombia", n: 240, x: 26.6, y: 51.5, h: 64 },
  { l: "Brasil", n: 140, x: 33.5, y: 60, h: 112 },
  { l: "Argentina", n: 95, x: 29.8, y: 74, h: 70 },
  { l: "Corea del Sur", n: 120, x: 80, y: 27, h: 62 },
  { l: "Japón", n: 140, x: 83.5, y: 25.5, h: 120 },
  { l: "Australia", n: 80, x: 85.5, y: 62, h: 84 },
];
const pinColors = ["#cc9933", "#14121a", "#a28243"];

// Llama animada del marquee: capa exterior + corazón, con parpadeo tipo fuego
const fire = `<svg class="p-fire" viewBox="0 0 24 24" aria-hidden="true"><path class="p-fire-o" fill="#ee7b1e" d="M13.5.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8C20 8.61 17.41 3.8 13.5.67z"/><path class="p-fire-i" fill="#ffc93c" d="M11.71 19c-1.78 0-3.22-1.4-3.22-3.14 0-1.62 1.05-2.76 2.81-3.12 1.77-.36 3.6-1.21 4.62-2.58.39 1.29.59 2.65.59 4.04 0 2.65-2.15 4.8-4.8 4.8z"/></svg>`;

// Nombre en dos líneas (nombre / apellidos) y en Título (evita nombres en MAYÚSCULAS del dataset)
const titleCase = (s) =>
  s.toLowerCase().replace(/(^|[\s\-])([a-záéíóúñü])/g, (m, p, c) => p + c.toUpperCase());
const artists = ARTISTS_ES.map((a) => {
  const parts = titleCase(a.name).split(" ");
  return { ...a, first: parts[0], last: parts.slice(1).join(" ") };
});
---

<Base
  title="La Negra Dance Festival — Mundial de Salsa y Bachata · Calpe 2026"
  description="La comunidad mundial de la salsa y la bachata. Talleres, shows, fiestas y el único Mundial con coreografías 100% de estreno. Calpe 2026."
  heroOverlay={true}
>
  <EventSchema lang="es" />
  <div class="prop">
    <!-- HERO (oscuro) -->
    <section class="p-hero">
      <video class="p-hero-video" autoplay muted loop playsinline src="https://res.cloudinary.com/u8ppc8of/video/upload/v1784369934/VIDEOWEB2025LANEGRACHAMPIONSCHIP_wpnfc8_itbv7q.mp4"></video>
      <div class="p-hero-inner">
        <p class="p-hero-date"><span>21–25 OCT 2026</span><span>Calpe · España</span></p>
        <div class="p-hero-cta">
          <a class="p-btn p-btn-light" href="/competicion/">Descubre el Mundial</a>
          <a class="p-btn p-btn-outline" href="/festival/">Descubre el festival</a>
        </div>
        <div class="p-hero-count" role="timer" aria-label="Cuenta atrás para el evento">
          <div class="p-hc"><span class="p-hc-n" data-d>0</span><span class="p-hc-l">Días</span></div>
          <div class="p-hc"><span class="p-hc-n" data-h>00</span><span class="p-hc-l">Horas</span></div>
          <div class="p-hc"><span class="p-hc-n" data-m>00</span><span class="p-hc-l">Min</span></div>
          <div class="p-hc"><span class="p-hc-n" data-s>00</span><span class="p-hc-l">Seg</span></div>
        </div>
      </div>
    </section>

    <!-- MARQUEE (frases grandes + fuego separador + skew con el scroll) -->
    <section class="p-marquee" aria-hidden="true" data-marquee>
      <div class="p-marquee-track">
        <div class="p-marquee-half">
          <span>Que se prenda fuego la tarima!!!</span><Fragment set:html={fire} />
          <span>Que se prenda fuego la tarima!!!</span><Fragment set:html={fire} />
          <span>Que se prenda fuego la tarima!!!</span><Fragment set:html={fire} />
        </div>
        <div class="p-marquee-half">
          <span>Que se prenda fuego la tarima!!!</span><Fragment set:html={fire} />
          <span>Que se prenda fuego la tarima!!!</span><Fragment set:html={fire} />
          <span>Que se prenda fuego la tarima!!!</span><Fragment set:html={fire} />
        </div>
      </div>
    </section>

    <!-- INTRO -->
    <section class="p-section">
      <div class="p-container p-intro">
        <h1 class="p-h2">Aprende con los mejores.<br />Compite contra los mejores.<br /><span class="p-accent">Baila con todos.</span></h1>
        <div class="p-intro-cols">
          <p>Desde 2010, La Negra Dance Festival reúne lo mejor de un congreso de baile y la espectacularidad de una competición mundial, con los mejores bailarines de más de 35 países en salsa y bachata.</p>
          <p>Talleres para todos los niveles, formación para profesionales, fiestas hasta el amanecer y el único Mundial con coreografías 100% de estreno, frente al mar en Calpe.</p>
        </div>
      </div>
    </section>

    <!-- STATEMENT 2 (comunidad) -->
    <section class="p-section p-center">
      <div class="p-container p-narrow">
        <div class="p-badge" aria-hidden="true">
          <img class="p-badge-ring" src="/img/logo-lanegra-ring.svg" alt="" />
          <img class="p-badge-face" src="/img/logo-lanegra-face.svg" alt="" />
        </div>
        <h2 class="p-h2">Una comunidad internacional de bailarines unida por la <span class="p-hl">salsa<svg class="p-hl-line" viewBox="0 0 500 150" preserveAspectRatio="none" aria-hidden="true"><path d="M8.1,146.2c0,0,240.6-55.6,479-13.8" pathLength="500"></path></svg></span> y la <span class="p-nb"><span class="p-hl p-hl-2">bachata<svg class="p-hl-line" viewBox="0 0 500 150" preserveAspectRatio="none" aria-hidden="true"><path d="M8.1,146.2c0,0,240.6-55.6,479-13.8" pathLength="500"></path></svg></span>,</span> entregada al nivel, la emoción y la celebración.</h2>
        <p class="p-lead p-quote">Un lugar donde, vengas del país que vengas, en cuanto pisas la pista estás entre los tuyos.</p>
      </div>
    </section>

    <!-- PILLARS -->
    <section class="p-section p-tight">
      <div class="p-container p-pillars">
        {pillars.map((p) => (
          <a class="p-pillar" href={p.href}>
            <div class="p-pillar-media"><img src={p.img} alt={p.title} loading="lazy" /></div>
            <div class="p-pillar-panel">
              <span class="p-pillar-tag">{p.tag}</span>
              <h3 class="p-pillar-t">{p.title}</h3>
              <p class="p-pillar-d">{p.desc}</p>
              <span class="p-btn p-btn-light p-btn-sm">{p.cta}</span>
            </div>
          </a>
        ))}
        <span class="p-pillars-plus" aria-hidden="true">+</span>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="p-section">
      <div class="p-container p-split">
        <h2 class="p-h2">Descúbrelo<br />todo.</h2>
        <p class="p-lead">Cuatro días de baile sin parar: artistas de leyenda, talleres para tu nivel y fiestas que no olvidarás.</p>
      </div>
      <div class="p-container p-cards">
        {features.map((f) => (
          <a class="p-card" href={f.href}>
            <div class="p-card-media"><img src={f.img} alt={f.title} loading="lazy" /></div>
            <div class="p-card-panel">
              <h3 class="p-card-t">{f.title}</h3>
              <p class="p-card-d">{f.desc}</p>
              <span class="p-card-link">{f.cta} →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- STATEMENT 3 -->
    <section class="p-section p-center">
      <div class="p-container p-narrow">
        <h2 class="p-display">Crecemos<br />bailando juntos.</h2>
        <p class="p-lead">Aquí no vienes a un evento: entras en una comunidad que se reencuentra cada año frente al Mediterráneo.</p>
        <div class="p-cta-row">
          <a class="p-btn p-btn-dark" href="/tu-pase/">Comprar pase</a>
          <div class="p-btn-off-wrap">
            <span class="p-btn p-btn-off" aria-disabled="true" title="Las inscripciones al Mundial 2026 están cerradas">Inscríbete al Mundial*</span>
            <p class="p-cta-note">*Inscripciones para competidores cerradas.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- VALUES -->
    <section class="p-section p-gray">
      <div class="p-container p-values">
        <div class="p-values-head">
          <p class="p-eyebrow">Nuestros valores</p>
          <h2 class="p-h2">Lo que nos<br />hace únicos.</h2>
        </div>
        <div class="p-values-list">
          {values.map((v, i) => (
            <div class={i === 0 ? "p-value active" : "p-value"} data-img={v.img} role="button" tabindex="0">
              <h3 class="p-value-t">{v.t}</h3>
              <p class="p-value-d">{v.d}</p>
            </div>
          ))}
        </div>
        <div class="p-values-media"><img src={values[0].img} alt="La Negra Dance Festival" loading="lazy" /></div>
      </div>
    </section>

    <!-- STATS -->
    <section class="p-stats">
      <div class="p-container p-stats-row">
        {stats.map((s) => (
          <div class="p-stat"><span class="p-stat-n">{s.n}</span><span class="p-stat-l">{s.l}</span></div>
        ))}
      </div>
    </section>

    <!-- PHOTO BAND (parallax interior + mensaje de internacionalidad) -->
    <section class="p-band">
      <div class="p-band-media">
        <img src={img("la-negra-dance-festival-fiesta-img-12.webp")} alt="" loading="lazy" />
      </div>
      <div class="p-band-content">
        <p class="p-band-eyebrow">35+ países · 5 continentes</p>
        <h2 class="p-band-title">El mundo entero<br />baila en Calpe.</h2>
        <p class="p-band-sub">Distintos idiomas, un mismo lenguaje. Cada octubre, bailarines de todo el planeta se dan cita frente al Mediterráneo.</p>
      </div>
    </section>

    <!-- WORLD MAP (nacionalidades) -->
    <section class="p-map-sec">
      <div class="p-container p-center p-map-head">
        <p class="p-eyebrow">Nacionalidades</p>
        <h2 class="p-h2">De todos los rincones<br />del planeta.</h2>
      </div>
      <div class="p-map" data-map>
        <div class="p-map-plane">
          <img class="p-map-img" src="/img/world-map-dots.svg" alt="Mapa de nacionalidades de los asistentes" width="2370" height="1104" loading="lazy" />
          {mapPins.map((p, i) => (
            <div
              class={p.big ? "p-pin p-pin-big" : "p-pin"}
              data-x={p.x}
              data-y={p.y}
              style={`left:${p.x}%; top:${p.y}%; --pin-d:${i * 80}ms; --stem:${p.h}px; --dot:${Math.round(8 + Math.min(14, Math.sqrt(p.n) / 4))}px; --pin-c:${p.big ? "#cc9933" : pinColors[i % 3]}`}
            >
              <span class="p-pin-bubble"><span class="p-pin-n" data-count={p.n}>{String(p.n).replace(/\B(?=(\d{3})+(?!\d))/g, ".")}</span></span>
              <span class="p-pin-l">{p.l}</span>
              <span class="p-pin-stem"></span>
              <span class="p-pin-hit"></span>
            </div>
          ))}
        </div>
      </div>
      {/* Móvil: rejilla de cifras siempre visible (sin hover, sin solapes) */}
      <div class="p-container p-map-grid">
        {[...mapPins].sort((a, b) => b.n - a.n).map((p) => (
          <div class="p-map-chip">
            <span class="p-map-chip-n">{String(p.n).replace(/\B(?=(\d{3})+(?!\d))/g, ".")}</span>
            <span class="p-map-chip-l">{p.l}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ARTISTS -->
    <section class="p-section p-center">
      <div class="p-container">
        <h2 class="p-display">Nuestros artistas.</h2>
        <p class="p-lead p-narrow">Las estrellas internacionales de la salsa y la bachata que harán arder la tarima.</p>
      </div>
      <div class="p-artists" data-artists-slider>
        <div class="p-artists-track">
          <div class="p-artists-set">
            {artists.map((a) => (
          <div class="p-artist">
            <div class="p-artist-img"><img src={img(a.img)} alt={a.name} loading="lazy" /></div>
            <span class="p-artist-n"><span>{a.first}</span>{a.last && <span>{a.last}</span>}</span>
            <span class="p-artist-c">{a.country}</span>
          </div>
        ))}
          </div>
          <div class="p-artists-set" aria-hidden="true">
            {artists.map((a) => (
          <div class="p-artist">
            <div class="p-artist-img"><img src={img(a.img)} alt={a.name} loading="lazy" /></div>
            <span class="p-artist-n"><span>{a.first}</span>{a.last && <span>{a.last}</span>}</span>
            <span class="p-artist-c">{a.country}</span>
          </div>
        ))}
          </div>
        </div>
      </div>
      <div class="p-container">
        <a class="p-btn p-btn-dark" href="/artistas/">Ver todos los artistas</a>
      </div>
    </section>

    <!-- FINAL CTA (oscuro) -->
    <section class="p-final">
      <div class="p-container p-final-inner">
        <h2 class="p-display p-white">Nos vemos en<br />Calpe 2026.</h2>
        <p class="p-lead p-white-70">Reserva tu Full Pass para La Negra Dance Festival y vive el Mundial de Salsa y Bachata.</p>
        <div class="p-hero-cta">
          <a class="p-btn p-btn-light" href="/tu-pase/">Compra tu pase</a>
          <a class="p-btn p-btn-outline" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Reserva hotel</a>
        </div>
      </div>
    </section>
  </div>
  <script>
    import "@/scripts/home.js";
  </script>
</Base>
