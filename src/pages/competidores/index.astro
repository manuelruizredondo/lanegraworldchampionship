---
import Base from "@/layouts/Base.astro";
import Lightbox from "@/components/Lightbox.astro";
import SubNav from "@/components/SubNav.astro";

const subNav = [
  { label: "Inscripción", href: "/competicion/#inscripcion" },
  { label: "Bases", href: "/competicion/#bases" },
  { label: "Pase competición", href: "/competicion/#fullpass" },
  { label: "Competidores", href: "/competidores/", active: true },
  { label: "Ganadores 2025", href: "/ganadores-2025/" },
  { label: "Ganadores 2024", href: "/ganadores/" },
];
import { img } from "@/data/img.js";

const categories = [
  { label: "Dúos Masculinos salsa", img: "DUOS-MASCULINO-SALSA-2025.jpeg" },
  { label: "Dúos Femeninos Salsa", img: "DUOS-FEMENINO-SALSA-2025.jpeg" },
  { label: "Parejas Salsa", img: "PAREJAS-SALSA-2025.jpeg" },
  { label: "Equipos Salsa", img: "GRUPOS-SALSA-2025.jpeg" },
  { label: "Solista femenino salsa (semi)", img: "FINAL-SOLISTAS-FEMENINO-SALSA.jpeg" },
  { label: "Solista femenino salsa", img: "ELIMINATORIA-SOLISTAS-FEMENINO-SALSA_1.jpeg" },
  { label: "Solista masculino salsa (semi)", img: "semifinal-y-final-chicos-2025.jpeg" },
  { label: "Solista masculino salsa", img: "ELIMINATORIA-SOLISTAS-MASCULINO-SALSA-2025.jpeg" },
  { label: "Solista Femenino Bachata", img: "SOLISTA-FEM-BACHATA-2025.jpeg" },
  { label: "Solista Masculino Bachata", img: "SOLISTA-MAS-BACHATA-2025.jpeg" },
  { label: "Dúos Bachata", img: "DUOS-BACHATA-2025.jpeg" },
  { label: "Parejas Bachata", img: "PAREJAS-BACHATA-2025.jpeg" },
  { label: "Equipos Bachata", img: "equipo-bahatca-final-festival-la-negra-2.jpg" },
];

const gallery = [
  "lanegra-dance-festival-home-1-7.webp",
  "lanegra-dance-festival-home-3-2.webp",
  "lanegra-dance-festival-home-3-10.webp",
  "lanegra-dance-festival-home-3-13.webp",
  "lanegra-dance-festival-home-3-14.webp",
  "lanegra-dance-festival-home-3-22.webp",
  "lanegra-dance-festival-home-3-23.webp",
  "lanegra-dance-festival-home-3-26.webp",
];
---

<Base title="Competidores" description="Los competidores del Mundial de Salsa y Bachata de La Negra Dance Festival." lang="es">
  <SubNav items={subNav} label="Secciones de la competición" />

  <div class="prop">
    <!-- INTRO + GRID -->
    <section class="p-section p-center competitors">
      <div class="p-container">
        <p class="p-eyebrow">Salsa y Bachata</p>
        <h1 class="p-display">Los competidores de 2025</h1>
        <div class="cat-grid">
          {categories.map((c) => (
            <article class="cat-card">
              <div class="cat-img"><img src={img(c.img)} alt={c.label} loading="lazy" data-lightbox role="button" tabindex="0" /></div>
              <h3 class="cat-label">{c.label}</h3>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- GALLERY -->
    <section class="p-section p-gray">
      <div class="p-container gallery-grid">
        {gallery.map((src) => (
          <div class="gallery-item"><img src={img(src)} alt="" loading="lazy" /></div>
        ))}
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="p-section p-center final-cta">
      <div class="p-container">
        <p class="p-eyebrow">Disfruta bailando</p>
        <h2 class="p-h2">Tu festival de baile latino</h2>
        <p class="p-lead p-narrow final-text">Tres días de salsa y bachata, para los enamorados-as del baile latino. Puro fuego en la pista: artistas, concursantes, talleres, fiesta y mucho ritmo. No te lo puedes perder, del 21 al 25 de octubre del 2026 en Calpe (España).</p>
      </div>
      <div class="p-container cta-box">
        <div class="cta-img"><img src={img("lanegra-dance-festival-home-1-7.webp")} alt="" loading="lazy" /></div>
        <div class="cta-content">
          <p>Un festival y concurso de baile a nivel internacional de Salsa y Bachata.</p>
          <p class="cta-claim">¡Ven, baila y disfruta!</p>
          <div class="cta-buttons">
            <a class="p-btn p-btn-light" href="/tu-pase/">Comprar Pase</a>
            <span class="reg-closed"><span class="p-btn p-btn-off" aria-disabled="true" role="button" title="Inscripciones cerradas">Inscríbete al Mundial</span><span class="reg-note">Inscripciones cerradas: el plazo de inscripción al Mundial 2026 ha finalizado.</span></span>
          </div>
        </div>
      </div>
    </section>
  </div>
  <Lightbox />
</Base>

<style>
  /* CATEGORY GRID */
  .competitors .p-display { margin-bottom: 48px; }
  .cat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px 30px; margin-top: 8px; }
  .cat-card { text-align: center; }
  .cat-img { border-radius: 18px; overflow: hidden; aspect-ratio: 3/4; margin-bottom: 18px; background: var(--p-card); }
  .cat-img img { width: 100%; height: 100%; object-fit: cover; cursor: zoom-in; transition: transform .4s ease; }
  .cat-card:hover .cat-img img { transform: scale(1.04); }
  .cat-label {
    font-weight: 700; text-transform: uppercase;
    font-size: 15px; letter-spacing: .06em; margin: 0; color: var(--p-ink);
  }

  /* GALLERY */
  .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .gallery-item { border-radius: 18px; overflow: hidden; aspect-ratio: 1/1; background: var(--p-card); }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; }

  /* FINAL CTA */
  .final-text { margin-bottom: 44px; }
  .cta-box { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; border-radius: var(--p-radius); overflow: hidden; margin-top: 8px; }
  .cta-img img { width: 100%; height: 100%; object-fit: cover; }
  .cta-content {
    background: radial-gradient(120% 120% at 50% 0%, #211c33 0%, #0f0b1e 65%);
    color: #fff; padding: clamp(36px, 5vw, 56px) clamp(30px, 4vw, 48px);
    display: flex; flex-direction: column; justify-content: center; text-align: left;
  }
  .cta-content p { color: rgba(255, 255, 255, .82); line-height: 1.6; margin: 0; }
  .cta-claim { font-weight: 700; letter-spacing: -.02em; color: #fff !important; font-size: clamp(24px, 3vw, 30px); margin: 10px 0 26px !important; }
  .cta-buttons { display: flex; gap: 14px; flex-wrap: wrap; align-items: flex-start; }
  .reg-closed { display: flex; flex-direction: column; align-items: flex-start; gap: 8px; }
  .reg-closed .p-btn-off { text-decoration: line-through; text-decoration-thickness: 2px; cursor: not-allowed; opacity: .5; background: transparent; color: #fff; border: 1.5px solid rgba(255, 255, 255, .4); }
  .reg-closed .p-btn-off:hover { transform: none; }
  .reg-note { font-size: 12px; color: rgba(255, 255, 255, .6); text-align: left; max-width: 260px; line-height: 1.4; }

  /* responsive */
  @media (max-width: 900px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .cta-box { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .cat-grid { grid-template-columns: 1fr; }
  }
</style>
