---
import Base from "@/layouts/Base.astro";
import { img } from "@/data/img.js";

const categories = [
  {
    title: "Female SALSA soloist",
    image: "solista-femenino-salsa-2024-1.jpg",
    podium: [
      "1st place: Yaiza Melero (Spain)",
      "2nd place: Yolieth Barragán (USA-Mexico)",
      "3rd place: Eliana Maradei (Italy)",
    ],
  },
  {
    title: "Male salsa soloist",
    image: "solista-masculino-salsa-2024.jpg",
    podium: [
      "1st place: Tony El Haber (Italy)",
      "2nd place: Henry Pinzón (Colombia)",
      "3rd place: Yenier Jiménez (Costa Rica)",
    ],
  },
  {
    title: "Female bachata soloist",
    image: "solista-femenino-bachata-2024.jpg",
    podium: [
      "1st place: Paula Lozano (Spain)",
      "2nd place: Elena Khamsi (Spain)",
      "3rd place: Reyes Lemos (Spain)",
    ],
  },
  {
    title: "Male bachata soloist",
    image: "solista-masculino-bachata-2024.jpg",
    podium: [
      "1st place: Juan Camilo Rojas (Colombia)",
      "2nd place: Andrés Murillo (Colombia)",
      "3rd place: Dmitry Oleynikov (Russia)",
    ],
  },
  {
    title: "Salsa couples",
    image: "parejas-salsa-2024.jpg",
    podium: [
      "1st place: Tony El Haber & Sheida (Italy)",
      "2nd place: Adrián Oliver and Carmen Sanz (Spain)",
      "3rd place: Nicolò Cervino and Beatrice Pagliarin (Italy)",
    ],
  },
  {
    title: "Female Salsa Duets",
    image: "duo-salsa-famenino-2024.jpg",
    podium: [
      "1st place: Federica and Miriam (Italy)",
      "2nd place: Alicia and Vesna (Switzerland)",
      "3rd place: Ivonne and Zenaida (Spain)",
    ],
  },
  {
    title: "Bachata Couples",
    image: "parejas-bachata-2024.jpg",
    podium: [
      "1st place: Micaela and Francisco (Argentina)",
      "2nd place: Cristian and Shery (Mexico)",
      "3rd place: Berra and Nazareth (Spain)",
    ],
  },
  {
    title: "Salsa Groups",
    image: "grupo-salsa-2024.jpg",
    podium: [
      "1st place: Mambo a lo Ayala by: The Ayala Brothers (USA)",
      "2nd place: Rincón Salsero by Yénier Jiménez (Costa Rica)",
      "3rd place: Alma Dance Company by Alessandro Massaro (Italy)",
    ],
  },
  {
    title: "Bachata Groups",
    image: "grupo-bachata-2024.jpg",
    podium: [
      "1st place: Latin Attitude by Filipa y Pedro (Portugal)",
      "2nd place: Impulso Dominicano by Leif Candela (Spain)",
      "3rd place: Mangu Dance Company by Jorge El Bomba (Venezuela-Spain)",
    ],
  },
];

const gallery = [
  "lanegra-dance-festival-home-1-7.webp",
  "lanegra-dance-festival-home-3-2.webp",
  "lanegra-dance-festival-home-3-10.webp",
  "lanegra-dance-festival-home-3-13.webp",
  "lanegra-dance-festival-home-3-14.webp",
  "lanegra-dance-festival-home-3-22.webp",
  "lanegra-dance-festival-home-3-23.webp",
  "lanegra-dance-festival-home-3-26.webp",
];
---

<Base title="Winners 2024" description="The winners of the Salsa and Bachata World Cup at La Negra World Championship 2024." lang="en">
  <!-- INTRO -->
  <section class="section winners-intro text-center">
    <div class="container">
      <p class="eyebrow dark">Salsa and Bachata</p>
      <h1 class="script-title">The winners of 2024</h1>
    </div>
  </section>

  <!-- WINNERS GRID -->
  <section class="section-tight winners">
    <div class="container winners-grid">
      {categories.map((c) => (
        <article class="winner-card">
          <div class="winner-img"><img src={img(c.image)} alt={c.title} loading="lazy" /></div>
          <h2 class="winner-title">{c.title}</h2>
          <ol class="podium">
            {c.podium.map((p, i) => <li class={`pos-${i + 1}`}>{p}</li>)}
          </ol>
        </article>
      ))}
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section-tight">
    <div class="container gallery-grid">
      {gallery.map((src) => <div class="gallery-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section final-cta text-center">
    <div class="container">
      <p class="eyebrow dark">Enjoy dancing</p>
      <h2 class="script-title">Your Latin dance festival</h2>
      <p class="final-text">Three days of salsa and bachata, for those in love with Latin dance. Pure fire on the dance floor: artists, contestants, workshops, parties and lots of rhythm. Not to be missed, from October 21 to 25, 2026 in Calpe (Spain).</p>
    </div>
    <div class="container cta-box">
      <div class="cta-content">
        <p>An international Salsa and Bachata festival and dance competition.</p>
        <p class="cta-claim">Come, dance and enjoy!</p>
        <div class="cta-buttons">
          <a class="btn btn-light" href="/en/your-pass/">Buy Pass</a>
          <a class="btn btn-solid" href="/en/competition/#inscripcion">Register for the World Cup</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--navy); }

  .winners-intro { padding-bottom: 30px; }

  /* WINNERS GRID */
  .winners-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px 32px; }
  .winner-card { text-align: center; }
  .winner-img { border-radius: 12px; overflow: hidden; aspect-ratio: 4/3; margin-bottom: 18px; }
  .winner-img img { width: 100%; height: 100%; object-fit: cover; }
  .winner-title {
    font-family: var(--font-body); font-weight: 700; text-transform: uppercase;
    font-size: 20px; letter-spacing: .03em; color: var(--gold); margin: 0 0 14px;
  }
  .podium { list-style: none; margin: 0; padding: 0; }
  .podium li { font-size: 16px; padding: 6px 0; border-bottom: 1px solid rgba(0,0,0,.07); }
  .podium li:last-child { border-bottom: 0; }
  .podium .pos-1 { font-weight: 700; color: var(--navy); }

  /* GALLERY */
  .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .gallery-item { border-radius: 10px; overflow: hidden; aspect-ratio: 1/1; }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; }

  /* FINAL CTA */
  .final-text { max-width: 820px; margin: 0 auto 36px; }
  .cta-box { display: grid; border-radius: 16px; overflow: hidden; }
  .cta-content { background: linear-gradient(135deg,#14102b,#2a1f57); color: #fff; padding: 48px 44px; text-align: center; }
  .cta-claim { font-family: var(--font-script); color: var(--gold); font-size: 34px; margin: 6px 0 22px; }
  .cta-buttons { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }

  @media (max-width: 900px) {
    .winners-grid { grid-template-columns: 1fr; gap: 44px; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
