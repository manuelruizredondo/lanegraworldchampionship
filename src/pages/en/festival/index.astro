---
import Base from "@/layouts/Base.astro";
import SubNav from "@/components/SubNav.astro";
import { img } from "@/data/img.js";

const anchorNav = [
  { label: "FESTIVAL", href: "#info" },
  { label: "ARTISTS", href: "#artists" },
  { label: "WORKSHOPS", href: "#workshops" },
  { label: "FULL PASS", href: "#fullpass" },
  { label: "HOTEL", href: "#hotel" },
  { label: "CONTACT", href: "#contact" },
];

const introGallery = [
  "la-negra-dance-festival-festival-img-18.webp",
  "la-negra-dance-festival-festival-img-14.webp",
  "la-negra-dance-festival-festival-img-12.webp",
  "la-negra-dance-festival-festival-img-21.webp",
  "la-negra-dance-festival-fiesta-img-.webp",
  "la-negra-dance-festival-festival-img-1.webp",
];

const artists = [
  { name: "Tito Ortos", country: "Salsa | Puerto Rico", img: "la-negra-festival-tito-ortos.webp" },
  { name: "Bersy Cortez", country: "Salsa | Venezuela", img: "la-negra-festival-bersy-cortez.webp" },
  { name: "Maykel Fonts", country: "Salsa | Cuba", img: "la-negra-festival-maykel-fonts.webp" },
  { name: "Anita Santos Rubín", country: "Salsa | Brazil", img: "la-negra-festival-anita-santos.webp" },
  { name: "Yoyo Flow", country: "Salsa | Cuba", img: "yoyo-flow.jpg" },
  { name: "Marco Ferrigno", country: "Salsa | Italy", img: "marco-ferregno.jpg" },
  { name: "Dani J", country: "In concert | Spain", img: "dani-J-239x300.webp" },
  { name: "Korke and Judith", country: "Bachata | Spain", img: "korke-judith-bachata-la-negra-dance-festival.jpeg" },
  { name: "Gaby and Estefy", country: "Bachata | Dominican Republic and Spain", img: "festival-evelin-la-negra-Gabi-Estefy.jpg" },
  { name: "Samy el Mágico", country: "Bachata | Dominican Republic", img: "samy-el-magico-festival-la-negra-dance.jpg" },
  { name: "Darío and Sara", country: "Bachata | Spain", img: "dario-y-sara-240x300.webp" },
  { name: "Evelyn La Negra", country: "Bachata | Venezuela", img: "evelyn-la-negra-bachata-festival-pasos-libres_1.jpg" },
];

const talleresGallery = [
  "la-negra-dance-festival-galeria-2023-23.webp",
  "la-negra-dance-festival-galeria-2023-28.webp",
];

const hotelGallery = [
  "la-negra-dance-festival-festival-img-19.webp",
  "la-negra-dance-festival-festival-img-16.webp",
  "la-negra-dance-festival-festival-img-2.webp",
  "la-negra-dance-festival-festival-img-.webp",
  "la-negra-dance-festival-festival-img-8.webp",
  "la-negra-dance-festival-festival-img-5.webp",
];

const fiestaGallery = [
  "la-negra-dance-festival-festival-img-1.webp",
  "lanegra-dance-festival-comepeticion-2.webp",
  "la-negra-dance-festival-fiesta-img-12.webp",
  "la-negra-dance-festival-fiesta-img-7.webp",
  "la-negra-dance-festival-fiesta-img-10.webp",
];
---

<Base title="Festival" description="Salsa and bachata festival with workshops, social dancing and World Championship. From October 21 to 25, 2026 in Calpe (Spain)." lang="en">
  <!-- ANCHOR NAV -->
  <SubNav items={anchorNav} label="Festival sections" />

  <!-- INTRO -->
  <section id="info" class="section intro text-center">
    <div class="container">
      <p class="eyebrow dark">Salsa – Bachata</p>
      <h1 class="script-title">La Negra Dance Festival</h1>
      <h2 class="intro-sub">Salsa and bachata festival with workshops, social dancing and World Championship.</h2>
      <h2 class="intro-date">From October 21 to 25, 2026 in Calpe (Spain)</h2>
      <div class="intro-info">
        <p>
          <strong>LOCATION:</strong> Calpe, Alicante (Spain) – Host hotel AR Diamante Beach 4* superior.
          <a href="https://maps.app.goo.gl/1Upi3tNxMANnCbZ87" target="_blank" rel="noopener">See map</a>
        </p>
        <p>
          <strong>NEAREST AIRPORTS</strong> – Alicante Airport (50 min from the host hotel) – Valencia Airport (1h and 20min from the hotel)
        </p>
      </div>
      <a class="btn btn-solid" href="#fullpass">Buy Pass</a>
    </div>
    <div class="container intro-gallery">
      {introGallery.map((src) => <div class="g-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
    </div>
  </section>

  <!-- ARTISTS -->
  <section id="artists" class="section artists text-center">
    <div class="container">
      <p class="eyebrow dark">Salsa – Bachata</p>
      <h2 class="script-title">Our guest artists</h2>
      <p class="artists-intro">Every year we bring renowned artists and dancers from different corners of the world. Elite dancers, workshops, beach, pools, parties and world-renowned competitors from more than 20 countries come together every year for this great event.</p>
      <div class="artists-grid">
        {artists.map((a) => (
          <article class="artist">
            <div class="artist-img"><img src={img(a.img)} alt={a.name} loading="lazy" /></div>
            <h3 class="artist-name">{a.name}</h3>
            <p class="artist-country">{a.country}</p>
          </article>
        ))}
      </div>
      <a class="btn btn-outline" href="/en/artists/">View all</a>
    </div>
  </section>

  <!-- WORKSHOPS -->
  <section id="workshops" class="section talleres">
    <div class="container talleres-grid">
      <div class="talleres-imgs">
        {talleresGallery.map((src) => <div class="g-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
      </div>
      <div class="talleres-text">
        <p class="eyebrow dark">Salsa – Bachata</p>
        <h2 class="script-title">Workshops to enjoy</h2>
        <p>Every year we bring renowned artists and dancers from different corners of the world. From amateurs to competitors and professionals can enjoy basic, intermediate and advanced level workshops in disciplines such as: Cuban Salsa, On2, On2, Bachata Sensual, Traditional, Fusion and the latest trends. Masterclass only for professionals.</p>
        <a class="btn btn-outline" href="/en/workshops/">View all workshops</a>
      </div>
    </div>
  </section>

  <!-- FULL PASS -->
  <section id="fullpass" class="section fullpass text-center">
    <div class="container">
      <p class="eyebrow dark">Full Pass</p>
      <h2 class="script-title">See you at La Negra</h2>
      <p class="fullpass-note">Ticket sales managed through <a href="https://www.goandance.com/es/evento/8885/la-negra-dance-festival-2026-xv-campeonato-mundial-de-pasos-libres-la-negra-salsa-v-campeonato-mundial-de-pasos-libres-la-negra-bachata" target="_blank" rel="noopener">go&amp;dance</a>.</p>
      <div class="fullpass-widget">
        <iframe
          src="https://www.goandance.com/en/event-tickets/106ef4d5-c8be-4fce-8660-ea6854726bff?referer=https%3A%2F%2Fcampeonatopasoslibres.com%2Fcompeticion%2F"
          title="Buy Full Pass — go&dance"
          loading="lazy"
        ></iframe>
      </div>
      <p class="gd-credit">Powered by <a href="https://www.goandance.com/es/evento/8885/la-negra-dance-festival-2026-xv-campeonato-mundial-de-pasos-libres-la-negra-salsa-v-campeonato-mundial-de-pasos-libres-la-negra-bachata" target="_blank" rel="noopener">go&amp;dance</a></p>
      <a class="gd-link" href="https://www.goandance.com/es/evento/8885/la-negra-dance-festival-2026-xv-campeonato-mundial-de-pasos-libres-la-negra-salsa-v-campeonato-mundial-de-pasos-libres-la-negra-bachata" target="_blank" rel="noopener">Go to the tickets page ↗</a>
    </div>
  </section>

  <!-- HOTEL -->
  <section id="hotel" class="section hotel">
    <div class="container hotel-head text-center">
      <p class="eyebrow dark">AR Diamante Beach</p>
      <h2 class="script-title">Book your Hotel</h2>
      <h3 class="hotel-sub">La Negra Dance Festival Venue</h3>
    </div>
    <div class="container hotel-grid">
      <div class="hotel-text">
        <p>Enjoy a unique stay in AR Diamante Beach, a reference in the Costa Blanca with spectacular views of the sea and the Peñón de Ifach. Our elegant rooms combine comfort and style to make every awakening special.</p>
        <p>Relax in our three pools, including a children’s pool in an exclusive setting with palm trees, sun loungers, cocktails and entertainment. Beach or pool? Don’t choose, enjoy it all, just a few steps from the sea.</p>
        <p>In case of problems with the reservation please contact: <a href="mailto:reservas@galaxtur.com">reservas@galaxtur.com</a></p>
        <p class="hotel-warning">IMPORTANT NOTE: EXCLUSIVE RATE FOR EVENT ATTENDEES. IN CASE OF IDENTIFYING THE CONTRARY AND NOT PRESENTING THE FULLPASS AT CHECK-IN, THE RESERVATION WILL BE CANCELLED.</p>
        <a class="btn btn-solid" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Book your hotel</a>
      </div>
      <div class="hotel-map">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3115.9332867988783!2d0.07065367592495361!3d38.65041427177794!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x129dfe00f86d3eef%3A0x8f672c62926e85bf!2sAR%20Diamante%20Beach!5e0!3m2!1ses!2ses!4v1742755084006!5m2!1ses!2ses"
          title="AR Diamante Beach map"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
    <div class="container transfers">
      <h2 class="script-title transfers-title">How to get to the hotel from the airport or train station?</h2>
      <div class="transfers-grid">
        <div class="transfer-card">
          <h4>Alicante – Calpe airport transfers</h4>
          <p>Arrival or take-off between 7:00h and 23:55h: Price of shared transfer 23.50 € per person one way</p>
        </div>
        <div class="transfer-card">
          <h4>Alicante – Calpe train station transfers</h4>
          <p>Arrival or departure between 9:00 a.m. and 8:15 p.m.: Shared transfer price 18 € per person per way</p>
        </div>
      </div>
      <p class="transfers-note">Once the information is received, the reservation will be made and a confirmation and a link for the payment of the transfer will be sent.</p>
      <div class="text-center">
        <a class="btn btn-outline" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Book your hotel</a>
      </div>
    </div>
    <div class="container hotel-gallery">
      {hotelGallery.map((src) => <div class="g-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section contact">
    <div class="container contact-head text-center">
      <p class="eyebrow dark">La Negra Dance Festival</p>
      <h2 class="script-title">If you have any questions, please fill in the form</h2>
    </div>
    <div class="container contact-grid">
      <form class="contact-form" method="post" action="#">
        <div class="field-row">
          <input type="text" name="name" placeholder="First name" required />
          <input type="text" name="surname" placeholder="Last name" required />
        </div>
        <div class="field-row">
          <input type="email" name="email" placeholder="Email" required />
          <input type="tel" name="phone" placeholder="Phone" />
        </div>
        <input type="text" name="subject" placeholder="Subject" />
        <textarea name="message" rows="6" placeholder="Message" required></textarea>
        <label class="privacy">
          <input type="checkbox" name="privacy" required />
          <span>I have read and accept <a href="/en/privacy-policy/">the privacy policy and electronic mailings.</a></span>
        </label>
        <button class="btn btn-solid" type="submit">Send</button>
      </form>
      <div class="contact-imgs">
        {fiestaGallery.map((src) => <div class="g-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
      </div>
    </div>
  </section>

  <!-- FIESTA CTA -->
  <section class="fiesta-cta">
    <div class="container fiesta-inner">
      <p class="eyebrow">At night…</p>
      <h2 class="script-title white">Enjoy the party !</h2>
      <p>After an intense day of workshops, learning and rest… we have a party! The workshops and the competition are just the beginning. Get ready for nights of pure energy in our theme parties, where the best atmosphere, the best dancers and the best music will make you live an unforgettable experience.</p>
      <a class="btn btn-light" href="/en/fiesta/">Learn more</a>
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--gold); }

  /* ANCHOR NAV */
  .anchor-nav {
    position: sticky; top: 0; z-index: 20;
    background: var(--navy); padding: 10px 0;
  }
  .anchor-inner { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
  .anchor-nav a {
    color: #fff; text-decoration: none; font-family: var(--font-body);
    text-transform: uppercase; letter-spacing: .04em; font-size: 15px;
    padding: 8px 18px; border-radius: 999px; transition: background .2s, color .2s;
  }
  .anchor-nav a:hover { background: var(--gold); color: #fff; }

  /* INTRO */
  .intro-sub { font-family: var(--font-body); font-weight: 300; font-size: clamp(20px,3vw,26px); color: var(--navy); margin: 0 auto 10px; max-width: 820px; }
  .intro-date { font-family: var(--font-body); font-weight: 400; font-size: clamp(18px,2.4vw,22px); color: var(--gold-dark); margin: 0 0 24px; }
  .intro-info { max-width: 760px; margin: 0 auto 26px; }
  .intro-info p { font-size: 16px; }
  .intro-info a { color: var(--gold-dark); font-weight: 400; }

  .intro-gallery, .hotel-gallery {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 40px;
  }
  .g-item { border-radius: 10px; overflow: hidden; aspect-ratio: 4/3; }
  .g-item img { width: 100%; height: 100%; object-fit: cover; }

  /* ARTISTS */
  .artists { background: var(--cream); }
  .artists-intro { max-width: 760px; margin: 0 auto 36px; }
  .artists-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px 24px; margin-bottom: 36px; }
  .artist-img { border-radius: 10px; overflow: hidden; aspect-ratio: 3/4; margin-bottom: 14px; }
  .artist-img img { width: 100%; height: 100%; object-fit: cover; }
  .artist-name { font-family: var(--font-body); font-weight: 700; text-transform: uppercase; font-size: 17px; letter-spacing: .03em; margin: 0 0 4px; color: var(--navy); }
  .artist-country { color: var(--gold-dark); font-size: 15px; margin: 0; }

  /* WORKSHOPS */
  .talleres-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 44px; align-items: center; }
  .talleres-imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .talleres-imgs .g-item { aspect-ratio: 3/4; }
  .talleres-text p { font-size: 16px; margin-bottom: 22px; }

  /* FULL PASS */
  .fullpass { background: var(--cream); }
  .fullpass-note { max-width: 640px; margin: 0 auto 28px; }
  .fullpass-note a { color: var(--gold-dark); font-weight: 400; }
  .fullpass-widget {
    max-width: 100%; margin: 0 auto; border-radius: 14px; overflow: hidden;
    box-shadow: 0 14px 40px rgba(15,11,30,.14);
  }
  .fullpass-widget iframe { width: 100%; height: 430px; border: 0; display: block; }

  /* HOTEL */
  .hotel-sub { font-family: var(--font-body); font-weight: 400; color: var(--navy); font-size: 22px; margin: 0 0 8px; }
  .hotel-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 44px; align-items: start; margin-top: 20px; }
  .hotel-text p { font-size: 16px; }
  .hotel-text p a { color: var(--gold-dark); font-weight: 400; }
  .hotel-warning { font-weight: 400; color: var(--navy); background: var(--gold-light); padding: 14px 18px; border-radius: 8px; font-size: 14px; }
  .hotel-map iframe { width: 100%; height: 420px; border: 0; border-radius: 12px; display: block; }

  .transfers { margin-top: 56px; }
  .transfers-title { font-size: clamp(26px,4vw,38px); text-align: center; margin-bottom: 28px; }
  .transfers-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 18px; }
  .transfer-card { background: var(--cream); border-radius: 12px; padding: 26px 28px; }
  .transfer-card h4 { font-family: var(--font-body); font-weight: 700; text-transform: uppercase; color: var(--navy); margin: 0 0 10px; font-size: 17px; }
  .transfer-card p { margin: 0; font-size: 15px; }
  .transfers-note { text-align: center; max-width: 720px; margin: 0 auto 24px; font-size: 15px; }

  /* CONTACT */
  .contact { background: var(--cream); }
  .contact-head { margin-bottom: 36px; }
  .contact-grid { display: grid; grid-template-columns: 1.1fr .9fr; gap: 44px; align-items: start; }
  .contact-form { display: flex; flex-direction: column; gap: 14px; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .contact-form input[type="text"],
  .contact-form input[type="email"],
  .contact-form input[type="tel"],
  .contact-form textarea {
    width: 100%; font-family: var(--font-body); font-size: 16px;
    padding: 13px 16px; border: 1px solid #d8d2c8; border-radius: 8px; background: #fff;
  }
  .contact-form input:focus, .contact-form textarea:focus { outline: 2px solid var(--gold); border-color: var(--gold); }
  .privacy { display: flex; gap: 10px; align-items: flex-start; font-size: 14px; }
  .privacy a { color: var(--gold-dark); }
  .contact-form .btn { align-self: flex-start; }
  .contact-imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .contact-imgs .g-item { aspect-ratio: 1/1; }

  /* FIESTA CTA */
  .fiesta-cta { background: linear-gradient(135deg,#14102b,#2a1f57); color: #fff; padding: 70px 0; text-align: center; }
  .fiesta-inner { max-width: 760px; }
  .fiesta-inner .eyebrow { color: var(--gold); }
  .fiesta-inner p { font-size: 16px; margin-bottom: 26px; }

  /* responsive */
  @media (max-width: 900px) {
    .intro-gallery, .hotel-gallery { grid-template-columns: repeat(2, 1fr); }
    .artists-grid { grid-template-columns: repeat(2, 1fr); }
    .talleres-grid { grid-template-columns: 1fr; }
    .hotel-grid { grid-template-columns: 1fr; }
    .transfers-grid { grid-template-columns: 1fr; }
    .contact-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .field-row { grid-template-columns: 1fr; }
    .fullpass-widget iframe { height: 430px; }
  }

  /* En móvil el selector se apila y necesita más altura */
  @media (max-width: 600px) {
    .fullpass-widget iframe { height: 760px; }
  }
</style>
