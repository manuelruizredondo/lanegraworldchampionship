---
import Base from "@/layouts/Base.astro";
import SubNav from "@/components/SubNav.astro";
import { img } from "@/data/img.js";

const subNav = [
  { label: "Registration", href: "#registration" },
  { label: "Rules", href: "#rules" },
  { label: "Pass", href: "#fullpass" },
  { label: "Competitors", href: "/en/competitors/" },
  { label: "Winners 2025", href: "/en/winners-2025/" },
  { label: "Winners 2024", href: "/en/winners/" },
];

const FORM_URL = "https://docs.google.com/forms/d/e/1FAIpQLSfYZmv7H84x3PvdIFRJwJPQk2yU7KjQyGsu2ba5uu6kPtGapA/viewform?usp=header";

const heroGrid = [
  "lanegra-dance-festival-comepeticion-7.webp",
  "lanegra-dance-festival-comepeticion-6.webp",
  "lanegra-dance-festival-comepeticion-14.webp",
  "lanegra-dance-festival-comepeticion-13.webp",
  "lanegra-dance-festival-comepeticion-19.webp",
  "lanegra-dance-festival-comepeticion-15.webp",
];

const gallery = [
  "la-negra-dance-festival-artistas-1-6.webp",
  "la-negra-dance-festival-artistas-1-5.webp",
  "la-negra-dance-festival-artistas-1-4.webp",
  "la-negra-dance-festival-artistas-1-3.webp",
  "la-negra-dance-festival-artistas-1-7.webp",
  "la-negra-dance-festival-artistas-1-2.webp",
  "la-negra-dance-festival-artistas-1-1.webp",
  "la-negra-dance-festival-artistas-.webp",
  "la-negra-dance-festival-festival-img-5.webp",
  "la-negra-dance-festival-festival-img-6.webp",
  "la-negra-dance-festival-festival-img-8.webp",
  "la-negra-dance-festival-img-ganadores-2.webp",
  "la-negra-dance-festival-img-ganadores-3.webp",
  "la-negra-dance-festival-img-ganadores-4.webp",
  "la-negra-dance-festival-img-ganadores-5.webp",
  "la-negra-dance-festival-img-ganadores-6.webp",
  "la-negra-dance-festival-img-ganadores-7.webp",
];
---

<Base title="Competition" description="Registration for the Salsa and Bachata World Cup at La Negra Dance Festival. Download the rules, discover the workshops and book your hotel." lang="en">
  <SubNav items={subNav} label="Competition sections" />
  <!-- HERO / REGISTRATION -->
  <section class="section registration text-center" id="registration">
    <div class="container">
      <p class="eyebrow dark">Salsa – Bachata</p>
      <h1 class="script-title">Registration for the 2026 World Cup</h1>
      <a class="btn btn-solid hero-btn" href={FORM_URL} target="_blank" rel="noopener">Register now</a>
      <div class="hero-grid">
        {heroGrid.map((src) => (
          <div class="hero-cell"><img src={img(src)} alt="" loading="lazy" /></div>
        ))}
      </div>
    </div>
  </section>

  <!-- RULES -->
  <section class="section rules" id="rules">
    <div class="container rules-inner">
      <div class="rules-text">
        <p class="eyebrow dark">Compete in Salsa and Bachata</p>
        <h2 class="script-title">Download the competition rules</h2>
        <div class="rules-buttons">
          <a class="btn btn-solid" href="/img/2026/05/SALSA-BASES-Y-REGLAMENTO-2026_1.pdf" target="_blank" rel="noopener">Salsa Rules</a>
          <a class="btn btn-outline" href="/img/2026/05/BACHATA-BASES-Y-REGLAMENTO-2026_1.docx.pdf" target="_blank" rel="noopener">Bachata Rules</a>
        </div>
      </div>
      <div class="rules-imgs">
        <img src={img("la-negra-dance-festival-galeria-2023-23.webp")} alt="" loading="lazy" />
        <img src={img("la-negra-dance-festival-galeria-2023-28.webp")} alt="" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- WORKSHOPS -->
  <section class="section workshops text-center">
    <div class="container">
      <p class="eyebrow dark">Salsa – Bachata</p>
      <h2 class="script-title">Workshops to enjoy</h2>
      <p class="workshops-text">Every year we bring renowned artists and dancers from different corners of the world. From amateurs to competitors and professionals can enjoy basic, intermediate and advanced level workshops in disciplines such as: Cuban Salsa, On2, On2, Bachata Sensual, Traditional, Fusion and the latest trends. Masterclass only for professionals.</p>
      <a class="btn btn-outline" href="/en/workshops/">View all workshops</a>
    </div>
  </section>

  <!-- FULL PASS -->
  <section class="section fullpass text-center" id="fullpass">
    <div class="container">
      <p class="eyebrow dark">Full Pass</p>
      <h2 class="script-title">See you at ….</h2>
      <p class="fullpass-text">Get your Full Pass to experience La Negra Dance Festival in full. Tickets managed through our official partner.</p>
      <a class="btn btn-solid" href="https://www.goandance.com" target="_blank" rel="noopener">go&amp;dance</a>
    </div>
  </section>

  <!-- HOTEL -->
  <section class="section hotel">
    <div class="container">
      <div class="hotel-head text-center">
        <p class="eyebrow dark">AR Diamante Beach</p>
        <h2 class="script-title">Book your Hotel</h2>
        <p class="hotel-sub">La Negra Dance Festival Venue</p>
      </div>
      <div class="hotel-grid">
        <div class="hotel-map">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3115.9332867988783!2d0.07065367592495361!3d38.65041427177794!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x129dfe00f86d3eef%3A0x8f672c62926e85bf!2sAR%20Diamante%20Beach!5e0!3m2!1ses!2ses!4v1742755084006!5m2!1ses!2ses"
            width="100%" height="360" style="border:0" loading="lazy"
            referrerpolicy="no-referrer-when-downgrade" title="AR Diamante Beach"></iframe>
        </div>
        <div class="hotel-text">
          <p>Enjoy a unique stay in <strong>AR Diamante Beach</strong>, a reference in the Costa Blanca with spectacular views of the sea and the Peñón de Ifach. Our elegant rooms combine comfort and style to make every awakening special.</p>
          <p>Relax in our <strong>three pools</strong>, including a children's pool in an exclusive setting with palm trees, sun loungers, cocktails and entertainment. Beach or pool? Don't choose, enjoy it all, just a few steps from the sea.</p>
          <p>In case of problems with the reservation please contact: <a href="mailto:reservas@galaxtur.com">reservas@galaxtur.com</a></p>
          <p class="hotel-note">IMPORTANT NOTE: EXCLUSIVE RATE FOR EVENT ATTENDEES. IN CASE OF IDENTIFYING THE CONTRARY AND NOT PRESENTING THE FULLPASS AT CHECK-IN, THE RESERVATION WILL BE CANCELLED.</p>
          <a class="btn btn-solid" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Book now</a>
        </div>
      </div>

      <div class="transfers">
        <h3 class="transfers-title">How to get to the hotel from the airport or train station?</h3>
        <div class="transfers-grid">
          <div class="transfer-card">
            <h4>Alicante – Calpe airport transfers</h4>
            <p>Arrival or take-off between 7:00h and 23:55h: Price of shared transfer 23.50 € per person one way</p>
          </div>
          <div class="transfer-card">
            <h4>Alicante – Calpe train station transfers</h4>
            <p>Arrival or departure between 9:00 a.m. and 8:15 p.m.: Shared transfer price 18 € per person per way</p>
          </div>
        </div>
        <p class="transfers-note">Once the information is received, the reservation will be made and a confirmation and a link for the payment of the transfer will be sent.</p>
        <div class="text-center">
          <a class="btn btn-outline" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Book now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section-tight gallery-section">
    <div class="container">
      <div class="gallery-grid">
        {gallery.map((src) => (
          <div class="gallery-cell"><img src={img(src)} alt="" loading="lazy" /></div>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section final-cta text-center">
    <div class="container">
      <p class="eyebrow dark">Enjoy dancing</p>
      <h2 class="script-title">Your Latin dance festival</h2>
      <p class="final-text">Three days of salsa and bachata, for those in love with Latin dance. Pure fire on the dance floor: artists, contestants, workshops, parties and lots of rhythm. Not to be missed, from October 21 to 25, 2026 in Calpe (Spain).</p>
      <p class="final-sub">An international Salsa and Bachata festival and dance competition.</p>
      <p class="final-claim">Come, dance and enjoy!</p>
      <div class="final-buttons">
        <a class="btn btn-outline" href="/en/winners/">Previous winners</a>
        <a class="btn btn-solid" href="/en/competitors/">Competitors</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--navy); }

  /* REGISTRATION / HERO */
  .registration h1 { margin-bottom: 22px; }
  .hero-btn { margin-bottom: 40px; }
  .hero-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .hero-cell { border-radius: 10px; overflow: hidden; aspect-ratio: 4/3; }
  .hero-cell img { width: 100%; height: 100%; object-fit: cover; }

  /* RULES */
  .rules { background: var(--cream); }
  .rules-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  .rules-buttons { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 12px; }
  .rules-imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .rules-imgs img { width: 100%; height: 100%; object-fit: cover; border-radius: 10px; aspect-ratio: 3/4; }

  /* WORKSHOPS */
  .workshops-text { max-width: 820px; margin: 0 auto 32px; }

  /* FULL PASS */
  .fullpass { background: linear-gradient(135deg,#14102b,#2a1f57); color: #fff; }
  .fullpass .eyebrow.dark { color: var(--gold); }
  .fullpass .script-title { color: var(--gold); }
  .fullpass-text { max-width: 720px; margin: 0 auto 28px; }

  /* HOTEL */
  .hotel-sub { font-size: 18px; color: var(--gold-dark); margin-top: 6px; }
  .hotel-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; margin-top: 36px; }
  .hotel-map { border-radius: 12px; overflow: hidden; line-height: 0; }
  .hotel-text p { font-size: 15px; margin: 0 0 16px; }
  .hotel-text a { color: var(--gold-dark); }
  .hotel-note { font-size: 13px; font-weight: 700; color: var(--navy); background: var(--cream); padding: 14px 16px; border-radius: 8px; }
  .transfers { margin-top: 56px; }
  .transfers-title { text-align: center; font-family: var(--font-body); font-weight: 700; color: var(--navy); font-size: 22px; margin-bottom: 28px; }
  .transfers-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 20px; }
  .transfer-card { background: var(--cream); border-radius: 10px; padding: 24px; }
  .transfer-card h4 { font-family: var(--font-body); font-weight: 700; color: var(--gold-dark); margin: 0 0 10px; font-size: 17px; }
  .transfer-card p { margin: 0; font-size: 15px; }
  .transfers-note { text-align: center; font-size: 14px; max-width: 720px; margin: 0 auto 22px; }

  /* GALLERY */
  .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  .gallery-cell { border-radius: 8px; overflow: hidden; aspect-ratio: 1; }
  .gallery-cell img { width: 100%; height: 100%; object-fit: cover; }

  /* FINAL CTA */
  .final-text { max-width: 820px; margin: 0 auto 18px; }
  .final-sub { max-width: 720px; margin: 0 auto 4px; }
  .final-claim { font-family: var(--font-script); color: var(--gold); font-size: 34px; margin: 6px 0 26px; }
  .final-buttons { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  /* responsive */
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: repeat(2, 1fr); }
    .rules-inner { grid-template-columns: 1fr; gap: 28px; }
    .hotel-grid { grid-template-columns: 1fr; gap: 28px; }
    .transfers-grid { grid-template-columns: 1fr; }
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .hero-grid { grid-template-columns: 1fr 1fr; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
