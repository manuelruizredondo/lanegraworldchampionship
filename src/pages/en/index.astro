---
import Base from "@/layouts/Base.astro";
import EventSchema from "@/components/EventSchema.astro";
import Faq from "@/components/Faq.astro";
import { img } from "@/data/img.js";
import { ARTISTS_EN } from "@/data/artists.js";

// Propuesta de home — estructura tipo "Board" (Nixtio) adaptada a La Negra Dance Festival.
const pillars = [
  {
    tag: "You come to compete",
    title: "The World Cup",
    desc: "Sign up for the Salsa & Bachata World Championship and compete before an elite international jury.",
    cta: "See the competition",
    href: "/en/competition/",
    img: img("festival-negra-dance-home-1.jpg"),
  },
  {
    tag: "You come to the festival",
    title: "The Festival",
    desc: "Workshops, parties, shows and a seafront hotel-spa. Enjoy it as an audience member in the best company.",
    cta: "See the festival",
    href: "/en/festival/",
    img: img("lanegra-dance-festival-comepeticion-7.webp"),
  },
];

const features = [
  { title: "The Artists", desc: "Step in and discover the constellation of salsa and bachata stars you'll have as teachers, judges and dance partners.", cta: "See artists", href: "/en/artists/", img: img("la-negra-dance-festival-galeria-2023-23.webp") },
  { title: "Workshops", desc: "Workshops and masterclasses for your level (beginner, intermediate, advanced or master) across every style of salsa and bachata.", cta: "See workshops", href: "/en/workshops/", img: img("la-negra-dance-festival-galeria-2023-10.webp") },
  { title: "The party", desc: "Two social dance floors until dawn: salsa and bachata in all their variants with the best DJs.", cta: "See the party", href: "/en/fiesta/", img: "/img/2025/03/lanegra-dance-festival-slide-2.webp" },
];

// Why it's the best salsa & bachata event: 4 proof points with their page
const reasons = [
  { n: "For the artists", t: "World-class artists", d: "More than 90 salsa and bachata legends every year as teachers, judges and dance partners. A line-up no other festival brings together.", cta: "The best artists", href: "/en/artists/", img: img("la-negra-dance-festival-galeria-2023-23.webp") },
  { n: "For the World Cup", t: "The one and only Pasos Libres World Cup", d: "The most prestigious Latin dance championship: 100% brand-new choreographies, an elite jury and competitors from more than 20 countries.", cta: "The best World Cup", href: "/en/world-championship/", img: img("ganadores_grupos_salsa_2025.jpg") },
  { n: "For the hotel", t: "A resort by the sea", d: "Everything happens in one 4★ spa hotel on the Mediterranean: you sleep, learn, compete and dance without ever leaving the festival.", cta: "See the hotel", href: "/en/festival/#hotel", img: "/img/2026/07/hotel-ar-diamante-piscina-atardecer.webp" },
  { n: "For the history", t: "15 editions of history", d: "Growing every year since 2010. Fifteen editions back the veteran, benchmark festival of salsa and bachata.", cta: "Past editions", href: "/en/editions/", img: img("lanegra-dance-festival-comepeticion-2.webp") },
];

const values = [
  { t: "Level", d: "The only World Cup with 100% brand-new choreographies and a top-tier jury.", img: img("lanegra-dance-festival-comepeticion-19.webp") },
  { t: "Community", d: "Dancers from more than 35 countries united by the same passion.", img: img("festival-pasos-negra-dance-2.jpeg") },
  { t: "Emotion", d: "Moments that give you goosebumps and stay with you long after the festival.", img: img("la-negra-dance-festival-fiesta-img-1.webp") },
];

const stats = [
  { n: "35+", l: "Countries" },
  { n: "90+", l: "Artists" },
  { n: "15", l: "Editions" },
  { n: "5.000+", l: "Dancers" },
];

// Mapa de nacionalidades: [país, asistentes, x%, y%] (cifras editables)
// Mapa de nacionalidades: país, asistentes, posición (x/y %), altura de varilla (h px)
const mapPins = [
  { l: "Spain", n: 3200, x: 47.2, y: 25.5, h: 150, big: true },
  { l: "Portugal", n: 170, x: 45.7, y: 28, h: 56 },
  { l: "France", n: 180, x: 48.6, y: 21.5, h: 96 },
  { l: "United Kingdom", n: 230, x: 47.6, y: 18.5, h: 144 },
  { l: "Germany", n: 260, x: 50.4, y: 21.5, h: 62 },
  { l: "Italy", n: 640, x: 51.6, y: 24.5, h: 114 },
  { l: "USA", n: 150, x: 21, y: 27.5, h: 110 },
  { l: "Canada", n: 110, x: 25, y: 13.5, h: 66 },
  { l: "Mexico", n: 210, x: 19, y: 37.5, h: 62 },
  { l: "Cuba", n: 130, x: 26.3, y: 39.5, h: 122 },
  { l: "Dominican Rep.", n: 90, x: 28.6, y: 41.5, h: 58 },
  { l: "Venezuela", n: 110, x: 29.2, y: 47.5, h: 100 },
  { l: "Colombia", n: 240, x: 26.6, y: 51.5, h: 64 },
  { l: "Brazil", n: 140, x: 33.5, y: 60, h: 112 },
  { l: "Argentina", n: 95, x: 29.8, y: 74, h: 70 },
  { l: "South Korea", n: 120, x: 80, y: 27, h: 62 },
  { l: "Japan", n: 140, x: 83.5, y: 25.5, h: 120 },
  { l: "Australia", n: 80, x: 85.5, y: 62, h: 84 },
];
const pinColors = ["#cc9933", "#14121a", "#a28243"];

// Llama animada del marquee: capa exterior + corazón, con parpadeo tipo fuego
const fire = `<svg class="p-fire" viewBox="0 0 24 24" aria-hidden="true"><path class="p-fire-o" fill="#ee7b1e" d="M13.5.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8C20 8.61 17.41 3.8 13.5.67z"/><path class="p-fire-i" fill="#ffc93c" d="M11.71 19c-1.78 0-3.22-1.4-3.22-3.14 0-1.62 1.05-2.76 2.81-3.12 1.77-.36 3.6-1.21 4.62-2.58.39 1.29.59 2.65.59 4.04 0 2.65-2.15 4.8-4.8 4.8z"/></svg>`;

// Nombre en dos líneas (nombre / apellidos) y en Título (evita nombres en MAYÚSCULAS del dataset)
const titleCase = (s) =>
  s.toLowerCase().replace(/(^|[\s\-])([a-záéíóúñü])/g, (m, p, c) => p + c.toUpperCase());
const artists = ARTISTS_EN.map((a) => {
  const parts = titleCase(a.name).split(" ");
  return { ...a, first: parts[0], last: parts.slice(1).join(" ") };
});
---

<Base
  lang="en"
  title="The best Salsa festival & the best Bachata festival · La Negra Dance Festival"
  description="The best salsa & bachata event: 90+ elite artists, the only World Cup with 100% brand-new choreographies, a seafront resort and 15 editions. Calpe, October 21–25, 2026."
  heroOverlay={true}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={img("la-negra-dance-festival-festival-img-12.webp")} fetchpriority="high" />
  </Fragment>
  <EventSchema lang="en" />
  <div class="prop">
    <!-- HERO (oscuro) -->
    <section class="p-hero">
      <video class="p-hero-video" autoplay muted loop playsinline preload="metadata" poster={img("la-negra-dance-festival-festival-img-12.webp")} src="https://res.cloudinary.com/u8ppc8of/video/upload/v1784387656/VIDEOWEB2025LANEGRACHAMPIONSCHIP_wpnfc8_vq3jps.mp4"></video>
      <div class="p-hero-inner">
        <h1 class="p-hero-title">La Negra World Championship &amp; salsa and bachata festival</h1>
        <p class="p-hero-date"><span>21–25 OCT 2026 · Calpe · Spain</span></p>
        <div class="p-hero-cta">
          <a class="p-btn p-btn-light" href="/en/world-championship/">Discover the World Cup</a>
          <a class="p-btn p-btn-outline" href="/en/festival/">Discover the festival</a>
        </div>
      </div>
        <div class="p-hero-count" role="timer" aria-label="Countdown to the event">
          <div class="p-hc"><span class="p-hc-n" data-d>0</span><span class="p-hc-l">Days</span></div>
          <div class="p-hc"><span class="p-hc-n" data-h>00</span><span class="p-hc-l">Hours</span></div>
          <div class="p-hc"><span class="p-hc-n" data-m>00</span><span class="p-hc-l">Min</span></div>
          <div class="p-hc"><span class="p-hc-n" data-s>00</span><span class="p-hc-l">Sec</span></div>
        </div>
    </section>

    <!-- MARQUEE (frases grandes + fuego separador + skew con el scroll) -->
    <section class="p-marquee" aria-hidden="true" data-marquee>
      <div class="p-marquee-track">
        <div class="p-marquee-half">
          <span>Que se prenda fuego la tarima!!!</span><Fragment set:html={fire} />
          <span>Que se prenda fuego la tarima!!!</span><Fragment set:html={fire} />
          <span>Que se prenda fuego la tarima!!!</span><Fragment set:html={fire} />
        </div>
        <div class="p-marquee-half">
          <span>Que se prenda fuego la tarima!!!</span><Fragment set:html={fire} />
          <span>Que se prenda fuego la tarima!!!</span><Fragment set:html={fire} />
          <span>Que se prenda fuego la tarima!!!</span><Fragment set:html={fire} />
        </div>
      </div>
    </section>

    <!-- STATEMENT 2 (comunidad) -->
    <section class="p-section p-center">
      <div class="p-container p-narrow">
        <div class="p-badge" aria-hidden="true">
          <img class="p-badge-ring" src="/img/logo-lanegra-ring.svg" alt="" />
          <img class="p-badge-face" src="/img/logo-lanegra-face.svg" alt="" />
        </div>
        <h2 class="p-h2">An international community of dancers united by <span class="p-hl">salsa<svg class="p-hl-line" viewBox="0 0 500 150" preserveAspectRatio="none" aria-hidden="true"><path d="M8.1,146.2c0,0,240.6-55.6,479-13.8" pathLength="500"></path></svg></span> and <span class="p-nb"><span class="p-hl p-hl-2">bachata<svg class="p-hl-line" viewBox="0 0 500 150" preserveAspectRatio="none" aria-hidden="true"><path d="M8.1,146.2c0,0,240.6-55.6,479-13.8" pathLength="500"></path></svg></span>,</span> devoted to skill, emotion and celebration.</h2>
        <p class="p-lead p-quote">A place where, whatever country you come from, the moment you step onto the floor you're among your own.</p>
      </div>
    </section>

    <!-- INTRO -->
    <section class="p-section p-gray">
      <div class="p-container p-intro">
        <h2 class="p-h2">Learn from the best.<br />Compete against the best.<br /><span class="p-accent">Dance with everyone.</span></h2>
        <div class="p-intro-cols">
          <p>Since 2010, La Negra Dance Festival has earned its place as the best salsa & bachata event: the most important artist line-up, a World Cup unlike any other and dancers from more than 35 countries.</p>
          <p>Workshops for every level, parties until dawn and the only World Cup with 100% brand-new choreographies. All in one seafront resort in Calpe, fifteen editions on.</p>
        </div>
      </div>
    </section>

    <!-- WHY THE BEST (positioning: artists · World Cup · hotel · editions) -->
    <section class="p-section why">
      <div class="p-container p-split">
        <h2 class="p-h2">The best salsa &amp; bachata<br />festival?</h2>
        <p class="p-lead">Don't take our word for it: the artists who come, the World Cup nobody else has, the resort where it all happens and fifteen editions say it for us.</p>
      </div>
      <div class="p-container why-grid">
        {reasons.map((r) => (
          <a class="why-card" href={r.href}>
            <img class="why-img" src={r.img} alt="" loading="lazy" />
            <div class="why-body">
              <span class="why-n">{r.n}</span>
              <h3 class="why-t">{r.t}</h3>
              <p class="why-d">{r.d}</p>
              <span class="p-card-link">{r.cta} →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- PILLARS -->
    <section class="p-section p-tight p-gray">
      <div class="p-container p-split">
        <h2 class="p-h2">Everything in<br />one festival.</h2>
        <p class="p-lead">Whether you come to compete in the World Cup or to enjoy it as an audience: workshops, shows, parties and a seafront hotel-spa, all in one place.</p>
      </div>
      <div class="p-container p-pillars">
        {pillars.map((p) => (
          <a class="p-pillar" href={p.href}>
            <div class="p-pillar-media"><img src={p.img} alt={p.title} loading="lazy" /></div>
            <div class="p-pillar-panel">
              <span class="p-pillar-tag">{p.tag}</span>
              <h3 class="p-pillar-t">{p.title}</h3>
              <p class="p-pillar-d">{p.desc}</p>
              <span class="p-btn p-btn-light p-btn-sm">{p.cta}</span>
            </div>
          </a>
        ))}
        <span class="p-pillars-plus" aria-hidden="true">+</span>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="p-section">
      <div class="p-container p-split">
        <h2 class="p-h2">Discover<br />it all.</h2>
        <p class="p-lead">Four days of non-stop dancing: legendary artists, workshops for your level and parties you'll never forget.</p>
      </div>
      <div class="p-container p-cards">
        {features.map((f) => (
          <a class="p-card" href={f.href}>
            <div class="p-card-media"><img src={f.img} alt={f.title} loading="lazy" /></div>
            <div class="p-card-panel">
              <h3 class="p-card-t">{f.title}</h3>
              <p class="p-card-d">{f.desc}</p>
              <span class="p-card-link">{f.cta} →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- STATEMENT 3 -->
    <section class="p-section p-center p-gray">
      <div class="p-container p-narrow">
        <h2 class="p-display">We grow<br />by dancing together.</h2>
        <p class="p-lead">Here you don't come to an event: you enter a community that reunites every year by the Mediterranean.</p>
        <div class="p-cta-row">
          <a class="p-btn p-btn-dark" href="/en/your-pass/">Buy pass</a>
          <div class="p-btn-off-wrap">
            <span class="p-btn p-btn-off" aria-disabled="true" title="Registration for the 2026 World Cup is closed">Register for the World Cup*</span>
            <p class="p-cta-note">*Competitor registration is closed.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- VALUES -->
    <section class="p-section">
      <div class="p-container p-values">
        <div class="p-values-head">
          <p class="p-eyebrow">Our values</p>
          <h2 class="p-h2">What makes<br />us unique.</h2>
        </div>
        <div class="p-values-list">
          {values.map((v, i) => (
            <div class={i === 0 ? "p-value active" : "p-value"} data-img={v.img} role="button" tabindex="0">
              <h3 class="p-value-t">{v.t}</h3>
              <p class="p-value-d">{v.d}</p>
            </div>
          ))}
        </div>
        <div class="p-values-media"><img src={values[0].img} alt="La Negra Dance Festival" loading="lazy" /></div>
      </div>
    </section>

    <!-- STATS -->
    <section class="p-stats">
      <div class="p-container p-stats-row">
        {stats.map((s) => (
          <div class="p-stat"><span class="p-stat-n">{s.n}</span><span class="p-stat-l">{s.l}</span></div>
        ))}
      </div>
    </section>

    <!-- PHOTO BAND (parallax interior + mensaje de internacionalidad) -->
    <section class="p-band">
      <div class="p-band-media">
        <img src={img("la-negra-dance-festival-fiesta-img-12.webp")} alt="" loading="lazy" />
      </div>
      <div class="p-band-content">
        <p class="p-band-eyebrow">35+ countries · 5 continents</p>
        <h2 class="p-band-title">The whole world<br />dances in Calpe.</h2>
        <p class="p-band-sub">Different languages, one same language. Every October, dancers from all over the planet gather by the Mediterranean.</p>
      </div>
    </section>

    <!-- WORLD MAP (nacionalidades) -->
    <section class="p-map-sec">
      <div class="p-container p-center p-map-head">
        <p class="p-eyebrow">Nationalities</p>
        <h2 class="p-h2">From every corner<br />of the planet.</h2>
      </div>
      <div class="p-map" data-map>
        <div class="p-map-plane">
          <img class="p-map-img" src="/img/world-map-dots.svg" alt="Map of attendees' nationalities" width="2370" height="1104" loading="lazy" />
          {mapPins.map((p, i) => (
            <div
              class={p.big ? "p-pin p-pin-big" : "p-pin"}
              data-x={p.x}
              data-y={p.y}
              style={`left:${p.x}%; top:${p.y}%; --pin-d:${i * 80}ms; --stem:${p.h}px; --dot:${Math.round(8 + Math.min(14, Math.sqrt(p.n) / 4))}px; --pin-c:${p.big ? "#cc9933" : pinColors[i % 3]}`}
            >
              <span class="p-pin-bubble"><span class="p-pin-n" data-count={p.n}>{String(p.n).replace(/\B(?=(\d{3})+(?!\d))/g, ".")}</span></span>
              <span class="p-pin-l">{p.l}</span>
              <span class="p-pin-stem"></span>
              <span class="p-pin-hit"></span>
            </div>
          ))}
        </div>
      </div>
      {/* Móvil: rejilla de cifras siempre visible (sin hover, sin solapes) */}
      <div class="p-container p-map-grid">
        {[...mapPins].sort((a, b) => b.n - a.n).map((p) => (
          <div class="p-map-chip">
            <span class="p-map-chip-n">{String(p.n).replace(/\B(?=(\d{3})+(?!\d))/g, ".")}</span>
            <span class="p-map-chip-l">{p.l}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ARTISTS -->
    <section class="p-section p-center">
      <div class="p-container">
        <h2 class="p-display">Our artists.</h2>
        <p class="p-lead p-narrow">The international salsa and bachata stars who will set the stage ablaze.</p>
      </div>
      <div class="p-artists" data-artists-slider>
        <div class="p-artists-track">
          <div class="p-artists-set">
            {artists.map((a) => (
          <div class="p-artist">
            <div class="p-artist-img"><img src={img(a.img)} alt={a.name} loading="lazy" /></div>
            <span class="p-artist-n"><span>{a.first}</span>{a.last && <span>{a.last}</span>}</span>
            <span class="p-artist-c">{a.country}</span>
          </div>
        ))}
          </div>
          <div class="p-artists-set" aria-hidden="true">
            {artists.map((a) => (
          <div class="p-artist">
            <div class="p-artist-img"><img src={img(a.img)} alt={a.name} loading="lazy" /></div>
            <span class="p-artist-n"><span>{a.first}</span>{a.last && <span>{a.last}</span>}</span>
            <span class="p-artist-c">{a.country}</span>
          </div>
        ))}
          </div>
        </div>
      </div>
      <div class="p-container">
        <a class="p-btn p-btn-dark" href="/en/artists/">See all artists</a>
      </div>
    </section>

    <Faq lang="en" />

    <!-- FINAL CTA (oscuro) -->
    <section class="p-final">
      <div class="p-container p-final-inner">
        <h2 class="p-display p-white">See you in<br />Calpe 2026.</h2>
        <p class="p-lead p-white-70">Book your Full Pass for La Negra Dance Festival and live the Salsa & Bachata World Championship.</p>
        <div class="p-hero-cta">
          <a class="p-btn p-btn-light" href="/en/your-pass/">Buy your pass</a>
          <a class="p-btn p-btn-outline" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Book hotel</a>
        </div>
      </div>
    </section>
  </div>
  <script>
    import "@/scripts/home.js";
  </script>
</Base>
