---
import Base from "@/layouts/Base.astro";
import { img } from "@/data/img.js";

const heroImgs = [
  "fiesta-la-negra-dance-festival-foto-3.jpeg",
  "fiesta-la-negra-dance-festival-foto-1.jpeg",
  "la-negra-dance-festival-fiesta-img-1.webp",
  "la-negra-dance-festival-fiesta-img-3.webp",
  "fiesta-la-negra-dance-festival-foto-2.jpeg",
  "la-negra-dance-festival-fiesta-img-4.webp",
];

const djs = [
  { name: "Fabrizio Zoro", country: "Italy", img: "fabrizio-la-negra-dance-musica-1.jpg", ig: "https://www.instagram.com/fabriziozoro/", yt: "https://www.youtube.com/channel/UCg9WHKNhujZQmfPreORPEWA" },
  { name: "DJ Legendary", country: "Spain", img: "WhatsApp-Image-2025-05-26-at-16.36.39.jpeg", ig: "https://www.instagram.com/alberz_legendario/" },
  { name: "Evelyn La Negra", country: "Venezuela", img: "evelyn.la_.negra-dance-festival.jpg", ig: "https://www.instagram.com/evelynlanegrasalsa/" },
  { name: "DJ Killo", country: "Spain", img: "hugo-leite-la-negra-dance-festival-1.jpg", ig: "https://www.instagram.com/dj.killo/" },
  { name: "DJ Salva", country: "Spain", img: "dj-salva-la-negra-dance-festival.jpeg", ig: "https://www.instagram.com/dj_salva_bachataysalsa/" },
  { name: "DJ Lissj", country: "Venezuela", img: "la-negra-dance-festival-fiesta-img-7.webp", ig: "https://www.instagram.com/lissettevianalovera/" },
];

const igIcon = `<svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.8.3 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.3 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.8-.3-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.4-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.9c.1-1.2.3-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4C8.4 2.2 8.8 2.2 12 2.2zm0 4.9a4.9 4.9 0 1 0 0 9.8 4.9 4.9 0 0 0 0-9.8zm0 8.1a3.2 3.2 0 1 1 0-6.4 3.2 3.2 0 0 1 0 6.4zm6.3-8.3a1.1 1.1 0 1 1-2.3 0 1.1 1.1 0 0 1 2.3 0z"/></svg>`;
const ytIcon = `<svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor"><path d="M23 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.7-1.7C19.4 5.2 12 5.2 12 5.2s-7.4 0-8.9.4A2.5 2.5 0 0 0 1.4 7.3C1 8.8 1 12 1 12s0 3.2.4 4.7a2.5 2.5 0 0 0 1.7 1.7c1.5.4 8.9.4 8.9.4s7.4 0 8.9-.4a2.5 2.5 0 0 0 1.7-1.7C23 15.2 23 12 23 12zM9.7 15.3V8.7l5.8 3.3-5.8 3.3z"/></svg>`;

const nights = [
  { title: "Jeans & Full Color", day: "Thursday", text: "A casual night full of color, comfort and freshness. Combine blue jeans with your favorite color", img: "festival-pasos-libres-fiesta-dias-1.jpeg" },
  { title: "White Party!", day: "Friday", text: "As has become a tradition, every Friday of the festival all shades of white are paraded.", img: "festival-pasos-libres-fiesta-dias-4.jpeg" },
  { title: "Elegant Night", day: "Saturday", text: "Dress your best for the most impressive night of the festival.", img: "festival-pasos-libres-fiesta-dias-3.jpeg" },
  { title: "Be yourself", day: "Sunday", text: "We love that you show yourself as you are. Tonight the dress code is up to you!", img: "festival-pasos-libres-fiesta-dias-2.jpeg" },
];

const gallery = [
  "la-negra-dance-festival-festival-img-1.webp",
  "lanegra-dance-festival-comepeticion-2.webp",
  "la-negra-dance-festival-fiesta-img-12.webp",
  "la-negra-dance-festival-fiesta-img-7.webp",
  "la-negra-dance-festival-fiesta-img-10.webp",
];
---

<Base title="Party" description="The most danced nights of the year: four nights, four themes and two social dancing rooms at La Negra Dance Festival." lang="en">
  <!-- HERO -->
  <section class="section fiesta-hero text-center">
    <div class="container">
      <p class="eyebrow dark">When the sun goes down…</p>
      <h1 class="script-title">The real magic of the festival begins!</h1>
      <h2 class="hero-sub">The most danced nights of the year are here</h2>
      <div class="hero-cols">
        <p>The workshops and competition are just the beginning. Get ready for nights of pure energy at our theme parties, where the best atmosphere, the best dancers and the best music will make you live an unforgettable experience.</p>
        <p>No matter if you come alone, with friends or as a couple: on the dance floor you will always find someone to share the rhythm with. Four nights, four themes, only one goal: that you don’t stop dancing.</p>
      </div>
    </div>
    <div class="container hero-gallery">
      {heroImgs.map((src) => <div class="hg-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
    </div>
  </section>

  <!-- TWO ROOMS -->
  <section class="section rooms text-center">
    <div class="container">
      <p class="eyebrow dark">Two rooms, double the dance</p>
      <h2 class="script-title">For your maximum enjoyment</h2>
      <div class="rooms-grid">
        <article class="room">
          <h3 class="script-title room-title">Salsa Room</h3>
          <p>90% Salsa of all times: romantic, great classics, timba, sones, salsatones, animations and ruedas with all the artists of the festival and 10% of bachata so you can enjoy a real party.</p>
        </article>
        <article class="room">
          <h3 class="script-title room-title">Bachata Room</h3>
          <p>90% bachata of all styles and 10% salsa romántica. You will only hear the best hits of all times and the most recent of your favorite genre.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- DJs -->
  <section class="section djs text-center">
    <div class="container">
      <h2 class="script-title djs-title">We will have the best musical selection thanks to our star DJs</h2>
      <div class="djs-grid">
        {djs.map((d) => (
          <article class="dj">
            <div class="dj-img"><img src={img(d.img)} alt={d.name} loading="lazy" /></div>
            <h3 class="dj-name">{d.name}</h3>
            <p class="dj-country">{d.country}</p>
            <div class="dj-social">
              {d.ig && <a href={d.ig} target="_blank" rel="noopener" aria-label="Instagram" set:html={igIcon}></a>}
              {d.yt && <a href={d.yt} target="_blank" rel="noopener" aria-label="YouTube" set:html={ytIcon}></a>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- THEME NIGHTS -->
  <section class="section nights text-center">
    <div class="container">
      <p class="eyebrow dark">Theme nights</p>
      <h2 class="script-title">A style for every party</h2>
      <p class="nights-intro">4 days with 4 parties, each day with a different style. Parties enlivened with the best music of our DJs for you to enjoy dancing the best salsa and bachata. Are you going to miss it?</p>
      <div class="nights-grid">
        {nights.map((n) => (
          <article class="night">
            <div class="night-img">
              <img src={img(n.img)} alt={n.title} loading="lazy" />
              <span class="night-day">{n.day}</span>
            </div>
            <h4 class="night-title">{n.title}</h4>
            <p class="night-text">{n.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PAST EDITIONS -->
  <section class="section past text-center">
    <div class="container past-gallery">
      {gallery.map((src) => <div class="pg-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
    </div>
    <div class="container">
      <p class="eyebrow dark">Past editions</p>
      <h3 class="script-title">Revive the magic</h3>
      <p class="past-text">Immerse yourself in the memories and emotions of our past editions. Discover in our photo gallery the most spectacular moments: passionate dances, unforgettable workshops, energetic parties and vibrant competitions: let yourself be inspired by the passion of bachata and get ready to live it!</p>
      <a class="btn btn-solid" href="/en/gallery-2023/">View gallery</a>
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--navy); }

  /* HERO */
  .hero-sub { font-family: var(--font-body); font-weight: 700; text-transform: uppercase; font-size: 22px; letter-spacing: .03em; color: var(--navy); margin: 6px 0 26px; }
  .hero-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; text-align: left; max-width: 1000px; margin: 0 auto; }
  .hero-cols p { font-size: 15px; }
  .hero-gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 44px; }
  .hg-item { border-radius: 10px; overflow: hidden; aspect-ratio: 4/3; }
  .hg-item img { width: 100%; height: 100%; object-fit: cover; }

  /* ROOMS */
  .rooms { background: var(--cream); }
  .rooms-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 12px; }
  .room { padding: 0 10px; }
  .room-title { font-size: 32px; color: var(--gold); margin: 0 0 14px; }
  .room p { font-size: 15px; }

  /* DJs */
  .djs-title { font-size: 30px; max-width: 820px; margin: 0 auto 40px; }
  .djs-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 20px; }
  .dj-img { border-radius: 10px; overflow: hidden; aspect-ratio: 3/4; margin-bottom: 12px; }
  .dj-img img { width: 100%; height: 100%; object-fit: cover; }
  .dj-name { font-family: var(--font-body); font-weight: 700; text-transform: uppercase; font-size: 16px; letter-spacing: .03em; color: var(--navy); margin: 0 0 4px; }
  .dj-country { font-family: var(--font-body); font-weight: 400; font-size: 15px; color: var(--gold-dark); margin: 0 0 10px; }
  .dj-social { display: flex; gap: 8px; justify-content: center; }
  .dj-social a { display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; background: var(--gold); color: #fff; }
  .dj-social a:hover { background: var(--gold-dark); }

  /* NIGHTS */
  .nights { background: var(--navy); }
  .nights .eyebrow.dark { color: var(--gold); }
  .nights .script-title { color: var(--gold); }
  .nights-intro { color: var(--cream); max-width: 820px; margin: 0 auto 40px; font-size: 15px; }
  .nights-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
  .night-img { position: relative; border-radius: 10px; overflow: hidden; aspect-ratio: 3/4; margin-bottom: 16px; }
  .night-img img { width: 100%; height: 100%; object-fit: cover; }
  .night-day {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 24px 12px 12px; color: #fff;
    font-family: var(--font-display); font-style: italic; font-size: 18px;
    background: linear-gradient(to top, rgba(15,11,30,.85), transparent);
  }
  .night-title { font-family: var(--font-body); font-weight: 700; text-transform: uppercase; font-size: 18px; letter-spacing: .03em; color: #fff; margin: 0 0 10px; }
  .night-text { color: var(--cream); font-size: 14px; margin: 0; }

  /* PAST */
  .past-gallery { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-bottom: 44px; }
  .pg-item { border-radius: 10px; overflow: hidden; aspect-ratio: 3/4; }
  .pg-item img { width: 100%; height: 100%; object-fit: cover; }
  .past-text { max-width: 820px; margin: 0 auto 28px; font-size: 15px; }

  /* responsive */
  @media (max-width: 900px) {
    .hero-cols { grid-template-columns: 1fr; gap: 14px; }
    .hero-gallery { grid-template-columns: repeat(2, 1fr); }
    .rooms-grid { grid-template-columns: 1fr; gap: 30px; }
    .djs-grid { grid-template-columns: repeat(3, 1fr); }
    .nights-grid { grid-template-columns: repeat(2, 1fr); }
    .past-gallery { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .hero-gallery { grid-template-columns: 1fr; }
    .djs-grid { grid-template-columns: repeat(2, 1fr); }
    .nights-grid { grid-template-columns: 1fr; }
    .past-gallery { grid-template-columns: repeat(2, 1fr); }
  }
</style>
