<Base title="Gallery 2024 — La Negra World Championship" description="Photo gallery from the 2024 edition of La Negra World Championship." lang="en">
  <section class="section gallery-head text-center">
    <div class="container">
      <p class="eyebrow dark">Photo Gallery</p>
      <h1 class="script-title">Relive other editions – 2024</h1>
      <p class="gallery-sub">i DJ to set the stage on fire !</p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="gallery-grid">
        {photos.map((name) => (
          <div class="gallery-item">
            <img src={img(name)} alt="La Negra World Championship 2024" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--gold); }
  .gallery-head { padding-bottom: 30px; }
  .gallery-sub { font-family: var(--font-script); color: var(--gold); font-size: 28px; margin: 8px 0 0; }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .gallery-item {
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .4s ease;
  }
  .gallery-item:hover img { transform: scale(1.05); }

  @media (max-width: 900px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); gap: 12px; }
  }
  @media (max-width: 600px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }
</style>
