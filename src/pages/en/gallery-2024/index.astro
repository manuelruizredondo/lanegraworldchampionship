---

<Base title="Gallery 2024 — La Negra Dance Festival" description="Photo gallery from the 2024 edition of La Negra Dance Festival." lang="en">
  <div class="prop">
    <section class="p-section p-center gallery-head">
      <div class="p-container">
        <p class="p-eyebrow">Photo Gallery</p>
        <h1 class="p-display">Relive other editions – 2024</h1>
        <p class="p-lead">i DJ to set the stage on fire !</p>
      </div>
    </section>

    <section class="p-section p-tight">
      <div class="p-container">
        <div class="prop-gallery">
          {photos.map((name) => (
            <figure class="g-item">
              <img src={img(name)} alt="La Negra Dance Festival 2024" loading="lazy" data-lightbox />
            </figure>
          ))}
        </div>
      </div>
    </section>

    <Lightbox />
  </div>
</Base>

<style>
  .gallery-head { padding-bottom: 0; }
  .gallery-head .p-lead { margin-top: 10px; }

  .prop-gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .g-item {
    margin: 0;
    border-radius: 18px;
    overflow: hidden;
    aspect-ratio: 3 / 2;
    background: var(--p-card);
  }
  .g-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    cursor: zoom-in;
    transition: transform .5s ease;
  }
  .g-item:hover img { transform: scale(1.05); }

  @media (max-width: 900px) {
    .prop-gallery { grid-template-columns: repeat(2, 1fr); gap: 14px; }
  }
  @media (max-width: 560px) {
    .prop-gallery { grid-template-columns: 1fr; }
  }
</style>
