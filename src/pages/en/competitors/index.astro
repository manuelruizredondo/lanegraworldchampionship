---
import Base from "@/layouts/Base.astro";
import { img } from "@/data/img.js";

const categories = [
  { label: "Male salsa duos", img: "DUOS-MASCULINO-SALSA-2025.jpeg" },
  { label: "Female Salsa Duets", img: "DUOS-FEMENINO-SALSA-2025.jpeg" },
  { label: "Salsa Couples", img: "PAREJAS-SALSA-2025.jpeg" },
  { label: "Salsa Teams", img: "GRUPOS-SALSA-2025.jpeg" },
  { label: "Female salsa soloist (semi)", img: "FINAL-SOLISTAS-FEMENINO-SALSA.jpeg" },
  { label: "Female salsa soloist", img: "ELIMINATORIA-SOLISTAS-FEMENINO-SALSA_1.jpeg" },
  { label: "Male salsa soloist (semi)", img: "semifinal-y-final-chicos-2025.jpeg" },
  { label: "Male salsa soloist", img: "ELIMINATORIA-SOLISTAS-MASCULINO-SALSA-2025.jpeg" },
  { label: "Bachata Female Soloist", img: "SOLISTA-FEM-BACHATA-2025.jpeg" },
  { label: "Bachata Male Soloist", img: "SOLISTA-MAS-BACHATA-2025.jpeg" },
  { label: "Bachata duos", img: "DUOS-BACHATA-2025.jpeg" },
  { label: "Bachata Couples", img: "PAREJAS-BACHATA-2025.jpeg" },
  { label: "Bachata Teams", img: "equipo-bahatca-final-festival-la-negra-2.jpg" },
];

const gallery = [
  "lanegra-dance-festival-home-1-7.webp",
  "lanegra-dance-festival-home-3-2.webp",
  "lanegra-dance-festival-home-3-10.webp",
  "lanegra-dance-festival-home-3-13.webp",
  "lanegra-dance-festival-home-3-14.webp",
  "lanegra-dance-festival-home-3-22.webp",
  "lanegra-dance-festival-home-3-23.webp",
  "lanegra-dance-festival-home-3-26.webp",
];
---

<Base title="Competitors" description="The competitors of La Negra Dance Festival's Salsa and Bachata World Cup." lang="en">
  <!-- INTRO + GRID -->
  <section class="section competitors text-center">
    <div class="container">
      <p class="eyebrow dark">Salsa and Bachata</p>
      <h2 class="script-title">Competitors in 2025</h2>
      <div class="cat-grid">
        {categories.map((c) => (
          <article class="cat-card">
            <div class="cat-img"><img src={img(c.img)} alt={c.label} loading="lazy" /></div>
            <h3 class="cat-label">{c.label}</h3>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section-tight">
    <div class="container gallery-grid">
      {gallery.map((src) => (
        <div class="gallery-item"><img src={img(src)} alt="" loading="lazy" /></div>
      ))}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section final-cta text-center">
    <div class="container">
      <p class="eyebrow dark">Enjoy dancing</p>
      <h2 class="script-title">Your Latin dance festival</h2>
      <p class="final-text">Three days of salsa and bachata, for those in love with Latin dance. Pure fire on the dance floor: artists, contestants, workshops, parties and lots of rhythm. Not to be missed, from October 21 to 25, 2026 in Calpe (Spain).</p>
    </div>
    <div class="container cta-box">
      <div class="cta-img"><img src={img("lanegra-dance-festival-home-1-7.webp")} alt="" loading="lazy" /></div>
      <div class="cta-content">
        <p>An international Salsa and Bachata festival and dance competition.</p>
        <p class="cta-claim">Come, dance and enjoy!</p>
        <div class="cta-buttons">
          <a class="btn btn-light" href="/en/your-pass/">Buy Pass</a>
          <a class="btn btn-solid" href="/en/competition/#inscripcion">Register for the World Cup</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--navy); }

  /* CATEGORY GRID */
  .competitors .script-title { margin-bottom: 40px; }
  .cat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px 26px; }
  .cat-card { text-align: center; }
  .cat-img { border-radius: 10px; overflow: hidden; aspect-ratio: 4/3; margin-bottom: 14px; }
  .cat-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease; }
  .cat-card:hover .cat-img img { transform: scale(1.04); }
  .cat-label {
    font-family: var(--font-body); font-weight: 700; text-transform: uppercase;
    font-size: 17px; letter-spacing: .03em; margin: 0; color: var(--navy);
  }

  /* GALLERY */
  .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .gallery-item { border-radius: 10px; overflow: hidden; aspect-ratio: 1/1; }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; }

  /* FINAL CTA */
  .final-text { max-width: 820px; margin: 0 auto 36px; }
  .cta-box { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; border-radius: 16px; overflow: hidden; }
  .cta-img img { width: 100%; height: 100%; object-fit: cover; }
  .cta-content { background: linear-gradient(135deg,#14102b,#2a1f57); color: #fff; padding: 48px 44px; display: flex; flex-direction: column; justify-content: center; text-align: left; }
  .cta-claim { font-family: var(--font-script); color: var(--gold); font-size: 34px; margin: 6px 0 22px; }
  .cta-buttons { display: flex; gap: 14px; flex-wrap: wrap; }

  /* responsive */
  @media (max-width: 900px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .cta-box { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .cat-grid { grid-template-columns: 1fr; }
  }
</style>
