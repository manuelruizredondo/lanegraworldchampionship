---
import Base from "@/layouts/Base.astro";
import SubNav from "@/components/SubNav.astro";
import { img } from "@/data/img.js";

const anchorNav = [
  { label: "FESTIVAL", href: "#info" },
  { label: "ARTISTAS", href: "#artistas" },
  { label: "TALLERES", href: "#talleres" },
  { label: "FULL PASS", href: "#fullpass" },
  { label: "HOTEL", href: "#hotel" },
  { label: "CONTACTAR", href: "#contactar" },
];

const introGallery = [
  "la-negra-dance-festival-festival-img-18.webp",
  "la-negra-dance-festival-festival-img-14.webp",
  "la-negra-dance-festival-festival-img-12.webp",
  "la-negra-dance-festival-festival-img-21.webp",
  "la-negra-dance-festival-fiesta-img-.webp",
  "la-negra-dance-festival-festival-img-1.webp",
];

const artists = [
  { name: "Tito Ortos", country: "Salsa | Puerto Rico", img: "la-negra-festival-tito-ortos.webp" },
  { name: "Bersy Cortez", country: "Salsa | Venezuela", img: "la-negra-festival-bersy-cortez.webp" },
  { name: "Maykel Fonts", country: "Salsa | Cuba", img: "la-negra-festival-maykel-fonts.webp" },
  { name: "Anita Santos Rubín", country: "Salsa | Brasil", img: "la-negra-festival-anita-santos.webp" },
  { name: "Yoyo Flow", country: "Salsa | Cuba", img: "yoyo-flow.jpg" },
  { name: "Marco Ferrigno", country: "Salsa | Italia", img: "marco-ferregno.jpg" },
  { name: "Dani J", country: "En concierto | España", img: "dani-J-239x300.webp" },
  { name: "Korke y Judith", country: "Bachata | España", img: "korke-judith-bachata-la-negra-dance-festival.jpeg" },
  { name: "Gaby y Estefy", country: "Bachata | República Dominicana y España", img: "festival-evelin-la-negra-Gabi-Estefy.jpg" },
  { name: "Samy el Mágico", country: "Bachata | República Dominicana", img: "samy-el-magico-festival-la-negra-dance.jpg" },
  { name: "Darío y Sara", country: "Bachata | España", img: "dario-y-sara-240x300.webp" },
  { name: "Evelyn La Negra", country: "Bachata | Venezuela", img: "evelyn-la-negra-bachata-festival-pasos-libres_1.jpg" },
];

const talleresGallery = [
  "la-negra-dance-festival-galeria-2023-23.webp",
  "la-negra-dance-festival-galeria-2023-28.webp",
];

const hotelGallery = [
  "la-negra-dance-festival-festival-img-19.webp",
  "la-negra-dance-festival-festival-img-16.webp",
  "la-negra-dance-festival-festival-img-2.webp",
  "la-negra-dance-festival-festival-img-.webp",
  "la-negra-dance-festival-festival-img-8.webp",
  "la-negra-dance-festival-festival-img-5.webp",
];

const fiestaGallery = [
  "la-negra-dance-festival-festival-img-1.webp",
  "lanegra-dance-festival-comepeticion-2.webp",
  "la-negra-dance-festival-fiesta-img-12.webp",
  "la-negra-dance-festival-fiesta-img-7.webp",
  "la-negra-dance-festival-fiesta-img-10.webp",
];

const gdEvent = "https://www.goandance.com/es/evento/8885/la-negra-dance-festival-2026-xv-campeonato-mundial-de-pasos-libres-la-negra-salsa-v-campeonato-mundial-de-pasos-libres-la-negra-bachata";
---

<Base title="Festival" description="Festival de salsa y bachata con workshops, baile social y Campeonato Mundial. Del 21 al 25 de octubre del 2026 en Calpe (España).">
  <SubNav items={anchorNav} label="Secciones del festival" />

  <div class="prop">
    <!-- HERO -->
    <section id="info" class="p-phero" style={`background-image:url(${img("la-negra-dance-festival-festival-img-12.webp")})`}>
      <div class="p-phero-inner">
        <p class="p-eyebrow">Salsa · Bachata</p>
        <h1 class="p-phero-title">La Negra Dance Festival</h1>
        <p class="p-phero-sub">Festival de salsa y bachata con workshops, baile social y Campeonato Mundial. Del 21 al 25 de octubre de 2026 · Calpe (España).</p>
        <div class="p-phero-cta">
          <a class="p-btn p-btn-light" href="#fullpass">Comprar pase</a>
        </div>
      </div>
    </section>

    <!-- INFO + GALERÍA -->
    <section class="p-section p-center">
      <div class="p-container">
        <div class="f-info p-narrow">
          <p><strong>Lugar:</strong> Calpe, Alicante (España) — Hotel sede AR Diamante Beach 4* superior. <a href="https://maps.app.goo.gl/1Upi3tNxMANnCbZ87" target="_blank" rel="noopener">Ver mapa</a></p>
          <p><strong>Aeropuertos más cercanos:</strong> Alicante (50 min del hotel) · Valencia (1h 20min del hotel)</p>
        </div>
      </div>
      <div class="p-container">
        <div class="f-gallery">
          {introGallery.map((src) => <div class="f-g-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
        </div>
      </div>
    </section>

    <!-- ARTISTS -->
    <section id="artistas" class="p-section p-center p-gray">
      <div class="p-container">
        <p class="p-eyebrow">Salsa · Bachata</p>
        <h2 class="p-h2">Nuestros artistas invitados</h2>
        <p class="p-lead p-narrow">Cada año traemos de distintos rincones del mundo a artistas y bailarines de reconocido prestigio. Élite, talleres, playa, piscinas, fiestas y competidores de más de 20 países se unen en este gran evento.</p>
        <div class="f-artists">
          {artists.map((a) => (
            <article class="f-artist">
              <div class="f-artist-img"><img src={img(a.img)} alt={a.name} loading="lazy" /></div>
              <h3 class="f-artist-n">{a.name}</h3>
              <p class="f-artist-c">{a.country}</p>
            </article>
          ))}
        </div>
        <a class="p-btn p-btn-light" href="/artistas/">Ver todos</a>
      </div>
    </section>

    <!-- WORKSHOPS -->
    <section id="talleres" class="p-section">
      <div class="p-container f-split">
        <div class="f-split-imgs">
          {talleresGallery.map((src) => <div class="f-g-item f-g-tall"><img src={img(src)} alt="" loading="lazy" /></div>)}
        </div>
        <div class="f-split-text">
          <p class="p-eyebrow">Salsa · Bachata</p>
          <h2 class="p-h2">Talleres donde disfrutar</h2>
          <p class="p-lead">Desde aficionados hasta competidores y profesionales pueden disfrutar de talleres básicos, intermedios y avanzados en disciplinas como Salsa Cubana, On1, On2, Bachata Sensual, Tradicional, Fusión y las últimas tendencias. Masterclass solo para profesionales.</p>
          <a class="p-btn p-btn-dark" href="/talleres/">Ver todos los talleres</a>
        </div>
      </div>
    </section>

    <!-- FULL PASS -->
    <section id="fullpass" class="p-section p-center p-gray">
      <div class="p-container">
        <p class="p-eyebrow">Full Pass</p>
        <h2 class="p-h2">Nos vemos en La Negra</h2>
        <p class="p-lead p-narrow">Venta de entradas gestionada a través de <a class="f-a" href={gdEvent} target="_blank" rel="noopener">go&amp;dance</a>.</p>
        <div class="f-widget">
          <iframe
            src="https://www.goandance.com/es/event-tickets/106ef4d5-c8be-4fce-8660-ea6854726bff?referer=https%3A%2F%2Fcampeonatopasoslibres.com%2Fcompeticion%2F"
            title="Compra de Full Pass — go&dance"
            loading="lazy"
          ></iframe>
        </div>
        <p class="f-credit">Powered by <a class="f-a" href={gdEvent} target="_blank" rel="noopener">go&amp;dance</a></p>
        <a class="p-link f-gd-link" href={gdEvent} target="_blank" rel="noopener">Ir a la página de entradas ↗</a>
      </div>
    </section>

    <!-- HOTEL -->
    <section id="hotel" class="p-section">
      <div class="p-container p-center">
        <p class="p-eyebrow">AR Diamante Beach</p>
        <h2 class="p-h2">Reserva ya tu hotel</h2>
        <p class="p-lead">Sede de La Negra Dance Festival</p>
      </div>
      <div class="p-container f-hotel-grid">
        <div class="f-hotel-text">
          <p>Disfruta de una estancia inigualable en AR Diamante Beach, un referente en la Costa Blanca con vistas espectaculares al mar y al Peñón de Ifach. Sus elegantes habitaciones combinan confort y estilo para que cada despertar sea especial.</p>
          <p>Relájate en sus tres piscinas, incluida una infantil, en un entorno exclusivo con palmeras, tumbonas, cócteles y animación. ¿Playa o piscina? No elijas, disfrútalo todo, a solo unos pasos del mar.</p>
          <p>En caso de problema con la reserva pueden contactar a: <a href="mailto:reservas@galaxtur.com">reservas@galaxtur.com</a></p>
          <p class="f-warning">NOTA IMPORTANTE: tarifa exclusiva para asistentes al evento. En caso de identificar lo contrario y no presentar el Full Pass al hacer el check-in se procederá a la anulación de la reserva.</p>
          <a class="p-btn p-btn-dark" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Reserva tu hotel</a>
        </div>
        <div class="f-map">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3115.9332867988783!2d0.07065367592495361!3d38.65041427177794!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x129dfe00f86d3eef%3A0x8f672c62926e85bf!2sAR%20Diamante%20Beach!5e0!3m2!1ses!2ses!4v1742755084006!5m2!1ses!2ses"
            title="Mapa AR Diamante Beach"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
      <div class="p-container f-transfers">
        <h3 class="p-h2 f-transfers-title">¿Cómo llegar al hotel desde el aeropuerto o la estación de tren?</h3>
        <div class="f-transfers-grid">
          <div class="f-transfer">
            <h4>Transfer aeropuerto Alicante — Calpe</h4>
            <p>Llegada o despegue entre las 7:00h y las 23:55h: transfer compartido 23,50 € por persona y trayecto.</p>
          </div>
          <div class="f-transfer">
            <h4>Transfer estación de trenes Alicante — Calpe</h4>
            <p>Llegada o salida entre las 9:00h y las 20:15h: transfer compartido 18 € por persona y trayecto.</p>
          </div>
        </div>
        <p class="f-transfers-note p-lead">Una vez recibida la información se realizará la reserva y se enviará la confirmación y un enlace para el pago del transfer.</p>
        <div class="p-center">
          <a class="p-btn p-btn-light" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Reserva tu hotel</a>
        </div>
      </div>
      <div class="p-container">
        <div class="f-gallery">
          {hotelGallery.map((src) => <div class="f-g-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contactar" class="p-section p-gray">
      <div class="p-container p-center">
        <p class="p-eyebrow">La Negra Dance Festival</p>
        <h2 class="p-h2">Contacta con nosotros</h2>
      </div>
      <div class="p-container f-contact-grid">
        <form class="f-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" data-contact>
          <input type="hidden" name="form-name" value="contact" />
          <p class="f-hp" hidden><label>No rellenar: <input name="bot-field" /></label></p>
          <div class="f-row">
            <input type="text" name="nombre" placeholder="Nombre" required />
            <input type="text" name="apellidos" placeholder="Apellidos" required />
          </div>
          <div class="f-row">
            <input type="email" name="email" placeholder="Email" required />
            <input type="tel" name="telefono" placeholder="Teléfono" />
          </div>
          <input type="text" name="asunto" placeholder="Asunto" />
          <textarea name="mensaje" rows="6" placeholder="Mensaje" required></textarea>
          <label class="f-privacy">
            <input type="checkbox" name="privacidad" required />
            <span>He leído y acepto <a href="/politica-de-privacidad/">la política de privacidad y envíos electrónicos.</a></span>
          </label>
          <button class="p-btn p-btn-dark" type="submit">Enviar</button>
          <p class="f-msg" data-contact-msg hidden></p>
        </form>
        <div class="f-contact-imgs">
          {fiestaGallery.map((src) => <div class="f-g-item f-g-sq"><img src={img(src)} alt="" loading="lazy" /></div>)}
        </div>
      </div>
    </section>

    <!-- FIESTA CTA -->
    <section class="p-final">
      <div class="f-final-inner">
        <p class="p-eyebrow">Por la noche…</p>
        <h2 class="p-h2 p-white">¡Disfruta la fiesta!</h2>
        <p class="p-white-70">Después de una jornada intensa de talleres, aprendizaje y descanso… ¡tenemos fiesta! Prepárate para noches de pura energía en nuestras fiestas temáticas, con el mejor ambiente, los mejores bailarines y la mejor música.</p>
        <a class="p-btn p-btn-light" href="/fiesta/">Saber más</a>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ okMsg: "¡Gracias! Hemos recibido tu mensaje, te responderemos pronto.", errMsg: "Ups, algo falló. Inténtalo de nuevo o escríbenos por email." }}>
    (function () {
      var form = document.querySelector("[data-contact]");
      if (!form) return;
      var msg = form.querySelector("[data-contact-msg]");
      form.addEventListener("submit", function (e) {
        e.preventDefault();
        var data = new URLSearchParams(new FormData(form)).toString();
        fetch("/", { method: "POST", headers: { "Content-Type": "application/x-www-form-urlencoded" }, body: data })
          .then(function (r) { if (!r.ok) throw new Error(); form.reset(); msg.textContent = okMsg; msg.className = "f-msg ok"; msg.hidden = false; })
          .catch(function () { msg.textContent = errMsg; msg.className = "f-msg err"; msg.hidden = false; });
      });
    })();
  </script>
</Base>

<style>
  /* Intro */
  .f-date { font-weight: 600; color: var(--gold-dark); font-size: clamp(16px, 2vw, 20px); margin: -6px 0 22px; }
  .f-info { margin: 0 auto 26px; }
  .f-info p { font-size: 16px; line-height: 1.6; color: var(--p-muted); margin: 0 0 8px; }
  .f-info strong { color: var(--p-ink); }
  .f-info a, .f-a { color: var(--gold-dark); font-weight: 600; }

  /* Galerías */
  .f-gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 44px; }
  .f-g-item { border-radius: 18px; overflow: hidden; aspect-ratio: 4/3; background: var(--p-card); }
  .f-g-item img { width: 100%; height: 100%; object-fit: cover; }
  .f-g-tall { aspect-ratio: 3/4; }
  .f-g-sq { aspect-ratio: 1/1; }

  /* Artistas (bolas) */
  .f-artists { display: grid; grid-template-columns: repeat(4, 1fr); gap: 38px 28px; margin: 44px 0 36px; }
  .f-artist { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .f-artist-img {
    width: 82%; aspect-ratio: 1; overflow: hidden; margin-bottom: 16px;
    border-radius: 42% 58% 47% 53% / 52% 43% 57% 48%;
    transition: border-radius .7s ease, transform .4s ease;
  }
  .f-artist:nth-child(2n) .f-artist-img { border-radius: 58% 42% 55% 45% / 45% 57% 43% 55%; }
  .f-artist:nth-child(3n) .f-artist-img { border-radius: 50% 50% 42% 58% / 60% 40% 55% 45%; }
  .f-artist:nth-child(4n) .f-artist-img { border-radius: 46% 54% 60% 40% / 48% 58% 42% 55%; }
  .f-artist:hover .f-artist-img { border-radius: 50%; transform: translateY(-5px) scale(1.03); }
  .f-artist-img img { width: 100%; height: 100%; object-fit: cover; }
  .f-artist-n { font-weight: 600; font-size: clamp(16px, 1.4vw, 21px); letter-spacing: -.02em; color: var(--p-ink); margin: 0 0 2px; }
  .f-artist-c { font-size: 13px; color: var(--gold-dark); margin: 0; }

  /* Split (talleres) */
  .f-split { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(30px, 5vw, 64px); align-items: center; }
  .f-split-imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .f-split-text .p-lead { margin-bottom: 26px; }

  /* Full pass */
  .f-widget { max-width: 900px; margin: 8px auto 0; border-radius: var(--p-radius); overflow: hidden; box-shadow: 0 14px 40px rgba(15, 11, 30, .14); }
  .f-widget iframe { width: 100%; height: 430px; border: 0; display: block; }
  .f-credit { margin: 18px 0 6px; font-size: 13px; color: var(--p-muted); }
  .f-gd-link { display: inline-block; }

  /* Hotel */
  .f-hotel-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(30px, 5vw, 64px); align-items: start; margin-top: 8px; }
  .f-hotel-text p { font-size: 16px; line-height: 1.6; color: var(--p-muted); margin: 0 0 14px; }
  .f-hotel-text a { color: var(--gold-dark); font-weight: 600; }
  .f-warning { background: #faf3e2; border-left: 4px solid var(--gold); border-radius: 8px; padding: 14px 18px; font-size: 14px; line-height: 1.55; color: #5a4a22; font-weight: 500; }
  .f-map iframe { width: 100%; height: 420px; border: 0; border-radius: var(--p-radius); display: block; }
  .f-transfers { margin-top: 52px; }
  .f-transfers-title { text-align: center; font-size: clamp(22px, 3vw, 32px); margin-bottom: 26px; }
  .f-transfers-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 18px; }
  .f-transfer { background: var(--p-soft); border: 1px solid var(--p-line); border-radius: 16px; padding: 24px 26px; }
  .f-transfer h4 { font-weight: 700; color: var(--p-ink); margin: 0 0 8px; font-size: 16px; }
  .f-transfer p { margin: 0; color: var(--p-muted); font-size: 15px; line-height: 1.55; }
  .f-transfers-note { text-align: center; max-width: 720px; margin: 0 auto 24px; }

  /* Contacto */
  .f-contact-grid { display: grid; grid-template-columns: 1.1fr .9fr; gap: clamp(30px, 5vw, 60px); align-items: start; margin-top: 8px; }
  .f-form { display: flex; flex-direction: column; gap: 14px; }
  .f-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .f-form input[type="text"], .f-form input[type="email"], .f-form input[type="tel"], .f-form textarea {
    width: 100%; font-family: var(--font-body); font-size: 16px; color: var(--p-ink);
    padding: 13px 16px; border: 1px solid var(--p-line); border-radius: 12px; background: #fff;
  }
  .f-form input:focus, .f-form textarea:focus { outline: 2px solid var(--gold); border-color: var(--gold); }
  .f-privacy { display: flex; gap: 10px; align-items: flex-start; font-size: 14px; color: var(--p-muted); }
  .f-privacy a { color: var(--gold-dark); font-weight: 600; }
  .f-form .p-btn { align-self: flex-start; }
  .f-msg { margin: 4px 0 0; font-size: 14px; font-weight: 600; }
  .f-msg.ok { color: #1c7a3f; }
  .f-msg.err { color: #c0392b; }
  .f-contact-imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

  /* Fiesta CTA */
  .f-final-inner { max-width: 760px; margin: 0 auto; text-align: center; }

  /* Responsive */
  @media (max-width: 900px) {
    .f-gallery { grid-template-columns: repeat(2, 1fr); }
    .f-artists { grid-template-columns: repeat(2, 1fr); }
    .f-split, .f-hotel-grid, .f-transfers-grid, .f-contact-grid { grid-template-columns: 1fr; }
    .f-split-imgs { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .f-row { grid-template-columns: 1fr; }
    .f-widget iframe { height: 760px; }
  }
</style>
