---
import Base from "@/layouts/Base.astro";
import SubNav from "@/components/SubNav.astro";
import { img } from "@/data/img.js";

const subNav = [
  { label: "Inscripción", href: "#inscripcion" },
  { label: "Bases", href: "#bases" },
  { label: "Pase competición", href: "#fullpass" },
  { label: "Competidores", href: "/competidores/" },
  { label: "Ganadores 2025", href: "/ganadores-2025/" },
  { label: "Ganadores 2024", href: "/ganadores/" },
];

const FORM_URL = "https://docs.google.com/forms/d/e/1FAIpQLSfYZmv7H84x3PvdIFRJwJPQk2yU7KjQyGsu2ba5uu6kPtGapA/viewform?usp=header";

const heroGrid = [
  "lanegra-dance-festival-comepeticion-7.webp",
  "lanegra-dance-festival-comepeticion-6.webp",
  "lanegra-dance-festival-comepeticion-14.webp",
  "lanegra-dance-festival-comepeticion-13.webp",
  "lanegra-dance-festival-comepeticion-19.webp",
  "lanegra-dance-festival-comepeticion-15.webp",
];

const gallery = [
  "la-negra-dance-festival-artistas-1-6.webp",
  "la-negra-dance-festival-artistas-1-5.webp",
  "la-negra-dance-festival-artistas-1-4.webp",
  "la-negra-dance-festival-artistas-1-3.webp",
  "la-negra-dance-festival-artistas-1-7.webp",
  "la-negra-dance-festival-artistas-1-2.webp",
  "la-negra-dance-festival-artistas-1-1.webp",
  "la-negra-dance-festival-artistas-.webp",
  "la-negra-dance-festival-festival-img-5.webp",
  "la-negra-dance-festival-festival-img-6.webp",
  "la-negra-dance-festival-festival-img-8.webp",
  "la-negra-dance-festival-img-ganadores-2.webp",
  "la-negra-dance-festival-img-ganadores-3.webp",
  "la-negra-dance-festival-img-ganadores-4.webp",
  "la-negra-dance-festival-img-ganadores-5.webp",
  "la-negra-dance-festival-img-ganadores-6.webp",
  "la-negra-dance-festival-img-ganadores-7.webp",
];
---

<Base title="Competición" description="Inscripciones para el Mundial de Salsa y Bachata de La Negra Dance Festival. Descarga las bases, conoce los talleres y reserva tu hotel.">
  <SubNav items={subNav} label="Secciones de la competición" />

  <div class="prop">
    <!-- HERO / INSCRIPCIÓN -->
    <section id="inscripcion" class="p-section p-center">
      <div class="p-container">
        <p class="p-eyebrow">Salsa · Bachata</p>
        <h1 class="p-display">Inscripciones para el mundial 2026</h1>
        <span class="reg-closed c-hero-btn"><span class="btn btn-solid btn-off" aria-disabled="true" role="button" title="Inscripciones cerradas">Inscríbete ahora</span><span class="reg-note">Inscripciones cerradas: el plazo de inscripción al Mundial 2026 ha finalizado.</span></span>
        <div class="c-hero-grid">
          {heroGrid.map((src) => (
            <div class="c-g-item"><img src={img(src)} alt="" loading="lazy" /></div>
          ))}
        </div>
      </div>
    </section>

    <!-- BASES -->
    <section id="bases" class="p-section p-gray">
      <div class="p-container c-split">
        <div class="c-split-text">
          <p class="p-eyebrow">Compite en Salsa y Bachata</p>
          <h2 class="p-h2">Consulta las bases de la competición</h2>
          <div class="c-buttons">
            <a class="p-btn p-btn-dark" href="/bases-y-reglamento/#salsa">Bases Salsa</a>
            <a class="p-btn p-btn-light" href="/bases-y-reglamento/#bachata">Bases Bachata</a>
          </div>
        </div>
        <div class="c-split-imgs">
          <div class="c-g-item c-g-tall"><img src={img("la-negra-dance-festival-galeria-2023-23.webp")} alt="" loading="lazy" /></div>
          <div class="c-g-item c-g-tall"><img src={img("la-negra-dance-festival-galeria-2023-28.webp")} alt="" loading="lazy" /></div>
        </div>
      </div>
    </section>

    <!-- TALLERES -->
    <section class="p-section p-center">
      <div class="p-container">
        <p class="p-eyebrow">Salsa · Bachata</p>
        <h2 class="p-h2">Talleres donde disfrutar</h2>
        <p class="p-lead p-narrow">Todos los años traemos de diferentes rincones del mundo a artistas y bailarines de reconocido prestigio. Desde aficionados hasta competidores y profesionales pueden disfrutar de talleres de niveles básicos, intermedios y avanzados en disciplinas como: Salsa Cubana, On2, On2, Bachata Sensual, Tradicional, Fusión y las últimas tendencias. Masterclass solo para profesionales.</p>
        <a class="p-btn p-btn-dark c-mt" href="/talleres/">Ver todos los talleres</a>
      </div>
    </section>

    <!-- FULL PASS -->
    <section id="fullpass" class="p-section p-center p-gray">
      <div class="p-container">
        <p class="p-eyebrow">Full Pass</p>
        <h2 class="p-h2">Nos vemos en La Negra</h2>
        <p class="p-lead p-narrow">Consigue tu Full Pass para vivir La Negra Dance Festival al completo. Entradas gestionadas a través de nuestro partner oficial.</p>
        <div class="c-widget">
          <div id="goandance-tickets-106ef4d5-c8be-4fce-8660-ea6854726bff-iframe"><iframe height="100px" width="100%" frameborder="0" scrolling="auto" src="https://www.goandance.com/es/event-tickets/106ef4d5-c8be-4fce-8660-ea6854726bff?referer=https%3A%2F%2Fcampeonatopasoslibres.com%2Fcompeticion%2F"></iframe></div>
        </div>
        <p class="c-credit">Powered by <a class="c-a" href="https://www.goandance.com/es/evento/8885/la-negra-dance-festival-2026-xv-campeonato-mundial-de-pasos-libres-la-negra-salsa-v-campeonato-mundial-de-pasos-libres-la-negra-bachata" target="_blank" rel="noopener">go&amp;dance</a></p>
        <a class="p-link c-gd-link" href="https://www.goandance.com/es/evento/8885/la-negra-dance-festival-2026-xv-campeonato-mundial-de-pasos-libres-la-negra-salsa-v-campeonato-mundial-de-pasos-libres-la-negra-bachata" target="_blank" rel="noopener">Ir a la página de entradas ↗</a>
      </div>
    </section>

    <!-- HOTEL -->
    <section class="p-section">
      <div class="p-container p-center">
        <p class="p-eyebrow">AR Diamante Beach</p>
        <h2 class="p-h2">Reserva ya tu Hotel</h2>
        <p class="p-lead">Sede de La Negra Dance Festival</p>
      </div>
      <div class="p-container c-hotel-grid">
        <div class="c-map">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3115.9332867988783!2d0.07065367592495361!3d38.65041427177794!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x129dfe00f86d3eef%3A0x8f672c62926e85bf!2sAR%20Diamante%20Beach!5e0!3m2!1ses!2ses!4v1742755084006!5m2!1ses!2ses"
            width="100%" height="360" style="border:0" loading="lazy"
            referrerpolicy="no-referrer-when-downgrade" title="AR Diamante Beach"></iframe>
        </div>
        <div class="c-hotel-text">
          <p>Disfruta de una estancia inigualable en <strong>AR Diamante Beach</strong>, un referente en la Costa Blanca con vistas espectaculares al mar y al Peñón de Ifach. Nuestras elegantes habitaciones combinan confort y estilo para que cada despertar sea especial.</p>
          <p>Relájate en nuestras <strong>tres piscinas</strong>, incluyendo una infantil en un entorno exclusivo con palmeras, tumbonas, cócteles y animación. ¿Playa o piscina? No elijas, disfrútalo todo, a solo unos pasos del mar.</p>
          <p>En caso de problema con la reserva pueden contactar a: <a href="mailto:reservas@galaxtur.com">reservas@galaxtur.com</a></p>
          <p class="c-warning">NOTA IMPORTANTE: TARIFA EXCLUSIVA PARA ASISTENTES AL EVENTO. EN CASO DE IDENTIFICAR LO CONTRARIO Y NO PRESENTAR EL FULLPASS AL HACER EL CHECK-IN SE PROCEDERÁ A LA ANULACIÓN DE LA RESERVA.</p>
          <a class="p-btn p-btn-dark" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Reserva tu hotel</a>
        </div>
      </div>

      <div class="p-container c-transfers">
        <h3 class="p-h2 c-transfers-title">¿Cómo llegar al hotel desde el aeropuerto o la estación de tren?</h3>
        <div class="c-transfers-grid">
          <div class="c-transfer">
            <h4>Transfers aeropuerto Alicante - Calpe</h4>
            <p>Llegada o despegue entre las 7:00h y las 23:55h: Precio del transfer compartido 23.50 € por persona y trayecto</p>
          </div>
          <div class="c-transfer">
            <h4>Transfers estación de trenes Alicante - Calpe</h4>
            <p>Llegada o salida entre las 9:00h y las 20:15h: Precio del transfer compartido 18 € por persona y trayecto</p>
          </div>
        </div>
        <p class="c-transfers-note p-lead">Una vez recibida la información se realizará la reserva y se enviará la confirmación y un link para el pago del transfer.</p>
        <div class="p-center">
          <a class="p-btn p-btn-light" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Reserva tu hotel</a>
        </div>
      </div>
    </section>

    <!-- GALERÍA -->
    <section class="p-section p-tight p-gray">
      <div class="p-container">
        <div class="c-gallery">
          {gallery.map((src) => (
            <div class="c-g-item c-g-sq"><img src={img(src)} alt="" loading="lazy" /></div>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="p-final">
      <div class="p-final-inner">
        <p class="p-eyebrow">Disfruta bailando</p>
        <h2 class="p-h2 p-white">Tu festival de baile latino</h2>
        <p class="p-white-70">Tres días de salsa y bachata, para los enamorados-as del baile latino. Puro fuego en la pista: artistas, concursantes, talleres, fiesta y mucho ritmo. No te lo puedes perder, del 21 al 25 de octubre del 2026 en Calpe (España).</p>
        <p class="c-final-sub">Un festival y concurso de baile a nivel internacional de Salsa y Bachata.</p>
        <p class="c-final-claim">¡Ven, baila y disfruta!</p>
        <div class="c-final-buttons">
          <a class="p-btn p-btn-outline" href="/ganadores/">Ganadores anteriores</a>
          <a class="p-btn p-btn-light" href="/competidores/">Competidores</a>
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  /* Imágenes / galerías */
  .c-g-item { border-radius: 18px; overflow: hidden; aspect-ratio: 4/3; background: var(--p-card); }
  .c-g-item img { width: 100%; height: 100%; object-fit: cover; }
  .c-g-tall { aspect-ratio: 3/4; }
  .c-g-sq { aspect-ratio: 1/1; }

  /* Inscripción / hero */
  .c-hero-btn { margin-bottom: 40px; }
  .c-hero-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-top: 8px; }

  /* Bases (split) */
  .c-split { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(30px, 5vw, 64px); align-items: center; }
  .c-split-imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .c-buttons { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 24px; }

  /* Talleres */
  .c-mt { margin-top: 32px; }

  /* Full pass */
  .c-widget { max-width: 900px; margin: 8px auto 0; border-radius: 18px; overflow: hidden; box-shadow: 0 14px 40px rgba(15, 11, 30, .14); background: #fff; }
  .c-widget iframe { width: 100%; height: 430px; border: 0; display: block; }
  .c-credit { margin: 18px 0 6px; font-size: 13px; color: var(--p-muted); }
  .c-a { color: var(--gold-dark); font-weight: 600; }
  .c-gd-link { display: inline-block; }

  /* Hotel */
  .c-hotel-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(30px, 5vw, 64px); align-items: start; margin-top: 8px; }
  .c-map iframe { width: 100%; height: 420px; border: 0; border-radius: 18px; display: block; }
  .c-hotel-text p { font-size: 16px; line-height: 1.6; color: var(--p-muted); margin: 0 0 14px; }
  .c-hotel-text strong { color: var(--p-ink); }
  .c-hotel-text a { color: var(--gold-dark); font-weight: 600; }
  .c-warning { background: #faf3e2; border-left: 4px solid var(--gold); border-radius: 16px; padding: 14px 18px; font-size: 13px; line-height: 1.55; color: #5a4a22; font-weight: 600; }
  .c-transfers { margin-top: 52px; }
  .c-transfers-title { text-align: center; font-size: clamp(22px, 3vw, 32px); margin-bottom: 26px; }
  .c-transfers-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 18px; }
  .c-transfer { background: var(--p-soft); border: 1px solid var(--p-line); border-radius: 18px; padding: 24px 26px; }
  .c-transfer h4 { font-weight: 700; color: var(--p-ink); margin: 0 0 8px; font-size: 17px; }
  .c-transfer p { margin: 0; color: var(--p-muted); font-size: 15px; line-height: 1.55; }
  .c-transfers-note { text-align: center; max-width: 720px; margin: 0 auto 24px; }

  /* Galería */
  .c-gallery { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }

  /* Final CTA */
  .c-final-sub { max-width: 720px; margin: 0 auto 4px; color: rgba(255,255,255,.72); font-size: clamp(15px, 1.5vw, 18px); }
  .c-final-claim { font-weight: 700; letter-spacing: -.02em; color: var(--gold); font-size: clamp(24px, 3vw, 30px); margin: 10px 0 28px; }
  .c-final-buttons { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; align-items: flex-start; }

  /* Responsive */
  @media (max-width: 900px) {
    .c-hero-grid { grid-template-columns: repeat(2, 1fr); }
    .c-split, .c-hotel-grid, .c-transfers-grid { grid-template-columns: 1fr; }
    .c-gallery { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .c-hero-grid { grid-template-columns: 1fr 1fr; }
    .c-gallery { grid-template-columns: repeat(2, 1fr); }
    /* En móvil el selector se apila y necesita más altura */
    .c-widget iframe { height: 760px; }
  }
</style>
