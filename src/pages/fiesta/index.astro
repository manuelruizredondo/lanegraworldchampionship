---
import Base from "@/layouts/Base.astro";
import { img } from "@/data/img.js";

const heroImgs = [
  "fiesta-la-negra-dance-festival-foto-3.jpeg",
  "fiesta-la-negra-dance-festival-foto-1.jpeg",
  "la-negra-dance-festival-fiesta-img-1.webp",
  "la-negra-dance-festival-fiesta-img-3.webp",
  "fiesta-la-negra-dance-festival-foto-2.jpeg",
  "la-negra-dance-festival-fiesta-img-4.webp",
];

const salaSalsaImgs = [
  "fiesta-la-negra-dance-festival-foto-1.jpeg",
  "la-negra-dance-festival-fiesta-img-1.webp",
  "la-negra-dance-festival-fiesta-img-10.webp",
];
const salaBachataImgs = [
  "fiesta-la-negra-dance-festival-foto-2.jpeg",
  "la-negra-dance-festival-fiesta-img-3.webp",
  "la-negra-dance-festival-fiesta-img-12.webp",
];

const djs = [
  { name: "Fabrizio Zoro", country: "Italia", img: "fabrizio-la-negra-dance-musica-1.jpg", ig: "https://www.instagram.com/fabriziozoro/", yt: "https://www.youtube.com/channel/UCg9WHKNhujZQmfPreORPEWA" },
  { name: "DJ Legendario", country: "España", img: "WhatsApp-Image-2025-05-26-at-16.36.39.jpeg", ig: "https://www.instagram.com/alberz_legendario/" },
  { name: "Evelyn La Negra", country: "Venezuela", img: "evelyn.la_.negra-dance-festival.jpg", ig: "https://www.instagram.com/evelynlanegrasalsa/" },
  { name: "DJ Killo", country: "España", img: "hugo-leite-la-negra-dance-festival-1.jpg", ig: "https://www.instagram.com/dj.killo/" },
  { name: "DJ Salva", country: "España", img: "dj-salva-la-negra-dance-festival.jpeg", ig: "https://www.instagram.com/dj_salva_bachataysalsa/" },
  { name: "DJ Lissj", country: "Venezuela", img: "la-negra-dance-festival-fiesta-img-7.webp", ig: "https://www.instagram.com/lissettevianalovera/" },
];
const djArtists = djs.map((d) => { const p = d.name.split(" "); return { ...d, first: p[0], last: p.slice(1).join(" ") }; });

const igIcon = `<svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.8.3 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.3 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.8-.3-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.4-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.9c.1-1.2.3-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4C8.4 2.2 8.8 2.2 12 2.2zm0 4.9a4.9 4.9 0 1 0 0 9.8 4.9 4.9 0 0 0 0-9.8zm0 8.1a3.2 3.2 0 1 1 0-6.4 3.2 3.2 0 0 1 0 6.4zm6.3-8.3a1.1 1.1 0 1 1-2.3 0 1.1 1.1 0 0 1 2.3 0z"/></svg>`;
const ytIcon = `<svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor"><path d="M23 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.7-1.7C19.4 5.2 12 5.2 12 5.2s-7.4 0-8.9.4A2.5 2.5 0 0 0 1.4 7.3C1 8.8 1 12 1 12s0 3.2.4 4.7a2.5 2.5 0 0 0 1.7 1.7c1.5.4 8.9.4 8.9.4s7.4 0 8.9-.4a2.5 2.5 0 0 0 1.7-1.7C23 15.2 23 12 23 12zM9.7 15.3V8.7l5.8 3.3-5.8 3.3z"/></svg>`;

const nights = [
  { title: "Jeans & Full Color", day: "Jueves", text: "Una noche casual llena de color, confor y frescura. Combina blue jeans con tu color favorito", img: "festival-pasos-libres-fiesta-dias-1.jpeg" },
  { title: "White Party!", day: "Viernes", text: "Como ya es tradición cada viernes del festival desfilan todos los tonos de blanco", img: "festival-pasos-libres-fiesta-dias-4.jpeg" },
  { title: "Noche Elegante", day: "Sábado", text: "Viste tus mejores galas para la noche más impresionante del festival.", img: "festival-pasos-libres-fiesta-dias-3.jpeg" },
  { title: "Se tu mismo", day: "Domingo", text: "Nos encanta que te muestres tal cuál eres. Esta noche el dress code lo pones tú!", img: "festival-pasos-libres-fiesta-dias-2.jpeg" },
];

const gallery = [
  "la-negra-dance-festival-festival-img-1.webp",
  "lanegra-dance-festival-comepeticion-2.webp",
  "la-negra-dance-festival-fiesta-img-12.webp",
  "la-negra-dance-festival-fiesta-img-7.webp",
  "la-negra-dance-festival-fiesta-img-10.webp",
];
---

<Base title="La Fiesta" description="Las noches más bailadas del año: cuatro noches, cuatro temáticas y dos salas de baile social en La Negra Dance Festival." lang="es">
  <div class="prop">
  <!-- HERO -->
  <section class="p-section fi-hero">
    <div class="p-container fi-hero-grid">
      <div class="fi-hero-media" data-slideshow>
        {heroImgs.map((src, i) => <img class={"fi-slide" + (i === 0 ? " is-on" : "")} src={img(src)} alt="" loading={i === 0 ? "eager" : "lazy"} />)}
        <div class="fi-bars">{heroImgs.map((_, i) => <span class={i === 0 ? "is-on" : undefined}></span>)}</div>
        <div class="fi-card">
          <p class="fi-card-top">En la pista</p>
          <p class="fi-card-main">¡No pares de bailar!</p>
          <p class="fi-card-foot"><span class="fi-card-emoji">🎶</span> Salsa &amp; Bachata hasta el amanecer</p>
        </div>
      </div>
      <div class="fi-hero-text">
        <p class="p-eyebrow">Cuando cae el sol…</p>
        <h1 class="p-display fi-h1">¡Empieza la verdadera magia del festival!</h1>
        <p class="p-lead">Las noches más bailadas del año: cuatro noches, cuatro temáticas y dos salas de baile social. El mejor ambiente, los mejores bailarines y la mejor música para que no pares de bailar, vengas solo, con amigos o en pareja.</p>
        <a class="p-btn p-btn-dark" href="/tu-pase/">Consigue tu pase</a>
      </div>
    </div>
  </section>

  <!-- DOS SALAS -->
  <section class="p-section p-gray">
    <div class="p-container p-center">
      <p class="p-eyebrow">Dos salas, el doble de baile</p>
      <h2 class="p-h2">Para que disfrutes al máximo</h2>
    </div>
    <div class="p-container fi-salas">
      <article class="fi-sala" data-slideshow>
        {salaSalsaImgs.map((src, i) => <img class={"fi-slide" + (i === 0 ? " is-on" : "")} src={img(src)} alt="" loading="lazy" />)}
        <div class="fi-sala-body">
          <p class="fi-sala-tag">Baile social</p>
          <h3 class="fi-sala-t">Sala Salsa</h3>
          <p class="fi-sala-d">90% salsa de todas las épocas: romántica, clásicos, timba, sones, salsatones, animaciones y ruedas con los artistas del festival. Y un 10% de bachata para un auténtico fiestón.</p>
        </div>
      </article>
      <article class="fi-sala" data-slideshow>
        {salaBachataImgs.map((src, i) => <img class={"fi-slide" + (i === 0 ? " is-on" : "")} src={img(src)} alt="" loading="lazy" />)}
        <div class="fi-sala-body">
          <p class="fi-sala-tag">Baile social</p>
          <h3 class="fi-sala-t">Sala Bachata</h3>
          <p class="fi-sala-d">90% bachata de todos los estilos y 10% de salsa romántica. Solo los mejores éxitos de todos los tiempos y lo más reciente de tu género favorito.</p>
        </div>
      </article>
    </div>
  </section>

  <!-- DJs -->
  <section class="p-section p-center djs">
    <div class="p-container">
      <h2 class="p-h2 djs-title">Contaremos con la mejor selección musical gracias a nuestros DJs estrella</h2>
    </div>
    <div>
      <div class="p-artists" data-artists-slider>
        <div class="p-artists-track">
          <div class="p-artists-set">
            {djArtists.map((d) => (
              <div class="p-artist">
                <div class="p-artist-img"><img src={img(d.img)} alt={d.name} loading="lazy" /></div>
                <span class="p-artist-n"><span>{d.first}</span>{d.last && <span>{d.last}</span>}</span>
                <span class="p-artist-c">{d.country}</span>
                <div class="p-artist-social">
                  {d.ig && <a class="p-soc" href={d.ig} target="_blank" rel="noopener" aria-label="Instagram" set:html={igIcon}></a>}
                  {d.yt && <a class="p-soc" href={d.yt} target="_blank" rel="noopener" aria-label="YouTube" set:html={ytIcon}></a>}
                </div>
              </div>
            ))}
          </div>
          <div class="p-artists-set" aria-hidden="true">
            {djArtists.map((d) => (
              <div class="p-artist">
                <div class="p-artist-img"><img src={img(d.img)} alt={d.name} loading="lazy" /></div>
                <span class="p-artist-n"><span>{d.first}</span>{d.last && <span>{d.last}</span>}</span>
                <span class="p-artist-c">{d.country}</span>
                <div class="p-artist-social">
                  {d.ig && <a class="p-soc" href={d.ig} target="_blank" rel="noopener" aria-label="Instagram" set:html={igIcon}></a>}
                  {d.yt && <a class="p-soc" href={d.yt} target="_blank" rel="noopener" aria-label="YouTube" set:html={ytIcon}></a>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NOCHES TEMÁTICAS -->
  <section class="p-section p-center nights">
    <div class="p-container">
      <p class="p-eyebrow">Noches temáticas</p>
      <h2 class="p-h2">Un estilo para cada fiesta</h2>
      <p class="nights-intro">4 días con sus 4 fiestas, cada día con un estilo diferente. Fiestas amenizadas con la mejor música de nuestros DJs para que disfrutes bailando la mejor salsa y la mejor bachata. ¿Te lo vas a perder?</p>
      <div class="nights-grid">
        {nights.map((n) => (
          <article class="night">
            <div class="night-img">
              <img src={img(n.img)} alt={n.title} loading="lazy" />
              <span class="night-day">{n.day}</span>
            </div>
            <h4 class="night-title">{n.title}</h4>
            <p class="night-text">{n.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- EDICIONES PASADAS -->
  <section class="p-section p-center">
    <div class="p-container past-gallery">
      {gallery.map((src) => <div class="pg-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
    </div>
    <div class="p-container">
      <p class="p-eyebrow">Ediciones pasadas</p>
      <h3 class="p-h2">Revive la magia</h3>
      <p class="past-text">Sumérgete en los recuerdos y emociones de nuestras pasadas ediciones. Descubre en nuestra galería de fotos los momentos más espectaculares: bailes apasionados, talleres inolvidables, fiestas llenas de energía y competiciones vibrantes. ¡Déjate inspirar por la pasión de la bachata y prepárate para vivirlo!</p>
      <a class="p-btn p-btn-dark" href="/galeria-2024/">Ver galería</a>
    </div>
  </section>
  </div>
  <script>
    import "@/scripts/artists-slider.js";
  </script>
  <script>
    // Slideshow: las imágenes de cada bloque [data-slideshow] van cambiando en bucle
    document.querySelectorAll("[data-slideshow]").forEach((box, boxIdx) => {
      const slides = [...box.querySelectorAll(".fi-slide")];
      if (slides.length < 2) return;
      const bars = [...box.querySelectorAll(".fi-bars span")];
      let i = 0;
      const show = (n) => {
        slides.forEach((s, k) => s.classList.toggle("is-on", k === n));
        bars.forEach((b, k) => b.classList.toggle("is-on", k === n));
      };
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduce) return;
      setTimeout(() => {
        setInterval(() => { i = (i + 1) % slides.length; show(i); }, 3800);
      }, boxIdx * 700);
    });
  </script>
</Base>

<style>
  /* HERO (imagen que va cambiando + tarjeta flotante + titular al lado) */
  .fi-hero-grid { display: grid; grid-template-columns: 1.05fr 1fr; gap: clamp(28px, 5vw, 64px); align-items: center; }
  .fi-hero-media { position: relative; border-radius: 26px; overflow: hidden; aspect-ratio: 4/5; background: #14121a; box-shadow: 0 30px 70px rgba(20, 18, 26, .18); }
  .fi-slide { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 1s ease; }
  .fi-slide.is-on { opacity: 1; }
  .fi-bars { position: absolute; top: 16px; left: 16px; right: 16px; z-index: 3; display: flex; gap: 6px; }
  .fi-bars span { flex: 1; height: 3px; border-radius: 3px; background: rgba(255, 255, 255, .38); transition: background .3s; }
  .fi-bars span.is-on { background: rgba(255, 255, 255, .95); }
  .fi-card {
    position: absolute; left: 18px; right: 18px; bottom: 18px; z-index: 3;
    background: rgba(20, 18, 26, .5); -webkit-backdrop-filter: blur(14px); backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, .12); border-radius: 18px; padding: 16px 18px; color: #fff;
  }
  .fi-card-top { font-size: 13px; color: rgba(255, 255, 255, .7); margin: 0 0 4px; }
  .fi-card-main { font-size: clamp(17px, 2vw, 20px); font-weight: 600; letter-spacing: -.01em; margin: 0 0 12px; }
  .fi-card-foot { display: flex; align-items: center; gap: 8px; font-size: 14px; color: rgba(255, 255, 255, .9); margin: 0; }
  .fi-card-emoji { font-size: 18px; }
  .fi-hero-text { text-align: left; }
  .fi-h1 { font-size: clamp(34px, 4.6vw, 58px); margin-bottom: 18px; }
  .fi-hero-text .p-lead { margin-bottom: 28px; }

  /* SALAS (tarjetas de imagen que va cambiando, texto sobre degradado) */
  .fi-salas { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
  .fi-sala { position: relative; border-radius: 24px; overflow: hidden; min-height: clamp(360px, 42vw, 460px); background: #14121a; }
  .fi-sala::after { content: ""; position: absolute; inset: 0; z-index: 1; background: linear-gradient(to top, rgba(12, 9, 20, .92) 0%, rgba(12, 9, 20, .45) 45%, rgba(12, 9, 20, .1) 100%); }
  .fi-sala-body { position: absolute; z-index: 2; left: 0; right: 0; bottom: 0; padding: clamp(24px, 3vw, 34px); color: #fff; }
  .fi-sala-tag { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--gold); margin: 0 0 8px; }
  .fi-sala-t { font-size: clamp(26px, 3.4vw, 38px); font-weight: 700; letter-spacing: -.02em; margin: 0 0 10px; }
  .fi-sala-d { font-size: 14.5px; line-height: 1.6; color: rgba(255, 255, 255, .85); margin: 0; max-width: 46ch; }

  /* DJs */
  .djs-title { font-size: clamp(24px, 3vw, 34px); max-width: 820px; margin: 0 auto 40px; }

  /* NIGHTS */
  .nights { background: var(--navy); }
  .nights .p-eyebrow { color: var(--gold); }
  .nights .p-h2 { color: #fff; }
  .nights-intro { color: rgba(255,255,255,.8); max-width: 820px; margin: 0 auto 40px; font-size: 16px; line-height: 1.6; }
  .nights-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
  .night-img { position: relative; border-radius: 18px; overflow: hidden; aspect-ratio: 3/4; margin-bottom: 16px; }
  .night-img img { width: 100%; height: 100%; object-fit: cover; }
  .night-day {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 24px 12px 12px; color: #fff;
    font-family: var(--font-display); font-style: italic; font-size: 18px;
    background: linear-gradient(to top, rgba(15,11,30,.85), transparent);
  }
  .night-title { font-family: var(--font-body); font-weight: 700; text-transform: uppercase; font-size: 18px; letter-spacing: .03em; color: #fff; margin: 0 0 10px; }
  .night-text { color: rgba(255,255,255,.8); font-size: 14px; line-height: 1.55; margin: 0; }

  /* PAST */
  .past-gallery { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-bottom: 44px; }
  .pg-item { border-radius: 18px; overflow: hidden; aspect-ratio: 3/4; background: var(--p-card); }
  .pg-item img { width: 100%; height: 100%; object-fit: cover; }
  .past-text { max-width: 820px; margin: 0 auto 28px; font-size: 16px; line-height: 1.6; color: var(--p-muted); }

  /* responsive */
  @media (max-width: 900px) {
    .fi-hero-grid { grid-template-columns: 1fr; }
    .fi-hero-media { aspect-ratio: 4/3; max-height: 68vh; }
    .fi-salas { grid-template-columns: 1fr; }
    .nights-grid { grid-template-columns: repeat(2, 1fr); }
    .past-gallery { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .nights-grid { grid-template-columns: 1fr; }
    .past-gallery { grid-template-columns: repeat(2, 1fr); }
  }

  /* DJs: bolas más grandes y más separadas en escritorio (solo esta página) */
  @media (min-width: 760px) {
    .djs .p-artist { width: clamp(230px, 24vw, 320px); }
    .djs .p-artists-set { gap: clamp(44px, 5vw, 78px); padding-right: clamp(44px, 5vw, 78px); }
  }

  /* DJs: al hacer rollover salen burbujas de redes en abanico hacia arriba */
  .djs .p-artists { padding-top: 100px; }
  .djs .p-artist { position: relative; }
  /* Puente invisible sobre cada bola: mantiene el :hover al mover el ratón hacia las
     burbujas, para que no se cierren antes de poder clicarlas. Cubre la zona de padding
     superior del slider (dentro del recorte, así que no se ve). */
  .djs .p-artist::before { content: ""; position: absolute; z-index: 1; left: 0; right: 0; top: -100px; height: 104px; }
  .djs .p-artist-social { position: absolute; top: 6px; left: 50%; width: 0; height: 0; z-index: 3; pointer-events: none; }
  .djs .p-soc {
    position: absolute; left: 0; top: 0;
    width: 44px; height: 44px; margin: -22px 0 0 -22px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%; color: #fff; background: var(--gold);
    box-shadow: 0 10px 24px rgba(20, 18, 26, .28);
    opacity: 0; transform: translate(0, 0) scale(.2); pointer-events: none;
    transition: transform .55s cubic-bezier(.34, 1.56, .64, 1), opacity .3s ease, background .2s;
  }
  .djs .p-soc:hover { background: var(--gold-dark); }
  @media (hover: hover) {
    .djs .p-artist:hover { z-index: 5; }
    .djs .p-artist:hover .p-soc { opacity: 1; pointer-events: auto; }
    /* 1 red -> arriba */
    .djs .p-artist:hover .p-soc:only-child { transform: translate(0, -66px) scale(1); }
    /* 2 redes -> arriba-izquierda + arriba-derecha */
    .djs .p-artist:hover .p-soc:first-child:nth-last-child(2) { transform: translate(-54px, -52px) scale(1); }
    .djs .p-artist:hover .p-soc:nth-child(2):last-child { transform: translate(54px, -52px) scale(1); transition-delay: .06s; }
    /* 3 redes -> arriba-izq + arriba + arriba-der */
    .djs .p-artist:hover .p-soc:first-child:nth-last-child(3) { transform: translate(-68px, -46px) scale(1); }
    .djs .p-artist:hover .p-soc:nth-child(2):nth-last-child(2) { transform: translate(0, -70px) scale(1); transition-delay: .05s; }
    .djs .p-artist:hover .p-soc:nth-child(3):last-child { transform: translate(68px, -46px) scale(1); transition-delay: .1s; }
  }
</style>
