    podium: [
      "1er puesto: Tony El Haber (Italia)",
      "2do puesto: Henry Pinzón (Colombia)",
      "3er puesto: Yenier Jiménez (Costa Rica)",
    ],
  },
  {
    title: "Solista bachata femenina",
    image: "solista-femenino-bachata-2024.jpg",
    podium: [
      "1er puesto: Paula Lozano (España)",
      "2do puesto: Elena Khamsi (España)",
      "3er puesto: Reyes Lemos (España)",
    ],
  },
  {
    title: "Solista bachata masculino",
    image: "solista-masculino-bachata-2024.jpg",
    podium: [
      "1er puesto: Juan Camilo Rojas (Colombia)",
      "2do puesto: Andrés Murillo (Colombia)",
      "3er puesto: Dmitry Oleynikov (Rusia)",
    ],
  },
  {
    title: "Parejas salsa",
    image: "parejas-salsa-2024.jpg",
    podium: [
      "1er puesto: Tony El Haber y Sheida (Italia)",
      "2do puesto: Adrián Oliver y Carmen Sanz (España)",
      "3er puesto: Nicolò Cervino y Beatrice Pagliarin (Italia)",
    ],
  },
  {
    title: "Dúos Salsa Femenino",
    image: "duo-salsa-famenino-2024.jpg",
    podium: [
      "1er puesto: Federica y Miriam (Italia)",
      "2do puesto: Alicia y Vesna (Suiza)",
      "3er puesto: Ivonne y Zenaida (España)",
    ],
  },
