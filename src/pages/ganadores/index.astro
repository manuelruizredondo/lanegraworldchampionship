const gallery = [
  "lanegra-dance-festival-home-1-7.webp",
  "lanegra-dance-festival-home-3-2.webp",
  "lanegra-dance-festival-home-3-10.webp",
  "lanegra-dance-festival-home-3-13.webp",
  "lanegra-dance-festival-home-3-14.webp",
  "lanegra-dance-festival-home-3-22.webp",
  "lanegra-dance-festival-home-3-23.webp",
  "lanegra-dance-festival-home-3-26.webp",
];
---

<Base title="Ganadores 2024" description="Los ganadores del Mundial de Salsa y Bachata de La Negra Dance Festival 2024." lang="es">
  <SubNav items={subNav} label="Secciones de la competición" />
  <!-- INTRO -->
  <section class="section winners-intro text-center">
    <div class="container">
      <p class="eyebrow dark">Salsa y Bachata</p>
      <h1 class="script-title">Los ganadores de 2024</h1>
    </div>
  </section>

  <!-- WINNERS GRID -->
  <section class="section-tight winners">
    <div class="container winners-grid">
      {categories.map((c) => (
        <article class="winner-card">
          <div class="winner-img"><img src={img(c.image)} alt={c.title} loading="lazy" /></div>
          <h2 class="winner-title">{c.title}</h2>
          <ol class="podium">
            {c.podium.map((p, i) => <li class={`pos-${i + 1}`}>{p}</li>)}
          </ol>
        </article>
      ))}
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section-tight">
    <div class="container gallery-grid">
      {gallery.map((src) => <div class="gallery-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section final-cta">
    <div class="container">
      <div class="final-card text-center">
      <p class="eyebrow dark">Disfruta bailando</p>
      <h2 class="script-title">Tu festival de baile latino</h2>
      <p class="final-text">Tres días de salsa y bachata, para los enamorados-as del baile latino. Puro fuego en la pista: artistas, concursantes, talleres, fiesta y mucho ritmo. No te lo puedes perder, del 21 al 25 de octubre del 2026 en Calpe (España).</p>

        <p>Un festival y concurso de baile a nivel internacional de Salsa y Bachata.</p>
        <p class="cta-claim">¡Ven, baila y disfruta!</p>
        <div class="cta-buttons">
          <a class="btn btn-light" href="/tu-pase/">Comprar Pase</a>
          <span class="reg-closed"><span class="btn btn-solid btn-off" aria-disabled="true" role="button" title="Inscripciones cerradas">Inscríbete al Mundial</span><span class="reg-note">Inscripciones cerradas: el plazo de inscripción al Mundial 2026 ha finalizado.</span></span>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--gold); }

  .winners-intro { padding-bottom: 30px; }

  /* WINNERS GRID */
  .winners-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px 26px; }
  .winner-card { text-align: left; }
  .winner-img { border-radius: 12px; overflow: hidden; aspect-ratio: 4/3; margin-bottom: 18px; }
  .winner-img img { width: 100%; height: 100%; object-fit: cover; }
  .winner-title {
    font-family: var(--font-body); font-weight: 700; text-transform: uppercase;
    font-size: 20px; letter-spacing: .03em; color: var(--gold); margin: 0 0 14px;
  }
  .podium { list-style: none; margin: 0; padding: 0; }
  .podium li { font-size: 16px; padding: 6px 0; border-bottom: 1px solid rgba(0,0,0,.07); }
  .podium li:last-child { border-bottom: 0; }
  .podium .pos-1 { font-weight: 700; color: var(--navy); }

  /* GALLERY */
  .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .gallery-item { border-radius: 10px; overflow: hidden; aspect-ratio: 1/1; }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; }

  /* FINAL CTA */
  .final-text { max-width: 820px; margin: 0 auto 36px; }
  .cta-box { display: grid; border-radius: 16px; overflow: hidden; }
  .final-card {
    background: linear-gradient(160deg, #211c3d 0%, #0f0b1e 100%);
    border-radius: 28px;
    padding: clamp(40px, 6vw, 84px) clamp(24px, 5vw, 64px);
    color: #fff;
  }
  .final-card .script-title { color: #fff; }
  .final-card .final-text { color: rgba(255, 255, 255, .8); margin-bottom: 24px; }
  .final-card > p { color: rgba(255, 255, 255, .82); }
  .final-card .eyebrow.dark { color: var(--gold); }
  .final-card .cta-claim { color: #fff; }
  .cta-claim { font-family: var(--font-body); font-weight: 700; letter-spacing: -.02em; color: #fff; font-size: 28px; margin: 6px 0 22px; }
  .cta-buttons { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; align-items: flex-start; }

  @media (max-width: 900px) {
    .winners-grid { grid-template-columns: repeat(2, 1fr); gap: 40px 24px; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .winners-grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
