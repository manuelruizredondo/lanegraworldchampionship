---

<Base
  title="Galería 2023 — La Negra World Championship"
  description="Revive otras ediciones de La Negra World Championship con la galería de fotos de 2023."
  lang="es"
>
  <section class="section gallery-head text-center">
    <div class="container">
      <p class="eyebrow dark">Revive otras ediciones - 2023</p>
      <h1 class="script-title">¡Que se prenda fuego la tarima!</h1>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="gallery-grid">
        {images.map((name, i) => (
          <figure class="gallery-item">
            <img src={img(name)} alt={`La Negra World Championship 2023 — foto ${i + 1}`} loading="lazy" />
          </figure>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--navy); }
  .gallery-head { padding-bottom: 0; }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .gallery-item {
    margin: 0;
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 3 / 2;
    background: var(--cream);
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
  }
  .gallery-item:hover img { transform: scale(1.05); }

  @media (max-width: 900px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }
</style>
