---
import Base from "@/layouts/Base.astro";
import { img } from "@/data/img.js";

const gallery = [
  "lanegra-dance-festival-home-1-7.webp",
  "lanegra-dance-festival-home-3-2.webp",
  "lanegra-dance-festival-home-3-10.webp",
  "lanegra-dance-festival-home-3-13.webp",
  "lanegra-dance-festival-home-3-14.webp",
  "lanegra-dance-festival-home-3-22.webp",
  "lanegra-dance-festival-home-3-23.webp",
  "lanegra-dance-festival-home-3-26.webp",
];
---

<Base title="Talleres" description="Talleres y masterclass de salsa y bachata para todos los niveles. Del 21 al 25 de octubre del 2026 en Calpe (España).">
  <!-- INTRO -->
  <section class="section intro text-center">
    <div class="container">
      <p class="eyebrow dark">Salsa - Bachata</p>
      <h2 class="script-title">Próximamente talleres 2026</h2>
      <h2 class="intro-date">Del 21 al 25 de octubre del 2026 en Calpe (España)</h2>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section-tight">
    <div class="container gallery">
      {gallery.map((name) => (
        <div class="gallery-item"><img src={img(name)} alt="" loading="lazy" /></div>
      ))}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section final-cta text-center">
    <div class="container">
      <p class="eyebrow dark">Disfruta bailando</p>
      <h3 class="script-title">Tu festival de baile latino</h3>
      <p class="final-text">Tres días de salsa y bachata, para los enamorados-as del baile latino. Puro fuego en la pista: artistas, concursantes, talleres, fiesta y mucho ritmo. No te lo puedes perder, del 21 al 25 de octubre del 2026 en Calpe (España).</p>
    </div>
    <div class="container cta-box">
      <div class="cta-img"><img src={img("lanegra-dance-festival-home-1-7.webp")} alt="" loading="lazy" /></div>
      <div class="cta-content">
        <p>Un festival y concurso de baile a nivel internacional de Salsa y Bachata.</p>
        <p class="cta-claim">¡Ven, baila y disfruta!</p>
        <div class="cta-buttons">
          <a class="btn btn-light" href="/tu-pase/">Comprar Pase</a>
          <span class="reg-closed"><span class="btn btn-solid btn-off" aria-disabled="true" role="button" title="Inscripciones cerradas">Inscríbete al Mundial</span><span class="reg-note">Inscripciones cerradas: el plazo de inscripción al Mundial 2026 ha finalizado.</span></span>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--gold); }

  /* INTRO */
  .intro-date {
    font-family: var(--font-body);
    font-weight: 300;
    color: var(--text);
    font-size: clamp(20px, 3vw, 26px);
    line-height: 1.3;
    margin: 0;
  }

  /* GALLERY */
  .gallery { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .gallery-item { border-radius: 10px; overflow: hidden; aspect-ratio: 1 / 1; }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; }

  /* FINAL CTA */
  .final-text { max-width: 820px; margin: 0 auto 36px; }
  .cta-box { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; border-radius: 16px; overflow: hidden; }
  .cta-img img { width: 100%; height: 100%; object-fit: cover; }
  .cta-content { background: linear-gradient(135deg,#14102b,#2a1f57); color: #fff; padding: 48px 44px; display: flex; flex-direction: column; justify-content: center; text-align: left; }
  .cta-claim { font-family: var(--font-body); font-weight: 700; letter-spacing: -.02em; color: #fff; font-size: 28px; margin: 6px 0 22px; }
  .cta-buttons { display: flex; gap: 14px; flex-wrap: wrap; align-items: flex-start; }

  /* responsive */
  @media (max-width: 900px) {
    .gallery { grid-template-columns: repeat(2, 1fr); }
    .cta-box { grid-template-columns: 1fr; }
  }
</style>
