---
import Base from "@/layouts/Base.astro";
import EventSchema from "@/components/EventSchema.astro";
import { img } from "@/data/img.js";
import { ARTISTS_IT } from "@/data/artists.js";

// Propuesta de home — estructura tipo "Board" (Nixtio) adaptada a La Negra Dance Festival.
const pillars = [
  {
    tag: "Vieni a competere",
    title: "Il Mondiale",
    desc: "Iscriviti al Campionato Mondiale di Salsa e Bachata e gareggia davanti a una giuria di élite internazionale.",
    cta: "Scopri la competizione",
    href: "/it/competition/",
    img: img("festival-negra-dance-home-1.jpg"),
  },
  {
    tag: "Vieni al festival",
    title: "Il Festival",
    desc: "Workshop, feste, show e hotel-spa fronte mare. Vivilo come pubblico nella migliore compagnia.",
    cta: "Scopri il festival",
    href: "/it/festival/",
    img: img("lanegra-dance-festival-comepeticion-7.webp"),
  },
];

const features = [
  { title: "Gli Artisti", desc: "Entra e scopri la costellazione di stelle della salsa e della bachata che avrai come maestri, giudici e compagni di ballo.", cta: "Vedi artisti", href: "/it/artists/", img: img("la-negra-dance-festival-galeria-2023-23.webp") },
  { title: "Workshop", desc: "Workshop e masterclass per il tuo livello (base, medio, avanzato o master) in tutti gli stili di salsa e bachata.", cta: "Vedi workshop", href: "/it/workshops/", img: img("la-negra-dance-festival-galeria-2023-10.webp") },
  { title: "La festa", desc: "Due sale di ballo social fino all'alba: salsa e bachata in tutte le loro varianti con i migliori DJ.", cta: "Scopri la festa", href: "/it/fiesta/", img: "/img/2025/03/lanegra-dance-festival-slide-2.webp" },
];

// Perché è il miglior evento di salsa e bachata: 4 argomenti con la loro pagina
const reasons = [
  { n: "01", t: "Artisti di livello mondiale", d: "Più di 90 leggende della salsa e della bachata ogni anno come maestri, giudici e compagni di pista. Un cartellone che nessun altro festival riunisce.", cta: "Scopri gli artisti", href: "/it/artists/" },
  { n: "02", t: "L'unico Mondiale di Pasos Libres", d: "Il campionato più prestigioso del ballo latino: coreografie 100% in anteprima, giuria d'élite e concorrenti da più di 20 paesi.", cta: "Scopri il Mondiale", href: "/it/mondiale/" },
  { n: "03", t: "Un resort fronte mare", d: "Tutto accade in un unico hotel 4★ con spa sul Mediterraneo: dormi, impari, competi e balli senza mai uscire dal festival.", cta: "Vedi l'hotel", href: "/it/festival/#hotel" },
  { n: "04", t: "XV edizioni di storia", d: "Dal 2010, crescendo ogni anno. Quindici edizioni fanno del festival il punto di riferimento veterano della salsa e della bachata.", cta: "Edizioni precedenti", href: "/it/edizioni/" },
];

const values = [
  { t: "Livello", d: "L'unico Mondiale con coreografie 100% in anteprima e una giuria di primo livello.", img: img("lanegra-dance-festival-comepeticion-19.webp") },
  { t: "Comunità", d: "Ballerini di oltre 35 paesi uniti dalla stessa passione.", img: img("festival-pasos-negra-dance-2.jpeg") },
  { t: "Emozione", d: "Momenti che fanno venire la pelle d'oca e restano con te molto dopo il festival.", img: img("la-negra-dance-festival-fiesta-img-1.webp") },
];

const stats = [
  { n: "35+", l: "Paesi" },
  { n: "90+", l: "Artisti" },
  { n: "15", l: "Edizioni" },
  { n: "5.000+", l: "Ballerini" },
];

// Mapa de nacionalidades: [país, asistentes, x%, y%] (cifras editables)
// Mapa de nacionalidades: país, asistentes, posición (x/y %), altura de varilla (h px)
const mapPins = [
  { l: "Spagna", n: 3200, x: 47.2, y: 25.5, h: 150, big: true },
  { l: "Portogallo", n: 170, x: 45.7, y: 28, h: 56 },
  { l: "Francia", n: 180, x: 48.6, y: 21.5, h: 96 },
  { l: "Regno Unito", n: 230, x: 47.6, y: 18.5, h: 144 },
  { l: "Germania", n: 260, x: 50.4, y: 21.5, h: 62 },
  { l: "Italia", n: 640, x: 51.6, y: 24.5, h: 114 },
  { l: "USA", n: 150, x: 21, y: 27.5, h: 110 },
  { l: "Canada", n: 110, x: 25, y: 13.5, h: 66 },
  { l: "Messico", n: 210, x: 19, y: 37.5, h: 62 },
  { l: "Cuba", n: 130, x: 26.3, y: 39.5, h: 122 },
  { l: "Rep. Dominicana", n: 90, x: 28.6, y: 41.5, h: 58 },
  { l: "Venezuela", n: 110, x: 29.2, y: 47.5, h: 100 },
  { l: "Colombia", n: 240, x: 26.6, y: 51.5, h: 64 },
  { l: "Brasile", n: 140, x: 33.5, y: 60, h: 112 },
  { l: "Argentina", n: 95, x: 29.8, y: 74, h: 70 },
  { l: "Corea del Sud", n: 120, x: 80, y: 27, h: 62 },
  { l: "Giappone", n: 140, x: 83.5, y: 25.5, h: 120 },
  { l: "Australia", n: 80, x: 85.5, y: 62, h: 84 },
];
const pinColors = ["#cc9933", "#14121a", "#a28243"];

// Llama animada del marquee: capa exterior + corazón, con parpadeo tipo fuego
const fire = `<svg class="p-fire" viewBox="0 0 24 24" aria-hidden="true"><path class="p-fire-o" fill="#ee7b1e" d="M13.5.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8C20 8.61 17.41 3.8 13.5.67z"/><path class="p-fire-i" fill="#ffc93c" d="M11.71 19c-1.78 0-3.22-1.4-3.22-3.14 0-1.62 1.05-2.76 2.81-3.12 1.77-.36 3.6-1.21 4.62-2.58.39 1.29.59 2.65.59 4.04 0 2.65-2.15 4.8-4.8 4.8z"/></svg>`;

// Nombre en dos líneas (nombre / apellidos) y en Título (evita nombres en MAYÚSCULAS del dataset)
const titleCase = (s) =>
  s.toLowerCase().replace(/(^|[\s\-])([a-záéíóúñü])/g, (m, p, c) => p + c.toUpperCase());
const artists = ARTISTS_IT.map((a) => {
  const parts = titleCase(a.name).split(" ");
  return { ...a, first: parts[0], last: parts.slice(1).join(" ") };
});
---

<Base
  lang="it"
  title="La Negra Dance Festival — Il miglior festival di Salsa e Bachata · Calpe 2026"
  description="Il miglior evento di salsa e bachata: più di 90 artisti d'élite, l'unico Mondiale con coreografie 100% in anteprima, resort fronte mare e XV edizioni. Calpe, 21–25 ottobre 2026."
  heroOverlay={true}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={img("la-negra-dance-festival-festival-img-12.webp")} fetchpriority="high" />
  </Fragment>
  <EventSchema lang="it" />
  <div class="prop">
    <!-- HERO (oscuro) -->
    <section class="p-hero">
      <video class="p-hero-video" autoplay muted loop playsinline preload="metadata" poster={img("la-negra-dance-festival-festival-img-12.webp")} src="https://res.cloudinary.com/u8ppc8of/video/upload/v1784387656/VIDEOWEB2025LANEGRACHAMPIONSCHIP_wpnfc8_vq3jps.mp4"></video>
      <div class="p-hero-inner">
        <p class="p-hero-date"><span>21–25 OCT 2026</span><span>Calpe · Spagna</span></p>
        <div class="p-hero-cta">
          <a class="p-btn p-btn-light" href="/it/mondiale/">Scopri il Mondiale</a>
          <a class="p-btn p-btn-outline" href="/it/festival/">Scopri il festival</a>
        </div>
        <div class="p-hero-count" role="timer" aria-label="Conto alla rovescia per l'evento">
          <div class="p-hc"><span class="p-hc-n" data-d>0</span><span class="p-hc-l">Giorni</span></div>
          <div class="p-hc"><span class="p-hc-n" data-h>00</span><span class="p-hc-l">Ore</span></div>
          <div class="p-hc"><span class="p-hc-n" data-m>00</span><span class="p-hc-l">Min</span></div>
          <div class="p-hc"><span class="p-hc-n" data-s>00</span><span class="p-hc-l">Sec</span></div>
        </div>
      </div>
    </section>

    <!-- MARQUEE (frases grandes + fuego separador + skew con el scroll) -->
    <section class="p-marquee" aria-hidden="true" data-marquee>
      <div class="p-marquee-track">
        <div class="p-marquee-half">
          <span>Che il palco vada a fuoco!!!</span><Fragment set:html={fire} />
          <span>Che il palco vada a fuoco!!!</span><Fragment set:html={fire} />
          <span>Che il palco vada a fuoco!!!</span><Fragment set:html={fire} />
        </div>
        <div class="p-marquee-half">
          <span>Che il palco vada a fuoco!!!</span><Fragment set:html={fire} />
          <span>Che il palco vada a fuoco!!!</span><Fragment set:html={fire} />
          <span>Che il palco vada a fuoco!!!</span><Fragment set:html={fire} />
        </div>
      </div>
    </section>

    <!-- INTRO -->
    <section class="p-section">
      <div class="p-container p-intro">
        <h1 class="p-h2">Impara con i migliori.<br />Compete contro i migliori.<br /><span class="p-accent">Balla con tutti.</span></h1>
        <div class="p-intro-cols">
          <p>Dal 2010, La Negra Dance Festival si è guadagnato il titolo di miglior evento di salsa e bachata: il cartellone di artisti più importante, un Mondiale unico al mondo e ballerini da più di 35 paesi.</p>
          <p>Workshop per tutti i livelli, feste fino all'alba e l'unico Mondiale con coreografie 100% in anteprima. Tutto in un unico resort fronte mare a Calpe, quindici edizioni dopo.</p>
        </div>
      </div>
    </section>

    <!-- STATEMENT 2 (comunidad) -->
    <section class="p-section p-center">
      <div class="p-container p-narrow">
        <div class="p-badge" aria-hidden="true">
          <img class="p-badge-ring" src="/img/logo-lanegra-ring.svg" alt="" />
          <img class="p-badge-face" src="/img/logo-lanegra-face.svg" alt="" />
        </div>
        <h2 class="p-h2">Una comunità internazionale di ballerini unita dalla <span class="p-hl">salsa<svg class="p-hl-line" viewBox="0 0 500 150" preserveAspectRatio="none" aria-hidden="true"><path d="M8.1,146.2c0,0,240.6-55.6,479-13.8" pathLength="500"></path></svg></span> e dalla <span class="p-nb"><span class="p-hl p-hl-2">bachata<svg class="p-hl-line" viewBox="0 0 500 150" preserveAspectRatio="none" aria-hidden="true"><path d="M8.1,146.2c0,0,240.6-55.6,479-13.8" pathLength="500"></path></svg></span>,</span> dedita al livello, all'emozione e alla celebrazione.</h2>
        <p class="p-lead p-quote">Un luogo dove, da qualunque paese tu venga, appena metti piede in pista sei tra i tuoi.</p>
      </div>
    </section>

    <!-- PERCHÉ IL MIGLIORE (posizionamento: artisti · Mondiale · hotel · edizioni) -->
    <section class="p-section p-gray why">
      <div class="p-container p-split">
        <h2 class="p-h2">Il miglior festival<br />di salsa e bachata?</h2>
        <p class="p-lead">Non lo diciamo noi: lo dicono gli artisti che vengono, il Mondiale che nessun altro ha, il resort dove si vive e quindici edizioni che lo dimostrano.</p>
      </div>
      <div class="p-container why-grid">
        {reasons.map((r) => (
          <a class="why-card" href={r.href}>
            <span class="why-n">{r.n}</span>
            <h3 class="why-t">{r.t}</h3>
            <p class="why-d">{r.d}</p>
            <span class="p-card-link">{r.cta} →</span>
          </a>
        ))}
      </div>
    </section>

    <!-- PILLARS -->
    <section class="p-section p-tight">
      <div class="p-container p-pillars">
        {pillars.map((p) => (
          <a class="p-pillar" href={p.href}>
            <div class="p-pillar-media"><img src={p.img} alt={p.title} loading="lazy" /></div>
            <div class="p-pillar-panel">
              <span class="p-pillar-tag">{p.tag}</span>
              <h3 class="p-pillar-t">{p.title}</h3>
              <p class="p-pillar-d">{p.desc}</p>
              <span class="p-btn p-btn-light p-btn-sm">{p.cta}</span>
            </div>
          </a>
        ))}
        <span class="p-pillars-plus" aria-hidden="true">+</span>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="p-section">
      <div class="p-container p-split">
        <h2 class="p-h2">Scopri<br />tutto.</h2>
        <p class="p-lead">Quattro giorni di ballo senza sosta: artisti leggendari, workshop per il tuo livello e feste che non dimenticherai.</p>
      </div>
      <div class="p-container p-cards">
        {features.map((f) => (
          <a class="p-card" href={f.href}>
            <div class="p-card-media"><img src={f.img} alt={f.title} loading="lazy" /></div>
            <div class="p-card-panel">
              <h3 class="p-card-t">{f.title}</h3>
              <p class="p-card-d">{f.desc}</p>
              <span class="p-card-link">{f.cta} →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- STATEMENT 3 -->
    <section class="p-section p-center">
      <div class="p-container p-narrow">
        <h2 class="p-display">Cresciamo<br />ballando insieme.</h2>
        <p class="p-lead">Qui non vieni a un evento: entri in una comunità che si ritrova ogni anno di fronte al Mediterraneo.</p>
        <div class="p-cta-row">
          <a class="p-btn p-btn-dark" href="/it/your-pass/">Acquista pass</a>
          <div class="p-btn-off-wrap">
            <span class="p-btn p-btn-off" aria-disabled="true" title="Le iscrizioni al Mondiale 2026 sono chiuse">Iscriviti al Mondiale*</span>
            <p class="p-cta-note">*Iscrizioni per i concorrenti chiuse.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- VALUES -->
    <section class="p-section p-gray">
      <div class="p-container p-values">
        <div class="p-values-head">
          <p class="p-eyebrow">I nostri valori</p>
          <h2 class="p-h2">Ciò che ci<br />rende unici.</h2>
        </div>
        <div class="p-values-list">
          {values.map((v, i) => (
            <div class={i === 0 ? "p-value active" : "p-value"} data-img={v.img} role="button" tabindex="0">
              <h3 class="p-value-t">{v.t}</h3>
              <p class="p-value-d">{v.d}</p>
            </div>
          ))}
        </div>
        <div class="p-values-media"><img src={values[0].img} alt="La Negra Dance Festival" loading="lazy" /></div>
      </div>
    </section>

    <!-- STATS -->
    <section class="p-stats">
      <div class="p-container p-stats-row">
        {stats.map((s) => (
          <div class="p-stat"><span class="p-stat-n">{s.n}</span><span class="p-stat-l">{s.l}</span></div>
        ))}
      </div>
    </section>

    <!-- PHOTO BAND (parallax interior + mensaje de internacionalidad) -->
    <section class="p-band">
      <div class="p-band-media">
        <img src={img("la-negra-dance-festival-fiesta-img-12.webp")} alt="" loading="lazy" />
      </div>
      <div class="p-band-content">
        <p class="p-band-eyebrow">35+ paesi · 5 continenti</p>
        <h2 class="p-band-title">Il mondo intero<br />balla a Calpe.</h2>
        <p class="p-band-sub">Lingue diverse, un solo linguaggio. Ogni ottobre, ballerini di tutto il pianeta si danno appuntamento di fronte al Mediterraneo.</p>
      </div>
    </section>

    <!-- WORLD MAP (nacionalidades) -->
    <section class="p-map-sec">
      <div class="p-container p-center p-map-head">
        <p class="p-eyebrow">Nazionalità</p>
        <h2 class="p-h2">Da ogni angolo<br />del pianeta.</h2>
      </div>
      <div class="p-map" data-map>
        <div class="p-map-plane">
          <img class="p-map-img" src="/img/world-map-dots.svg" alt="Mappa delle nazionalità dei partecipanti" width="2370" height="1104" loading="lazy" />
          {mapPins.map((p, i) => (
            <div
              class={p.big ? "p-pin p-pin-big" : "p-pin"}
              data-x={p.x}
              data-y={p.y}
              style={`left:${p.x}%; top:${p.y}%; --pin-d:${i * 80}ms; --stem:${p.h}px; --dot:${Math.round(8 + Math.min(14, Math.sqrt(p.n) / 4))}px; --pin-c:${p.big ? "#cc9933" : pinColors[i % 3]}`}
            >
              <span class="p-pin-bubble"><span class="p-pin-n" data-count={p.n}>{String(p.n).replace(/\B(?=(\d{3})+(?!\d))/g, ".")}</span></span>
              <span class="p-pin-l">{p.l}</span>
              <span class="p-pin-stem"></span>
              <span class="p-pin-hit"></span>
            </div>
          ))}
        </div>
      </div>
      {/* Móvil: rejilla de cifras siempre visible (sin hover, sin solapes) */}
      <div class="p-container p-map-grid">
        {[...mapPins].sort((a, b) => b.n - a.n).map((p) => (
          <div class="p-map-chip">
            <span class="p-map-chip-n">{String(p.n).replace(/\B(?=(\d{3})+(?!\d))/g, ".")}</span>
            <span class="p-map-chip-l">{p.l}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ARTISTS -->
    <section class="p-section p-center">
      <div class="p-container">
        <h2 class="p-display">I nostri artisti.</h2>
        <p class="p-lead p-narrow">Le stelle internazionali della salsa e della bachata che faranno ardere il palco.</p>
      </div>
      <div class="p-artists" data-artists-slider>
        <div class="p-artists-track">
          <div class="p-artists-set">
            {artists.map((a) => (
          <div class="p-artist">
            <div class="p-artist-img"><img src={img(a.img)} alt={a.name} loading="lazy" /></div>
            <span class="p-artist-n"><span>{a.first}</span>{a.last && <span>{a.last}</span>}</span>
            <span class="p-artist-c">{a.country}</span>
          </div>
        ))}
          </div>
          <div class="p-artists-set" aria-hidden="true">
            {artists.map((a) => (
          <div class="p-artist">
            <div class="p-artist-img"><img src={img(a.img)} alt={a.name} loading="lazy" /></div>
            <span class="p-artist-n"><span>{a.first}</span>{a.last && <span>{a.last}</span>}</span>
            <span class="p-artist-c">{a.country}</span>
          </div>
        ))}
          </div>
        </div>
      </div>
      <div class="p-container">
        <a class="p-btn p-btn-dark" href="/it/artists/">Vedi tutti gli artisti</a>
      </div>
    </section>

    <!-- FINAL CTA (oscuro) -->
    <section class="p-final">
      <div class="p-container p-final-inner">
        <h2 class="p-display p-white">Ci vediamo a<br />Calpe 2026.</h2>
        <p class="p-lead p-white-70">Prenota il tuo Full Pass per La Negra Dance Festival e vivi il Mondiale di Salsa e Bachata.</p>
        <div class="p-hero-cta">
          <a class="p-btn p-btn-light" href="/it/your-pass/">Acquista il tuo pass</a>
          <a class="p-btn p-btn-outline" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Prenota hotel</a>
        </div>
      </div>
    </section>
  </div>
  <script>
    import "@/scripts/home.js";
  </script>
</Base>
