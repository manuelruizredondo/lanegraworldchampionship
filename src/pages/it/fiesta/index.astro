---
import Base from "@/layouts/Base.astro";
import { img } from "@/data/img.js";

const heroImgs = [
  "fiesta-la-negra-dance-festival-foto-3.jpeg",
  "fiesta-la-negra-dance-festival-foto-1.jpeg",
  "la-negra-dance-festival-fiesta-img-1.webp",
  "la-negra-dance-festival-fiesta-img-3.webp",
  "fiesta-la-negra-dance-festival-foto-2.jpeg",
  "la-negra-dance-festival-fiesta-img-4.webp",
];

const djs = [
  { name: "Fabrizio Zoro", country: "Italia", img: "fabrizio-la-negra-dance-musica-1.jpg", ig: "https://www.instagram.com/fabriziozoro/", yt: "https://www.youtube.com/channel/UCg9WHKNhujZQmfPreORPEWA" },
  { name: "DJ Legendary", country: "Spagna", img: "WhatsApp-Image-2025-05-26-at-16.36.39.jpeg", ig: "https://www.instagram.com/alberz_legendario/" },
  { name: "Evelyn La Negra", country: "Venezuela", img: "evelyn.la_.negra-dance-festival.jpg", ig: "https://www.instagram.com/evelynlanegrasalsa/" },
  { name: "DJ Killo", country: "Spagna", img: "hugo-leite-la-negra-dance-festival-1.jpg", ig: "https://www.instagram.com/dj.killo/" },
  { name: "DJ Salva", country: "Spagna", img: "dj-salva-la-negra-dance-festival.jpeg", ig: "https://www.instagram.com/dj_salva_bachataysalsa/" },
  { name: "DJ Lissj", country: "Venezuela", img: "la-negra-dance-festival-fiesta-img-7.webp", ig: "https://www.instagram.com/lissettevianalovera/" },
];
const djArtists = djs.map((d) => { const p = d.name.split(" "); return { ...d, first: p[0], last: p.slice(1).join(" ") }; });

const igIcon = `<svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.8.3 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.3 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.8-.3-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.4-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.9c.1-1.2.3-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4C8.4 2.2 8.8 2.2 12 2.2zm0 4.9a4.9 4.9 0 1 0 0 9.8 4.9 4.9 0 0 0 0-9.8zm0 8.1a3.2 3.2 0 1 1 0-6.4 3.2 3.2 0 0 1 0 6.4zm6.3-8.3a1.1 1.1 0 1 1-2.3 0 1.1 1.1 0 0 1 2.3 0z"/></svg>`;
const ytIcon = `<svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor"><path d="M23 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.7-1.7C19.4 5.2 12 5.2 12 5.2s-7.4 0-8.9.4A2.5 2.5 0 0 0 1.4 7.3C1 8.8 1 12 1 12s0 3.2.4 4.7a2.5 2.5 0 0 0 1.7 1.7c1.5.4 8.9.4 8.9.4s7.4 0 8.9-.4a2.5 2.5 0 0 0 1.7-1.7C23 15.2 23 12 23 12zM9.7 15.3V8.7l5.8 3.3-5.8 3.3z"/></svg>`;

const nights = [
  { title: "Jeans & Full Color", day: "Giovedì", text: "Una serata casual piena di colore, comfort e freschezza. Abbina i tuoi jeans blu al tuo colore preferito", img: "festival-pasos-libres-fiesta-dias-1.jpeg" },
  { title: "White Party!", day: "Venerdì", text: "Come ormai da tradizione, ogni venerdì del festival sfilano tutte le sfumature del bianco.", img: "festival-pasos-libres-fiesta-dias-4.jpeg" },
  { title: "Serata Elegante", day: "Sabato", text: "Vestiti al meglio per la serata più spettacolare del festival.", img: "festival-pasos-libres-fiesta-dias-3.jpeg" },
  { title: "Be yourself", day: "Domenica", text: "Adoriamo che tu ti mostri per come sei. Stasera il dress code lo decidi tu!", img: "festival-pasos-libres-fiesta-dias-2.jpeg" },
];

const gallery = [
  "la-negra-dance-festival-festival-img-1.webp",
  "lanegra-dance-festival-comepeticion-2.webp",
  "la-negra-dance-festival-fiesta-img-12.webp",
  "la-negra-dance-festival-fiesta-img-7.webp",
  "la-negra-dance-festival-fiesta-img-10.webp",
];
---

<Base title="Festa" description="Le notti più ballate dell'anno: quattro notti, quattro temi e due sale di ballo sociale al La Negra Dance Festival." lang="it">
  <!-- HERO -->
  <section class="section fiesta-hero text-center">
    <div class="container">
      <p class="eyebrow dark">Quando il sole tramonta…</p>
      <h1 class="script-title">Inizia la vera magia del festival!</h1>
      <h2 class="hero-sub">Le notti più ballate dell'anno sono arrivate</h2>
      <div class="hero-cols">
        <p>I workshop e la competizione sono solo l'inizio. Preparati a notti di pura energia alle nostre feste a tema, dove la migliore atmosfera, i migliori ballerini e la migliore musica ti faranno vivere un'esperienza indimenticabile.</p>
        <p>Non importa se vieni da solo, con gli amici o in coppia: sulla pista da ballo troverai sempre qualcuno con cui condividere il ritmo. Quattro notti, quattro temi, un solo obiettivo: che tu non smetta mai di ballare.</p>
      </div>
    </div>
    <div class="container hero-gallery">
      {heroImgs.map((src) => <div class="hg-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
    </div>
  </section>

  <!-- TWO ROOMS -->
  <section class="section rooms text-center">
    <div class="container">
      <p class="eyebrow dark">Due sale, doppio ballo</p>
      <h2 class="script-title">Per il tuo massimo divertimento</h2>
      <div class="rooms-grid">
        <article class="room">
          <h3 class="script-title room-title">Sala Salsa</h3>
          <p>90% Salsa di tutti i tempi: romantica, grandi classici, timba, sones, salsatones, animazioni e ruedas con tutti gli artisti del festival e 10% di bachata per farti vivere una vera festa.</p>
        </article>
        <article class="room">
          <h3 class="script-title room-title">Sala Bachata</h3>
          <p>90% bachata di tutti gli stili e 10% salsa romántica. Ascolterai solo i migliori successi di tutti i tempi e i più recenti del tuo genere preferito.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- DJs -->
  <section class="section djs text-center">
    <div class="container">
      <h2 class="script-title djs-title">Avremo la migliore selezione musicale grazie ai nostri DJ stellari</h2>
    </div>
    <div class="prop">
      <div class="p-artists" data-artists-slider>
        <div class="p-artists-track">
          <div class="p-artists-set">
            {djArtists.map((d) => (
              <div class="p-artist">
                <div class="p-artist-img"><img src={img(d.img)} alt={d.name} loading="lazy" /></div>
                <span class="p-artist-n"><span>{d.first}</span>{d.last && <span>{d.last}</span>}</span>
                <span class="p-artist-c">{d.country}</span>
                <div class="p-artist-social">
                  {d.ig && <a class="p-soc" href={d.ig} target="_blank" rel="noopener" aria-label="Instagram" set:html={igIcon}></a>}
                  {d.yt && <a class="p-soc" href={d.yt} target="_blank" rel="noopener" aria-label="YouTube" set:html={ytIcon}></a>}
                </div>
              </div>
            ))}
          </div>
          <div class="p-artists-set" aria-hidden="true">
            {djArtists.map((d) => (
              <div class="p-artist">
                <div class="p-artist-img"><img src={img(d.img)} alt={d.name} loading="lazy" /></div>
                <span class="p-artist-n"><span>{d.first}</span>{d.last && <span>{d.last}</span>}</span>
                <span class="p-artist-c">{d.country}</span>
                <div class="p-artist-social">
                  {d.ig && <a class="p-soc" href={d.ig} target="_blank" rel="noopener" aria-label="Instagram" set:html={igIcon}></a>}
                  {d.yt && <a class="p-soc" href={d.yt} target="_blank" rel="noopener" aria-label="YouTube" set:html={ytIcon}></a>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THEME NIGHTS -->
  <section class="section nights text-center">
    <div class="container">
      <p class="eyebrow dark">Notti a tema</p>
      <h2 class="script-title">Uno stile per ogni festa</h2>
      <p class="nights-intro">4 giorni con 4 feste, ogni giorno con uno stile diverso. Feste animate dalla migliore musica dei nostri DJ per farti divertire ballando la migliore salsa e bachata. Te la lascerai sfuggire?</p>
      <div class="nights-grid">
        {nights.map((n) => (
          <article class="night">
            <div class="night-img">
              <img src={img(n.img)} alt={n.title} loading="lazy" />
              <span class="night-day">{n.day}</span>
            </div>
            <h4 class="night-title">{n.title}</h4>
            <p class="night-text">{n.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PAST EDITIONS -->
  <section class="section past text-center">
    <div class="container past-gallery">
      {gallery.map((src) => <div class="pg-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
    </div>
    <div class="container">
      <p class="eyebrow dark">Edizioni passate</p>
      <h3 class="script-title">Rivivi la magia</h3>
      <p class="past-text">Immergiti nei ricordi e nelle emozioni delle nostre edizioni passate. Scopri nella nostra galleria fotografica i momenti più spettacolari: balli appassionati, workshop indimenticabili, feste piene di energia e competizioni vibranti: lasciati ispirare dalla passione della bachata e preparati a viverla!</p>
      <a class="btn btn-solid" href="/it/gallery-2023/">Vedi la galleria</a>
    </div>
  </section>
  <script>
    import "@/scripts/artists-slider.js";
  </script>
</Base>

<style>
  .eyebrow.dark { color: var(--gold); }

  /* HERO */
  .hero-sub { font-family: var(--font-body); font-weight: 700; text-transform: uppercase; font-size: 22px; letter-spacing: .03em; color: var(--navy); margin: 6px 0 26px; }
  .hero-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; text-align: left; max-width: 1000px; margin: 0 auto; }
  .hero-cols p { font-size: 15px; }
  .hero-gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 44px; }
  .hg-item { border-radius: 10px; overflow: hidden; aspect-ratio: 4/3; }
  .hg-item img { width: 100%; height: 100%; object-fit: cover; }

  /* ROOMS */
  .rooms { background: var(--cream); }
  .rooms-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 12px; }
  .room { padding: 0 10px; }
  .room-title { font-size: 32px; color: var(--gold); margin: 0 0 14px; }
  .room p { font-size: 15px; }

  /* DJs */
  .djs-title { font-size: 30px; max-width: 820px; margin: 0 auto 40px; }
  .djs-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 20px; }
  .dj-img { border-radius: 10px; overflow: hidden; aspect-ratio: 3/4; margin-bottom: 12px; }
  .dj-img img { width: 100%; height: 100%; object-fit: cover; }
  .dj-name { font-family: var(--font-body); font-weight: 700; text-transform: uppercase; font-size: 16px; letter-spacing: .03em; color: var(--navy); margin: 0 0 4px; }
  .dj-country { font-family: var(--font-body); font-weight: 400; font-size: 15px; color: var(--gold-dark); margin: 0 0 10px; }
  .dj-social { display: flex; gap: 8px; justify-content: center; }
  .dj-social a { display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; background: var(--gold); color: #fff; }
  .dj-social a:hover { background: var(--gold-dark); }

  /* NIGHTS */
  .nights { background: var(--navy); }
  .nights .eyebrow.dark { color: var(--gold); }
  .nights .script-title { color: #fff; }
  .nights-intro { color: var(--cream); max-width: 820px; margin: 0 auto 40px; font-size: 15px; }
  .nights-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
  .night-img { position: relative; border-radius: 10px; overflow: hidden; aspect-ratio: 3/4; margin-bottom: 16px; }
  .night-img img { width: 100%; height: 100%; object-fit: cover; }
  .night-day {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 24px 12px 12px; color: #fff;
    font-family: var(--font-display); font-style: italic; font-size: 18px;
    background: linear-gradient(to top, rgba(15,11,30,.85), transparent);
  }
  .night-title { font-family: var(--font-body); font-weight: 700; text-transform: uppercase; font-size: 18px; letter-spacing: .03em; color: #fff; margin: 0 0 10px; }
  .night-text { color: var(--cream); font-size: 14px; margin: 0; }

  /* PAST */
  .past-gallery { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-bottom: 44px; }
  .pg-item { border-radius: 10px; overflow: hidden; aspect-ratio: 3/4; }
  .pg-item img { width: 100%; height: 100%; object-fit: cover; }
  .past-text { max-width: 820px; margin: 0 auto 28px; font-size: 15px; }

  /* responsive */
  @media (max-width: 900px) {
    .hero-cols { grid-template-columns: 1fr; gap: 14px; }
    .hero-gallery { grid-template-columns: repeat(2, 1fr); }
    .rooms-grid { grid-template-columns: 1fr; gap: 30px; }
    .djs-grid { grid-template-columns: repeat(3, 1fr); }
    .nights-grid { grid-template-columns: repeat(2, 1fr); }
    .past-gallery { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .hero-gallery { grid-template-columns: 1fr; }
    .djs-grid { grid-template-columns: repeat(2, 1fr); }
    .nights-grid { grid-template-columns: 1fr; }
    .past-gallery { grid-template-columns: repeat(2, 1fr); }
  }

  /* DJs: bolas más grandes y más separadas en escritorio (solo esta página) */
  @media (min-width: 760px) {
    .djs .p-artist { width: clamp(230px, 24vw, 320px); }
    .djs .p-artists-set { gap: clamp(44px, 5vw, 78px); padding-right: clamp(44px, 5vw, 78px); }
  }

  /* DJs: al hacer rollover salen burbujas de redes en abanico hacia arriba */
  .djs .p-artists { padding-top: 100px; }
  .djs .p-artist { position: relative; }
  /* Puente invisible sobre cada bola: mantiene el :hover al mover el ratón hacia las
     burbujas, para que no se cierren antes de poder clicarlas. Cubre la zona de padding
     superior del slider (dentro del recorte, así que no se ve). */
  .djs .p-artist::before { content: ""; position: absolute; z-index: 1; left: 0; right: 0; top: -100px; height: 104px; }
  .djs .p-artist-social { position: absolute; top: 6px; left: 50%; width: 0; height: 0; z-index: 3; pointer-events: none; }
  .djs .p-soc {
    position: absolute; left: 0; top: 0;
    width: 44px; height: 44px; margin: -22px 0 0 -22px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%; color: #fff; background: var(--gold);
    box-shadow: 0 10px 24px rgba(20, 18, 26, .28);
    opacity: 0; transform: translate(0, 0) scale(.2); pointer-events: none;
    transition: transform .55s cubic-bezier(.34, 1.56, .64, 1), opacity .3s ease, background .2s;
  }
  .djs .p-soc:hover { background: var(--gold-dark); }
  @media (hover: hover) {
    .djs .p-artist:hover { z-index: 5; }
    .djs .p-artist:hover .p-soc { opacity: 1; pointer-events: auto; }
    /* 1 red -> arriba */
    .djs .p-artist:hover .p-soc:only-child { transform: translate(0, -66px) scale(1); }
    /* 2 redes -> arriba-izquierda + arriba-derecha */
    .djs .p-artist:hover .p-soc:first-child:nth-last-child(2) { transform: translate(-54px, -52px) scale(1); }
    .djs .p-artist:hover .p-soc:nth-child(2):last-child { transform: translate(54px, -52px) scale(1); transition-delay: .06s; }
    /* 3 redes -> arriba-izq + arriba + arriba-der */
    .djs .p-artist:hover .p-soc:first-child:nth-last-child(3) { transform: translate(-68px, -46px) scale(1); }
    .djs .p-artist:hover .p-soc:nth-child(2):nth-last-child(2) { transform: translate(0, -70px) scale(1); transition-delay: .05s; }
    .djs .p-artist:hover .p-soc:nth-child(3):last-child { transform: translate(68px, -46px) scale(1); transition-delay: .1s; }
  }
</style>
