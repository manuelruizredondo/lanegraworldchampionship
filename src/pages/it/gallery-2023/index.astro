<Base title="Galleria 2023 — La Negra World Championship" description="Galleria fotografica dell'edizione 2023 di La Negra World Championship." lang="it">
  <section class="section gallery-head text-center">
    <div class="container">
      <p class="eyebrow dark">Galleria Fotografica</p>
      <h1 class="script-title">Rivivi le altre edizioni – 2023</h1>
      <p class="gallery-sub">faccio il DJ per infiammare la pista !</p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="gallery-grid">
        {photos.map((name) => (
          <div class="gallery-item">
            <img src={img(name)} alt="La Negra World Championship 2023" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--gold); }
  .gallery-head { padding-bottom: 30px; }
  .gallery-sub { font-family: var(--font-script); color: var(--gold); font-size: 28px; margin: 8px 0 0; }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .gallery-item {
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .4s ease;
  }
  .gallery-item:hover img { transform: scale(1.05); }

  @media (max-width: 900px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); gap: 12px; }
  }
  @media (max-width: 600px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }
</style>
