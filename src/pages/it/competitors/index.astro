---
import Base from "@/layouts/Base.astro";
import Lightbox from "@/components/Lightbox.astro";
import SubNav from "@/components/SubNav.astro";

const subNav = [
  { label: "Iscrizione", href: "/it/competition/#registration" },
  { label: "Regolamento", href: "/it/competition/#rules" },
  { label: "Pass", href: "/it/competition/#fullpass" },
  { label: "Competitori", href: "/it/competitors/", active: true },
  { label: "Vincitori 2025", href: "/it/winners-2025/" },
  { label: "Vincitori 2024", href: "/it/winners/" },
];
import { img } from "@/data/img.js";

const categories = [
  { label: "Duo maschile salsa", img: "DUOS-MASCULINO-SALSA-2025.jpeg" },
  { label: "Duo femminile salsa", img: "DUOS-FEMENINO-SALSA-2025.jpeg" },
  { label: "Coppie salsa", img: "PAREJAS-SALSA-2025.jpeg" },
  { label: "Gruppi salsa", img: "GRUPOS-SALSA-2025.jpeg" },
  { label: "Solista femminile salsa (semi)", img: "FINAL-SOLISTAS-FEMENINO-SALSA.jpeg" },
  { label: "Solista femminile salsa", img: "ELIMINATORIA-SOLISTAS-FEMENINO-SALSA_1.jpeg" },
  { label: "Solista maschile salsa (semi)", img: "semifinal-y-final-chicos-2025.jpeg" },
  { label: "Solista maschile salsa", img: "ELIMINATORIA-SOLISTAS-MASCULINO-SALSA-2025.jpeg" },
  { label: "Solista femminile bachata", img: "SOLISTA-FEM-BACHATA-2025.jpeg" },
  { label: "Solista maschile bachata", img: "SOLISTA-MAS-BACHATA-2025.jpeg" },
  { label: "Duo bachata", img: "DUOS-BACHATA-2025.jpeg" },
  { label: "Coppie bachata", img: "PAREJAS-BACHATA-2025.jpeg" },
  { label: "Gruppi bachata", img: "equipo-bahatca-final-festival-la-negra-2.jpg" },
];

const gallery = [
  "lanegra-dance-festival-home-1-7.webp",
  "lanegra-dance-festival-home-3-2.webp",
  "lanegra-dance-festival-home-3-10.webp",
  "lanegra-dance-festival-home-3-13.webp",
  "lanegra-dance-festival-home-3-14.webp",
  "lanegra-dance-festival-home-3-22.webp",
  "lanegra-dance-festival-home-3-23.webp",
  "lanegra-dance-festival-home-3-26.webp",
];
---

<Base title="Concorrenti" description="I concorrenti della Coppa del Mondo di Salsa e Bachata del La Negra Dance Festival." lang="it">
  <SubNav items={subNav} label="Sezioni della competizione" />
  <!-- INTRO + GRID -->
  <section class="section competitors text-center">
    <div class="container">
      <p class="eyebrow dark">Salsa e Bachata</p>
      <h2 class="script-title">Concorrenti nel 2025</h2>
      <div class="cat-grid">
        {categories.map((c) => (
          <article class="cat-card">
            <div class="cat-img"><img src={img(c.img)} alt={c.label} loading="lazy" data-lightbox role="button" tabindex="0" /></div>
            <h3 class="cat-label">{c.label}</h3>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section-tight">
    <div class="container gallery-grid">
      {gallery.map((src) => (
        <div class="gallery-item"><img src={img(src)} alt="" loading="lazy" /></div>
      ))}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section final-cta text-center">
    <div class="container">
      <p class="eyebrow dark">Goditi la danza</p>
      <h2 class="script-title">Il tuo festival di danze latine</h2>
      <p class="final-text">Tre giorni di salsa e bachata, per chi ama la danza latina. Puro fuoco sulla pista da ballo: artisti, concorrenti, workshop, feste e tanto ritmo. Da non perdere, dal 21 al 25 ottobre 2026 a Calpe (Spagna).</p>
    </div>
    <div class="container cta-box">
      <div class="cta-img"><img src={img("lanegra-dance-festival-home-1-7.webp")} alt="" loading="lazy" /></div>
      <div class="cta-content">
        <p>Un festival internazionale di Salsa e Bachata e una competizione di danza.</p>
        <p class="cta-claim">Vieni, balla e divertiti!</p>
        <div class="cta-buttons">
          <a class="btn btn-light" href="/it/your-pass/">Acquista il Pass</a>
          <span class="reg-closed"><span class="btn btn-solid btn-off" aria-disabled="true" role="button" title="Iscrizioni chiuse">Iscriviti alla Coppa del Mondo</span><span class="reg-note">Iscrizioni chiuse: il periodo di iscrizione al Mondiale 2026 è terminato.</span></span>
        </div>
      </div>
    </div>
  </section>
  <Lightbox />
</Base>

<style>
  .eyebrow.dark { color: var(--gold); }

  /* CATEGORY GRID */
  .competitors .script-title { margin-bottom: 40px; }
  .cat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px 26px; }
  .cat-card { text-align: center; }
  .cat-img { border-radius: 10px; overflow: hidden; aspect-ratio: 3/4; margin-bottom: 14px; }
  .cat-img img { width: 100%; height: 100%; object-fit: cover; cursor: zoom-in; transition: transform .4s ease; }
  .cat-card:hover .cat-img img { transform: scale(1.04); }
  .cat-label {
    font-family: var(--font-body); font-weight: 700; text-transform: uppercase;
    font-size: 17px; letter-spacing: .03em; margin: 0; color: var(--navy);
  }

  /* GALLERY */
  .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .gallery-item { border-radius: 10px; overflow: hidden; aspect-ratio: 1/1; }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; }

  /* FINAL CTA */
  .final-text { max-width: 820px; margin: 0 auto 36px; }
  .cta-box { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; border-radius: 16px; overflow: hidden; }
  .cta-img img { width: 100%; height: 100%; object-fit: cover; }
  .cta-content { background: linear-gradient(135deg,#14102b,#2a1f57); color: #fff; padding: 48px 44px; display: flex; flex-direction: column; justify-content: center; text-align: left; }
  .cta-claim { font-family: var(--font-body); font-weight: 700; letter-spacing: -.02em; color: #fff; font-size: 28px; margin: 6px 0 22px; }
  .cta-buttons { display: flex; gap: 14px; flex-wrap: wrap; align-items: flex-start; }

  /* responsive */
  @media (max-width: 900px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .cta-box { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .cat-grid { grid-template-columns: 1fr; }
  }
</style>
