---
import Base from "@/layouts/Base.astro";
import { img } from "@/data/img.js";

const gallery = [
  "lanegra-dance-festival-home-1-7.webp",
  "lanegra-dance-festival-home-3-2.webp",
  "lanegra-dance-festival-home-3-10.webp",
  "lanegra-dance-festival-home-3-13.webp",
  "lanegra-dance-festival-home-3-14.webp",
  "lanegra-dance-festival-home-3-22.webp",
  "lanegra-dance-festival-home-3-23.webp",
  "lanegra-dance-festival-home-3-26.webp",
];
---

<Base title="Workshop" description="Workshop e masterclass di salsa e bachata per tutti i livelli. Dal 21 al 25 ottobre 2026 a Calpe (Spagna)." lang="it">
  <!-- INTRO -->
  <section class="section intro text-center">
    <div class="container">
      <p class="eyebrow dark">Salsa – Bachata</p>
      <h2 class="script-title">Prossimi workshop 2026</h2>
      <h2 class="intro-date">Dal 21 al 25 ottobre 2026 a Calpe (Spagna)</h2>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section-tight">
    <div class="container gallery">
      {gallery.map((name) => (
        <div class="gallery-item"><img src={img(name)} alt="" loading="lazy" /></div>
      ))}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section final-cta text-center">
    <div class="container">
      <p class="eyebrow dark">Divertiti a ballare</p>
      <h3 class="script-title">Il tuo festival di danza latina</h3>
      <p class="final-text">Tre giorni di salsa e bachata, per gli innamorati della danza latina. Pura passione in pista: artisti, concorrenti, workshop, feste e tanto ritmo. Da non perdere, dal 21 al 25 ottobre 2026 a Calpe (Spagna).</p>
    </div>
    <div class="container cta-box">
      <div class="cta-img"><img src={img("lanegra-dance-festival-home-1-7.webp")} alt="" loading="lazy" /></div>
      <div class="cta-content">
        <p>Un festival internazionale di salsa e bachata e competizione di danza.</p>
        <p class="cta-claim">Vieni, balla e divertiti!</p>
        <div class="cta-buttons">
          <a class="btn btn-light" href="/it/your-pass/">Acquista il Pass</a>
          <a class="btn btn-solid" href="/it/competition/#inscripcion">Iscriviti al Mondiale</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--navy); }

  /* INTRO */
  .intro-date {
    font-family: var(--font-body);
    font-weight: 300;
    color: var(--text);
    font-size: clamp(20px, 3vw, 26px);
    line-height: 1.3;
    margin: 0;
  }

  /* GALLERY */
  .gallery { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .gallery-item { border-radius: 10px; overflow: hidden; aspect-ratio: 1 / 1; }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; }

  /* FINAL CTA */
  .final-text { max-width: 820px; margin: 0 auto 36px; }
  .cta-box { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; border-radius: 16px; overflow: hidden; }
  .cta-img img { width: 100%; height: 100%; object-fit: cover; }
  .cta-content { background: linear-gradient(135deg,#14102b,#2a1f57); color: #fff; padding: 48px 44px; display: flex; flex-direction: column; justify-content: center; text-align: left; }
  .cta-claim { font-family: var(--font-script); color: var(--gold); font-size: 34px; margin: 6px 0 22px; }
  .cta-buttons { display: flex; gap: 14px; flex-wrap: wrap; }

  /* responsive */
  @media (max-width: 900px) {
    .gallery { grid-template-columns: repeat(2, 1fr); }
    .cta-box { grid-template-columns: 1fr; }
  }
</style>
