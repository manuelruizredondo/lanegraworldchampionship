---
import Base from "@/layouts/Base.astro";
import { img } from "@/data/img.js";

const categories = [
  {
    title: "Solista femminile SALSA",
    image: "solista-femenino-salsa-2024-1.jpg",
    podium: [
      "1° posto: Yaiza Melero (Spagna)",
      "2° posto: Yolieth Barragán (USA-Messico)",
      "3° posto: Eliana Maradei (Italia)",
    ],
  },
  {
    title: "Solista maschile salsa",
    image: "solista-masculino-salsa-2024.jpg",
    podium: [
      "1° posto: Tony El Haber (Italia)",
      "2° posto: Henry Pinzón (Colombia)",
      "3° posto: Yenier Jiménez (Costa Rica)",
    ],
  },
  {
    title: "Solista femminile bachata",
    image: "solista-femenino-bachata-2024.jpg",
    podium: [
      "1° posto: Paula Lozano (Spagna)",
      "2° posto: Elena Khamsi (Spagna)",
      "3° posto: Reyes Lemos (Spagna)",
    ],
  },
  {
    title: "Solista maschile bachata",
    image: "solista-masculino-bachata-2024.jpg",
    podium: [
      "1° posto: Juan Camilo Rojas (Colombia)",
      "2° posto: Andrés Murillo (Colombia)",
      "3° posto: Dmitry Oleynikov (Russia)",
    ],
  },
  {
    title: "Coppie salsa",
    image: "parejas-salsa-2024.jpg",
    podium: [
      "1° posto: Tony El Haber & Sheida (Italia)",
      "2° posto: Adrián Oliver e Carmen Sanz (Spagna)",
      "3° posto: Nicolò Cervino e Beatrice Pagliarin (Italia)",
    ],
  },
  {
    title: "Duo salsa femminile",
    image: "duo-salsa-famenino-2024.jpg",
    podium: [
      "1° posto: Federica e Miriam (Italia)",
      "2° posto: Alicia e Vesna (Svizzera)",
      "3° posto: Ivonne e Zenaida (Spagna)",
    ],
  },
  {
    title: "Coppie bachata",
    image: "parejas-bachata-2024.jpg",
    podium: [
      "1° posto: Micaela e Francisco (Argentina)",
      "2° posto: Cristian e Shery (Messico)",
      "3° posto: Berra e Nazareth (Spagna)",
    ],
  },
  {
    title: "Gruppi salsa",
    image: "grupo-salsa-2024.jpg",
    podium: [
      "1° posto: Mambo a lo Ayala di: The Ayala Brothers (USA)",
      "2° posto: Rincón Salsero di Yénier Jiménez (Costa Rica)",
      "3° posto: Alma Dance Company di Alessandro Massaro (Italia)",
    ],
  },
  {
    title: "Gruppi bachata",
    image: "grupo-bachata-2024.jpg",
    podium: [
      "1° posto: Latin Attitude di Filipa y Pedro (Portogallo)",
      "2° posto: Impulso Dominicano di Leif Candela (Spagna)",
      "3° posto: Mangu Dance Company di Jorge El Bomba (Venezuela-Spagna)",
    ],
  },
];

const gallery = [
  "lanegra-dance-festival-home-1-7.webp",
  "lanegra-dance-festival-home-3-2.webp",
  "lanegra-dance-festival-home-3-10.webp",
  "lanegra-dance-festival-home-3-13.webp",
  "lanegra-dance-festival-home-3-14.webp",
  "lanegra-dance-festival-home-3-22.webp",
  "lanegra-dance-festival-home-3-23.webp",
  "lanegra-dance-festival-home-3-26.webp",
];
---

<Base title="Vincitori 2024" description="I vincitori della Coppa del Mondo di Salsa e Bachata al La Negra World Championship 2024." lang="it">
  <!-- INTRO -->
  <section class="section winners-intro text-center">
    <div class="container">
      <p class="eyebrow dark">Salsa e Bachata</p>
      <h1 class="script-title">I vincitori del 2024</h1>
    </div>
  </section>

  <!-- WINNERS GRID -->
  <section class="section-tight winners">
    <div class="container winners-grid">
      {categories.map((c) => (
        <article class="winner-card">
          <div class="winner-img"><img src={img(c.image)} alt={c.title} loading="lazy" /></div>
          <h2 class="winner-title">{c.title}</h2>
          <ol class="podium">
            {c.podium.map((p, i) => <li class={`pos-${i + 1}`}>{p}</li>)}
          </ol>
        </article>
      ))}
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section-tight">
    <div class="container gallery-grid">
      {gallery.map((src) => <div class="gallery-item"><img src={img(src)} alt="" loading="lazy" /></div>)}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section final-cta text-center">
    <div class="container">
      <p class="eyebrow dark">Goditi il ballo</p>
      <h2 class="script-title">Il tuo festival di danza latina</h2>
      <p class="final-text">Tre giorni di salsa e bachata, per chi ama la danza latina. Puro fuoco sulla pista da ballo: artisti, concorrenti, workshop, feste e tanto ritmo. Da non perdere, dal 21 al 25 ottobre 2026 a Calpe (Spagna).</p>
    </div>
    <div class="container cta-box">
      <div class="cta-content">
        <p>Un festival internazionale di Salsa e Bachata e una competizione di danza.</p>
        <p class="cta-claim">Vieni, balla e divertiti!</p>
        <div class="cta-buttons">
          <a class="btn btn-light" href="/it/your-pass/">Acquista il Pass</a>
          <a class="btn btn-solid" href="/it/competition/#inscripcion">Iscriviti alla Coppa del Mondo</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--navy); }

  .winners-intro { padding-bottom: 30px; }

  /* WINNERS GRID */
  .winners-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px 32px; }
  .winner-card { text-align: center; }
  .winner-img { border-radius: 12px; overflow: hidden; aspect-ratio: 4/3; margin-bottom: 18px; }
  .winner-img img { width: 100%; height: 100%; object-fit: cover; }
  .winner-title {
    font-family: var(--font-body); font-weight: 700; text-transform: uppercase;
    font-size: 20px; letter-spacing: .03em; color: var(--gold); margin: 0 0 14px;
  }
  .podium { list-style: none; margin: 0; padding: 0; }
  .podium li { font-size: 16px; padding: 6px 0; border-bottom: 1px solid rgba(0,0,0,.07); }
  .podium li:last-child { border-bottom: 0; }
  .podium .pos-1 { font-weight: 700; color: var(--navy); }

  /* GALLERY */
  .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .gallery-item { border-radius: 10px; overflow: hidden; aspect-ratio: 1/1; }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; }

  /* FINAL CTA */
  .final-text { max-width: 820px; margin: 0 auto 36px; }
  .cta-box { display: grid; border-radius: 16px; overflow: hidden; }
  .cta-content { background: linear-gradient(135deg,#14102b,#2a1f57); color: #fff; padding: 48px 44px; text-align: center; }
  .cta-claim { font-family: var(--font-script); color: var(--gold); font-size: 34px; margin: 6px 0 22px; }
  .cta-buttons { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }

  @media (max-width: 900px) {
    .winners-grid { grid-template-columns: 1fr; gap: 44px; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
