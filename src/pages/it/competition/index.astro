---
import Base from "@/layouts/Base.astro";
import SubNav from "@/components/SubNav.astro";
import { img } from "@/data/img.js";

const subNav = [
  { label: "Iscrizione", href: "#registration" },
  { label: "Regolamento", href: "#rules" },
  { label: "Pass", href: "#fullpass" },
  { label: "Competitori", href: "/it/competitors/" },
  { label: "Vincitori 2025", href: "/it/winners-2025/" },
  { label: "Vincitori 2024", href: "/it/winners/" },
];

const FORM_URL = "https://docs.google.com/forms/d/e/1FAIpQLSfYZmv7H84x3PvdIFRJwJPQk2yU7KjQyGsu2ba5uu6kPtGapA/viewform?usp=header";

const heroGrid = [
  "lanegra-dance-festival-comepeticion-7.webp",
  "lanegra-dance-festival-comepeticion-6.webp",
  "lanegra-dance-festival-comepeticion-14.webp",
  "lanegra-dance-festival-comepeticion-13.webp",
  "lanegra-dance-festival-comepeticion-19.webp",
  "lanegra-dance-festival-comepeticion-15.webp",
];

const gallery = [
  "la-negra-dance-festival-artistas-1-6.webp",
  "la-negra-dance-festival-artistas-1-5.webp",
  "la-negra-dance-festival-artistas-1-4.webp",
  "la-negra-dance-festival-artistas-1-3.webp",
  "la-negra-dance-festival-artistas-1-7.webp",
  "la-negra-dance-festival-artistas-1-2.webp",
  "la-negra-dance-festival-artistas-1-1.webp",
  "la-negra-dance-festival-artistas-.webp",
  "la-negra-dance-festival-festival-img-5.webp",
  "la-negra-dance-festival-festival-img-6.webp",
  "la-negra-dance-festival-festival-img-8.webp",
  "la-negra-dance-festival-img-ganadores-2.webp",
  "la-negra-dance-festival-img-ganadores-3.webp",
  "la-negra-dance-festival-img-ganadores-4.webp",
  "la-negra-dance-festival-img-ganadores-5.webp",
  "la-negra-dance-festival-img-ganadores-6.webp",
  "la-negra-dance-festival-img-ganadores-7.webp",
];
---

<Base title="Competizione" description="Iscrizione alla Coppa del Mondo di Salsa e Bachata al La Negra Dance Festival. Scarica il regolamento, scopri i workshop e prenota il tuo hotel." lang="it">
  <SubNav items={subNav} label="Sezioni della competizione" />
  <!-- HERO / REGISTRATION -->
  <section class="section registration text-center" id="registration">
    <div class="container">
      <p class="eyebrow dark">Salsa – Bachata</p>
      <h1 class="script-title">Iscrizione alla Coppa del Mondo 2026</h1>
      <span class="reg-closed hero-btn"><span class="btn btn-solid btn-off" aria-disabled="true" role="button" title="Iscrizioni chiuse">Iscriviti ora</span><span class="reg-note">Iscrizioni chiuse: il periodo di iscrizione al Mondiale 2026 è terminato.</span></span>
      <div class="hero-grid">
        {heroGrid.map((src) => (
          <div class="hero-cell"><img src={img(src)} alt="" loading="lazy" /></div>
        ))}
      </div>
    </div>
  </section>

  <!-- RULES -->
  <section class="section rules" id="rules">
    <div class="container rules-inner">
      <div class="rules-text">
        <p class="eyebrow dark">Gareggia in Salsa e Bachata</p>
        <h2 class="script-title">Consulta il regolamento della competizione</h2>
        <div class="rules-buttons">
          <a class="btn btn-solid" href="/it/regolamento/#salsa">Regolamento Salsa</a>
          <a class="btn btn-outline" href="/it/regolamento/#bachata">Regolamento Bachata</a>
        </div>
      </div>
      <div class="rules-imgs">
        <img src={img("la-negra-dance-festival-galeria-2023-23.webp")} alt="" loading="lazy" />
        <img src={img("la-negra-dance-festival-galeria-2023-28.webp")} alt="" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- WORKSHOPS -->
  <section class="section workshops text-center">
    <div class="container">
      <p class="eyebrow dark">Salsa – Bachata</p>
      <h2 class="script-title">Workshop da vivere</h2>
      <p class="workshops-text">Ogni anno portiamo artisti e ballerini di fama provenienti da diversi angoli del mondo. Dagli amatori ai competitori e professionisti, tutti possono godersi workshop di livello base, intermedio e avanzato in discipline come: Salsa Cubana, On1, On2, Bachata Sensual, Tradizionale, Fusion e le ultime tendenze. Masterclass riservate ai soli professionisti.</p>
      <a class="btn btn-outline" href="/it/workshops/">Vedi tutti i workshop</a>
    </div>
  </section>

  <!-- FULL PASS -->
  <section class="section fullpass text-center" id="fullpass">
    <div class="container">
      <p class="eyebrow dark">Full Pass</p>
      <h2 class="script-title">Ci vediamo a La Negra</h2>
      <p class="fullpass-text">Ottieni il tuo Full Pass per vivere appieno il La Negra Dance Festival. Biglietti gestiti tramite il nostro partner ufficiale.</p>
            <div class="fullpass-widget">
        <div id="goandance-tickets-106ef4d5-c8be-4fce-8660-ea6854726bff-iframe"><iframe height="100px" width="100%" frameborder="0" scrolling="auto" src="https://www.goandance.com/en/event-tickets/106ef4d5-c8be-4fce-8660-ea6854726bff?referer=https%3A%2F%2Fcampeonatopasoslibres.com%2Fcompeticion%2F"></iframe></div>
      </div>
      <p class="gd-credit">Powered by <a href="https://www.goandance.com/es/evento/8885/la-negra-dance-festival-2026-xv-campeonato-mundial-de-pasos-libres-la-negra-salsa-v-campeonato-mundial-de-pasos-libres-la-negra-bachata" target="_blank" rel="noopener">go&amp;dance</a></p>
      <a class="gd-link" href="https://www.goandance.com/es/evento/8885/la-negra-dance-festival-2026-xv-campeonato-mundial-de-pasos-libres-la-negra-salsa-v-campeonato-mundial-de-pasos-libres-la-negra-bachata" target="_blank" rel="noopener">Vai alla pagina dei biglietti ↗</a>
    </div>
  </section>

  <!-- HOTEL -->
  <section class="section hotel">
    <div class="container">
      <div class="hotel-head text-center">
        <p class="eyebrow dark">AR Diamante Beach</p>
        <h2 class="script-title">Prenota il tuo Hotel</h2>
        <p class="hotel-sub">Sede del La Negra Dance Festival</p>
      </div>
      <div class="hotel-grid">
        <div class="hotel-map">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3115.9332867988783!2d0.07065367592495361!3d38.65041427177794!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x129dfe00f86d3eef%3A0x8f672c62926e85bf!2sAR%20Diamante%20Beach!5e0!3m2!1ses!2ses!4v1742755084006!5m2!1ses!2ses"
            width="100%" height="360" style="border:0" loading="lazy"
            referrerpolicy="no-referrer-when-downgrade" title="AR Diamante Beach"></iframe>
        </div>
        <div class="hotel-text">
          <p>Goditi un soggiorno unico all'<strong>AR Diamante Beach</strong>, un punto di riferimento sulla Costa Blanca con viste spettacolari sul mare e sul Peñón de Ifach. Le nostre eleganti camere uniscono comfort e stile per rendere speciale ogni risveglio.</p>
          <p>Rilassati nelle nostre <strong>tre piscine</strong>, inclusa una piscina per bambini, in un ambiente esclusivo con palme, lettini, cocktail e animazione. Spiaggia o piscina? Non scegliere, goditi tutto, a pochi passi dal mare.</p>
          <p>In caso di problemi con la prenotazione, contatta: <a href="mailto:reservas@galaxtur.com">reservas@galaxtur.com</a></p>
          <p class="hotel-note">NOTA IMPORTANTE: TARIFFA ESCLUSIVA PER I PARTECIPANTI ALL'EVENTO. IN CASO DI VERIFICA DEL CONTRARIO E DI MANCATA PRESENTAZIONE DEL FULLPASS AL CHECK-IN, LA PRENOTAZIONE VERRÀ ANNULLATA.</p>
          <a class="btn btn-solid" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Prenota il tuo hotel</a>
        </div>
      </div>

      <div class="transfers">
        <h3 class="transfers-title">Come raggiungere l'hotel dall'aeroporto o dalla stazione ferroviaria?</h3>
        <div class="transfers-grid">
          <div class="transfer-card">
            <h4>Transfer aeroporto Alicante – Calpe</h4>
            <p>Arrivo o partenza tra le 7:00 e le 23:55: Prezzo del transfer condiviso 23,50 € a persona a tratta</p>
          </div>
          <div class="transfer-card">
            <h4>Transfer stazione ferroviaria Alicante – Calpe</h4>
            <p>Arrivo o partenza tra le 9:00 e le 20:15: Prezzo del transfer condiviso 18 € a persona a tratta</p>
          </div>
        </div>
        <p class="transfers-note">Una volta ricevute le informazioni, verrà effettuata la prenotazione e verranno inviati una conferma e un link per il pagamento del transfer.</p>
        <div class="text-center">
          <a class="btn btn-outline" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Prenota il tuo hotel</a>
        </div>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section-tight gallery-section">
    <div class="container">
      <div class="gallery-grid">
        {gallery.map((src) => (
          <div class="gallery-cell"><img src={img(src)} alt="" loading="lazy" /></div>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section final-cta text-center">
    <div class="container">
      <p class="eyebrow dark">Goditi il ballo</p>
      <h2 class="script-title">Il tuo festival di danza latina</h2>
      <p class="final-text">Tre giorni di salsa e bachata, per gli innamorati della danza latina. Puro fuoco in pista: artisti, concorrenti, workshop, feste e tanto ritmo. Da non perdere, dal 21 al 25 ottobre 2026 a Calpe (Spagna).</p>
      <p class="final-sub">Un festival internazionale di Salsa e Bachata e una competizione di danza.</p>
      <p class="final-claim">Vieni, balla e divertiti!</p>
      <div class="final-buttons">
        <a class="btn btn-outline" href="/it/winners/">Vincitori precedenti</a>
        <a class="btn btn-solid" href="/it/competitors/">Competitori</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--gold); }

  /* REGISTRATION / HERO */
  .registration h1 { margin-bottom: 22px; }
  .hero-btn { margin-bottom: 40px; }
  .hero-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .hero-cell { border-radius: 10px; overflow: hidden; aspect-ratio: 4/3; }
  .hero-cell img { width: 100%; height: 100%; object-fit: cover; }

  /* RULES */
  .rules { background: var(--cream); }
  .rules-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  .rules-buttons { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 12px; }
  .rules-imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .rules-imgs img { width: 100%; height: 100%; object-fit: cover; border-radius: 10px; aspect-ratio: 3/4; }

  /* WORKSHOPS */
  .workshops-text { max-width: 820px; margin: 0 auto 32px; }

  /* FULL PASS */
  .fullpass { background: linear-gradient(135deg,#14102b,#2a1f57); color: #fff; }
  .fullpass .eyebrow.dark { color: var(--gold); }
  .fullpass .script-title { color: #fff; }
  .fullpass-text { max-width: 720px; margin: 0 auto 28px; }
  .fullpass-widget {
    max-width: 100%; margin: 8px auto 0; border-radius: 16px; overflow: hidden;
    background: #fff; box-shadow: 0 18px 44px rgba(15, 11, 30, .3);
  }
  .fullpass-widget iframe { width: 100%; height: 430px; border: 0; display: block; }

  /* HOTEL */
  .hotel-sub { font-size: 18px; color: var(--gold-dark); margin-top: 6px; }
  .hotel-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; margin-top: 36px; }
  .hotel-map { border-radius: 12px; overflow: hidden; line-height: 0; }
  .hotel-text p { font-size: 15px; margin: 0 0 16px; }
  .hotel-text p a { color: var(--gold-dark); }
  .hotel-note { font-size: 13px; font-weight: 700; color: var(--navy); background: var(--cream); padding: 14px 16px; border-radius: 8px; }
  .transfers { margin-top: 56px; }
  .transfers-title { text-align: center; font-family: var(--font-body); font-weight: 700; color: var(--navy); font-size: 22px; margin-bottom: 28px; }
  .transfers-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 20px; }
  .transfer-card { background: var(--cream); border-radius: 10px; padding: 24px; }
  .transfer-card h4 { font-family: var(--font-body); font-weight: 700; color: var(--gold-dark); margin: 0 0 10px; font-size: 17px; }
  .transfer-card p { margin: 0; font-size: 15px; }
  .transfers-note { text-align: center; font-size: 14px; max-width: 720px; margin: 0 auto 22px; }

  /* GALLERY */
  .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  .gallery-cell { border-radius: 8px; overflow: hidden; aspect-ratio: 1; }
  .gallery-cell img { width: 100%; height: 100%; object-fit: cover; }

  /* FINAL CTA */
  .final-text { max-width: 820px; margin: 0 auto 18px; }
  .final-sub { max-width: 720px; margin: 0 auto 4px; }
  .final-claim { font-family: var(--font-body); font-weight: 700; letter-spacing: -.02em; color: var(--gold); font-size: 28px; margin: 6px 0 26px; }
  .final-buttons { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; align-items: flex-start; }

  /* responsive */
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: repeat(2, 1fr); }
    .rules-inner { grid-template-columns: 1fr; gap: 28px; }
    .hotel-grid { grid-template-columns: 1fr; gap: 28px; }
    .transfers-grid { grid-template-columns: 1fr; }
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .hero-grid { grid-template-columns: 1fr 1fr; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* En móvil el selector se apila y necesita más altura */
  @media (max-width: 600px) {
    .fullpass-widget iframe { height: 760px; }
  }
</style>
