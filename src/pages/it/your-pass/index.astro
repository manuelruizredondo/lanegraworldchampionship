---
import Base from "@/layouts/Base.astro";
import { img } from "@/data/img.js";

const ticketsPage = "https://www.goandance.com/es/evento/8885/la-negra-dance-festival-2026-xv-campeonato-mundial-de-pasos-libres-la-negra-salsa-v-campeonato-mundial-de-pasos-libres-la-negra-bachata";

const fiestaImgs = [
  "la-negra-dance-festival-fiesta-img-12.webp",
  "la-negra-dance-festival-fiesta-img-7.webp",
  "la-negra-dance-festival-fiesta-img-10.webp",
];
---

<Base
  title="Il tuo pass"
  description="Ottieni il tuo Full Pass per La Negra Dance Festival. Workshop, gara e festa a Calpe."
  lang="it"
>
  <div class="prop">
    <!-- PASS / COUNTDOWN -->
    <section class="p-section pass-hero p-center">
      <div class="p-container">
        <p class="p-eyebrow">Full Pass</p>
        <h1 class="p-display p-white">Ottieni il tuo pass</h1>
        <div class="p-hero-count" role="timer" aria-label="Conto alla rovescia">
          <div class="p-hc"><span class="p-hc-n" data-cd-days>0</span><span class="p-hc-l">Giorni</span></div>
          <div class="p-hc"><span class="p-hc-n" data-cd-hours>00</span><span class="p-hc-l">Ore</span></div>
          <div class="p-hc"><span class="p-hc-n" data-cd-mins>00</span><span class="p-hc-l">Min</span></div>
          <div class="p-hc"><span class="p-hc-n" data-cd-secs>00</span><span class="p-hc-l">Sec</span></div>
        </div>
      </div>
    </section>

    <!-- TICKETING (embedded go&dance widget) -->
    <section class="p-section p-center" id="tickets">
      <div class="p-container">
        <p class="p-eyebrow">Acquista il tuo biglietto</p>
        <h2 class="p-h2">Ci vediamo il 21 ottobre 2026</h2>
        <p class="p-lead p-narrow">Prenota il tuo Full Pass per goderti i workshop, la gara e la festa a La Negra Dance Festival. Pagamento sicuro tramite go&amp;dance.</p>
        <div class="goandance-embed">
          <div class="goandance-tickets" id="goandance-tickets-106ef4d5-c8be-4fce-8660-ea6854726bff">
            <div id="goandance-tickets-106ef4d5-c8be-4fce-8660-ea6854726bff-iframe"><iframe height="100px" width="100%" frameborder="0" scrolling="auto" src="https://www.goandance.com/en/event-tickets/106ef4d5-c8be-4fce-8660-ea6854726bff?referer=https%3A%2F%2Fcampeonatopasoslibres.com%2Fcompeticion%2F"></iframe></div>
          </div>
        </div>
        <p class="gd-credit">Powered by <a href={ticketsPage} target="_blank" rel="noopener">go&amp;dance</a></p>
        <a class="p-link gd-link" href={ticketsPage} target="_blank" rel="noopener">Vai alla pagina dei biglietti ↗</a>
      </div>
    </section>

    <!-- HOTEL OFICIAL (sede del festival) -->
    <section class="p-section p-gray" id="hotel">
      <div class="p-container">
        <div class="hotel-ficha">
          <div class="hotel-body">
            <p class="p-eyebrow">Alloggio ufficiale</p>
            <h2 class="p-h2">Sede di La Negra Dance Festival</h2>
            <p class="hotel-sub">AR Diamante Beach · 4★ Superior · Calpe</p>
            <p>Goditi un soggiorno impareggiabile all'<strong>AR Diamante Beach</strong>, un punto di riferimento sulla Costa Blanca con viste spettacolari sul mare e sul Peñón de Ifach. Le nostre eleganti camere uniscono comfort e stile per rendere speciale ogni risveglio.</p>
            <p>Rilassati nelle nostre <strong>tre piscine</strong>, inclusa una per bambini, in un ambiente esclusivo con palme, lettini, cocktail e animazione. Spiaggia o piscina? Non scegliere: goditi tutto, a pochi passi dal mare.</p>
            <p>In caso di problemi con la prenotazione puoi contattare: <a href="mailto:reservas@galaxtur.com">reservas@galaxtur.com</a></p>
            <p class="hotel-note">IMPORTANTE: TARIFFA ESCLUSIVA PER I PARTECIPANTI ALL'EVENTO. IN CASO DI VERIFICA CONTRARIA E MANCATA PRESENTAZIONE DEL FULLPASS AL CHECK-IN, LA PRENOTAZIONE VERRÀ ANNULLATA.</p>
            <a class="p-btn p-btn-dark" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Prenota il tuo hotel</a>
          </div>
          <div class="hotel-video-wrap">
            <video class="hotel-video" autoplay muted loop playsinline poster={img("ciudad-calpes-la-negra-dance-festival.webp")}>
              <source src="/video/ar-diamante-beach.mp4" type="video/mp4" />
            </video>
            <span class="hotel-badge">Sede ufficiale del festival</span>
          </div>
        </div>

        <div class="transfers">
          <div class="transfers-grid">
            <div class="hotel-map">
              <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3115.9332867988783!2d0.07065367592495361!3d38.65041427177794!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x129dfe00f86d3eef%3A0x8f672c62926e85bf!2sAR%20Diamante%20Beach!5e0!3m2!1ses!2ses!4v1742755084006!5m2!1ses!2ses" width="100%" height="440" style="border:0" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="AR Diamante Beach"></iframe>
            </div>
            <div class="transfers-text">
              <h3 class="p-h2 transfers-title">Come raggiungere l'hotel dall'aeroporto o dalla stazione ferroviaria?</h3>
              <div class="transfer-card">
                <h4>Transfer aeroporto Alicante - Calpe</h4>
                <p>Arrivo o partenza tra le 7:00 e le 23:55: Prezzo del transfer condiviso 23,50 € a persona per tratta</p>
              </div>
              <div class="transfer-card">
                <h4>Transfer stazione ferroviaria Alicante - Calpe</h4>
                <p>Arrivo o partenza tra le 9:00 e le 20:15: Prezzo del transfer condiviso 18 € a persona per tratta</p>
              </div>
              <p class="transfers-note">Una volta ricevute le informazioni, effettueremo la prenotazione e invieremo la conferma e un link per il pagamento del transfer.</p>
              <a class="p-btn p-btn-light" href="https://ar-hotels.actpages.com/la-negra-festival.html" target="_blank" rel="noopener">Prenota il tuo hotel</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PARTY -->
    <section class="p-section">
      <div class="p-container fiesta-inner">
        <div class="fiesta-gallery">
          {fiestaImgs.map((name) => (
            <div class="fiesta-img"><img src={img(name)} alt="Festa di La Negra Dance Festival" loading="lazy" /></div>
          ))}
        </div>
        <div class="fiesta-text">
          <p class="p-eyebrow">Di notte…</p>
          <h2 class="p-h2">Goditi la festa !</h2>
          <p>Dopo un'intensa giornata di workshop, apprendimento e riposo…c'è la festa! I workshop e la gara sono solo l'inizio. Preparati a notti di pura energia nelle nostre feste a tema, dove la migliore atmosfera, i migliori ballerini e la migliore musica ti faranno vivere un'esperienza indimenticabile.</p>
          <a class="p-btn p-btn-dark" href="/it/fiesta/">Scopri di più</a>
        </div>
      </div>
    </section>
  </div>

  <script>
    // Countdown to the start of the festival: October 21, 2026 (Spain time)
    const target = new Date("2026-10-21T00:00:00+02:00").getTime();
    const el = {
      d: document.querySelector("[data-cd-days]"),
      h: document.querySelector("[data-cd-hours]"),
      m: document.querySelector("[data-cd-mins]"),
      s: document.querySelector("[data-cd-secs]"),
    };
    const pad = (n) => String(n).padStart(2, "0");
    function tick() {
      const diff = Math.max(0, target - Date.now());
      if (el.d) el.d.textContent = String(Math.floor(diff / 86400000));
      if (el.h) el.h.textContent = pad(Math.floor(diff / 3600000) % 24);
      if (el.m) el.m.textContent = pad(Math.floor(diff / 60000) % 60);
      if (el.s) el.s.textContent = pad(Math.floor(diff / 1000) % 60);
    }
    if (el.d) { tick(); setInterval(tick, 1000); }
  </script>
</Base>

<style>
  /* PASS / COUNTDOWN (hero oscuro del sistema Board) */
  .pass-hero {
    background: radial-gradient(120% 120% at 50% 0%, #211c33 0%, #0f0b1e 65%);
    color: #fff;
  }
  .pass-hero .p-eyebrow { color: var(--gold); }

  /* TICKETING (go&dance) */
  .goandance-embed { width: 100%; max-width: 900px; margin: 8px auto 0; }
  /* El auto-resize de go&dance (postMessage) puede no dispararse; fijamos una altura razonable */
  .goandance-embed :global(iframe) {
    display: block; width: 100%; border: 0;
    min-height: 780px;
    border-radius: var(--p-radius);
  }
  .gd-credit { margin: 18px 0 6px; font-size: 13px; color: var(--p-muted); }
  .gd-credit a { color: var(--gold-dark); font-weight: 700; }
  .gd-link { display: inline-block; }

  /* HOTEL OFICIAL — sede del festival */
  .hotel-ficha { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(28px, 4vw, 56px); align-items: center; }
  .hotel-sub { font-size: 15px; font-weight: 700; color: var(--gold-dark); margin: -6px 0 20px; }
  .hotel-body > p { font-size: 16px; line-height: 1.6; color: var(--p-muted); margin: 0 0 16px; }
  .hotel-body p a { color: var(--gold-dark); font-weight: 600; }
  .hotel-note {
    font-size: 13px; font-weight: 700; color: #5a4a22;
    background: #faf3e2; border-left: 4px solid var(--gold);
    padding: 14px 18px; border-radius: 16px; margin: 0 0 22px;
  }
  .hotel-video-wrap {
    position: relative; border-radius: var(--p-radius); overflow: hidden;
    min-height: 460px; box-shadow: 0 24px 60px rgba(20, 18, 26, .14);
  }
  .hotel-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .hotel-badge {
    position: absolute; top: 18px; left: 18px; z-index: 2;
    background: var(--gold); color: #fff;
    font-size: 12px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase;
    padding: 8px 14px; border-radius: 999px; box-shadow: 0 8px 22px rgba(20, 18, 26, .3);
  }
  .transfers { margin-top: clamp(42px, 5vw, 68px); }
  .transfers-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(28px, 4vw, 56px); align-items: start; }
  .hotel-map { border-radius: var(--p-radius); overflow: hidden; line-height: 0; box-shadow: 0 18px 44px rgba(20, 18, 26, .12); }
  .hotel-map iframe { display: block; width: 100%; min-height: 440px; }
  .transfers-title { font-size: clamp(22px, 2.6vw, 30px); margin: 0 0 20px; }
  .transfer-card { background: #fff; border: 1px solid var(--p-line); border-radius: 16px; padding: 20px 22px; margin-bottom: 16px; }
  .transfer-card h4 { font-weight: 700; color: var(--gold-dark); margin: 0 0 8px; font-size: 16px; }
  .transfer-card p { margin: 0; font-size: 15px; line-height: 1.5; color: var(--p-muted); }
  .transfers-note { font-size: 14px; color: var(--p-muted); margin: 0 0 20px; }
  @media (max-width: 900px) {
    .hotel-ficha, .transfers-grid { grid-template-columns: 1fr; }
    .hotel-video-wrap { min-height: 0; aspect-ratio: 16 / 9; }
    .hotel-map { order: -1; }
  }

  /* PARTY */
  .fiesta-inner { display: grid; grid-template-columns: 1.1fr 1fr; gap: 48px; align-items: center; }
  .fiesta-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .fiesta-img { border-radius: 18px; overflow: hidden; aspect-ratio: 3/4; }
  .fiesta-img:first-child { grid-column: 1 / -1; aspect-ratio: 16/9; }
  .fiesta-img img { width: 100%; height: 100%; object-fit: cover; }
  .fiesta-text > p { font-size: 16px; line-height: 1.6; color: var(--p-muted); margin: 0 0 22px; }
  @media (max-width: 900px) {
    .fiesta-inner { grid-template-columns: 1fr; gap: 30px; }
  }

  /* En móvil el selector se apila y necesita más altura */
  @media (max-width: 600px) {
    .goandance-embed :global(iframe) { min-height: 760px; }
  }
</style>
