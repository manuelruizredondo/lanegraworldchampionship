---
import Base from "@/layouts/Base.astro";
import { img } from "@/data/img.js";

const YEARS = [
  { year: "2024", href: "/it/gallery-2024/", cover: "la-negra-dance-festival-img-ganadores-7.webp", sub: "Vincitori, workshop e le migliori feste dell'edizione 2024." },
  { year: "2023", href: "/it/gallery-2023/", cover: "la-negra-dance-festival-galeria-2023-27.webp", sub: "Rivivi in immagini tutto ciò che è successo nel 2023." },
];
---

<Base title="Galleria" description="Galleria fotografica di La Negra Dance Festival: rivivi ogni edizione in immagini." lang="it">
  <section class="section intro text-center">
    <div class="container">
      <p class="eyebrow dark">La Negra Dance Festival</p>
      <h1 class="script-title">Galleria fotografica</h1>
      <p class="intro-sub">Rivivi ogni edizione del festival in immagini: la competizione, i workshop e le feste indimenticabili.</p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container gal-grid">
      {YEARS.map((y) => (
        <a class="gal-card" href={y.href}>
          <div class="gal-img"><img src={img(y.cover)} alt={`Galleria ${y.year}`} loading="lazy" /></div>
          <div class="gal-body">
            <span class="gal-year">{y.year}</span>
            <p class="gal-sub">{y.sub}</p>
            <span class="gal-link">Guarda le foto →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .eyebrow.dark { color: var(--gold); }
  .intro-sub { max-width: 620px; margin: 8px auto 0; color: #6a6a74; font-size: 17px; line-height: 1.6; }

  .gal-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 28px; max-width: 900px; }
  .gal-card {
    display: block; border: 1px solid #ece8e1; border-radius: 16px; overflow: hidden; background: #fff;
    text-decoration: none; color: inherit; transition: box-shadow .2s ease, transform .2s ease;
  }
  .gal-card:hover { box-shadow: 0 18px 40px rgba(20, 18, 26, .1); transform: translateY(-4px); }
  .gal-img { aspect-ratio: 3 / 2; overflow: hidden; background: var(--cream); }
  .gal-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
  .gal-card:hover .gal-img img { transform: scale(1.05); }
  .gal-body { padding: 20px 22px 24px; }
  .gal-year {
    display: block; font-family: var(--font-body); font-weight: 800; font-size: clamp(30px, 5vw, 44px);
    line-height: 1; letter-spacing: -.03em; color: #14121a; margin-bottom: 8px;
  }
  .gal-sub { color: #5a5a64; font-size: 15px; line-height: 1.55; margin: 0 0 12px; }
  .gal-link { font-weight: 700; font-size: 14px; color: var(--gold-dark); }

  @media (max-width: 640px) { .gal-grid { grid-template-columns: 1fr; } }
</style>
