---
import "../styles/global.css";
import "../styles/proposal.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsApp from "../components/WhatsApp.astro";
import Analytics from "../components/Analytics.astro";
import { routeFor } from "../data/routes.js";
import { img } from "../data/img.js";

const DEFAULT_DESC = {
  es: "Festival y campeonato internacional de Salsa y Bachata. Del 21 al 25 de octubre del 2026 en Calpe (España).",
  en: "International Salsa and Bachata festival and championship. From October 21 to 25, 2026 in Calpe (Spain).",
  it: "Festival e campionato internazionale di Salsa e Bachata. Dal 21 al 25 ottobre 2026 a Calpe (Spagna).",
};

const SKIP_LABEL = {
  es: "Saltar al contenido",
  en: "Skip to content",
  it: "Vai al contenuto",
};

const {
  title = "La Negra Dance Festival",
  description,
  lang = "es",
  heroOverlay = false,
  image,
} = Astro.props;

const desc = description || DEFAULT_DESC[lang] || DEFAULT_DESC.es;
const fullTitle = title.includes("La Negra") ? title : `${title} — La Negra Dance Festival`;

// URLs absolutas para canonical / og / hreflang
const site = Astro.site ?? new URL("https://campeonatopasoslibres.com");
const canonical = new URL(Astro.url.pathname, site);
// og:image: foto por página (prop `image`) o, por defecto, una foto del festival
const ogImage = new URL(image ? img(image) : img("festival-negra-dance-home-1.jpg"), site);
const alternates = routeFor(Astro.url.pathname);
const OG_LOCALE = { es: "es_ES", en: "en_US", it: "it_IT" };

// Entidad de marca (JSON-LD Organization) en todas las páginas: ayuda a
// buscadores y motores de IA a identificar la marca y sus perfiles oficiales.
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "La Negra Dance Festival",
  alternateName: ["Campeonato Mundial de Pasos Libres", "La Negra World Championship"],
  url: site.href,
  logo: new URL("/img/2025/03/logotipo-def-lanegra-dance-festival.png", site).href,
  sameAs: [
    "https://www.instagram.com/lanegraworldchampionship/",
    "https://www.instagram.com/lanegraworldchampionship/",
    "https://www.facebook.com/lanegradancefestival",
    "https://www.youtube.com/user/LaNegraSalsa1",
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    {alternates && (
      <>
        <link rel="alternate" hreflang="es" href={new URL(alternates.es, site)} />
        <link rel="alternate" hreflang="en" href={new URL(alternates.en, site)} />
        <link rel="alternate" hreflang="it" href={new URL(alternates.it, site)} />
        <link rel="alternate" hreflang="x-default" href={new URL(alternates.es, site)} />
      </>
    )}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="La Negra Dance Festival" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={OG_LOCALE[lang] || "es_ES"} />
    <meta property="og:image:alt" content={fullTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#0f0b1e" />
    <link rel="icon" href="/img/favicon/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://res.cloudinary.com" />
    {/* Fuente Inter — solo los pesos usados (300–800) y carga NO bloqueante */}
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" />
    </noscript>
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} is:inline />
    <slot name="head" />
  </head>
  <body class={heroOverlay ? "hero-overlay" : undefined}>
    <a class="skip-link" href="#main">{SKIP_LABEL[lang] || SKIP_LABEL.es}</a>
    <Header lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <WhatsApp lang={lang} />
    <Analytics lang={lang} />
  </body>
</html>
